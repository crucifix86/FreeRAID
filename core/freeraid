cmd_smart() {
    local dev="${1:-}"
    [ -z "$dev" ] && die "Usage: freeraid smart <device>"
    [ -b "$dev" ] || die "Device $dev not found"
    require smartctl

    local raw
    raw=$(smartctl -j -x "$dev" 2>/dev/null || true)
    [ -z "$raw" ] && { echo '{"error":"smartctl returned no data"}'; return; }

    # Parse key fields with jq, provide safe defaults for missing fields
    echo "$raw" | jq '{
        device:            (.device.name // ""),
        type:              (.device.type // ""),
        model:             (.model_name // .model_family // "Unknown"),
        serial:            (.serial_number // ""),
        firmware:          (.firmware_version // ""),
        capacity_bytes:    (.user_capacity.bytes // 0),
        rotation_rate:     (.rotation_rate // 0),
        smart_supported:   (.smart_support.available // false),
        smart_enabled:     (.smart_support.enabled // false),
        smart_passed:      (.smart_status.passed // null),
        temp:              (.temperature.current // null),
        temp_max:          (.temperature.drive_trip // null),
        power_on_hours:    (.power_on_hours.hours // null),
        power_cycles:      (.power_cycle_count // null),
        reallocated_sectors: (
            .ata_smart_attributes.table[]?
            | select(.id == 5) | .raw.value
        ) // null,
        pending_sectors: (
            .ata_smart_attributes.table[]?
            | select(.id == 197) | .raw.value
        ) // null,
        uncorrectable: (
            .ata_smart_attributes.table[]?
            | select(.id == 198) | .raw.value
        ) // null,
        attributes: (
            [.ata_smart_attributes.table[]? | {
                id:    .id,
                name:  .name,
                value: .value,
                worst: .worst,
                thresh:.thresh,
                raw:   .raw.string,
                flags: {
                    prefailure: .flags.prefailure,
                    updated:    .flags.updated_online,
                    failed:     (.value < .thresh)
                }
            }]
        ),
        nvme_health: (
            if .nvme_smart_health_information_log then {
                critical_warning:     .nvme_smart_health_information_log.critical_warning,
                media_errors:         .nvme_smart_health_information_log.media_errors,
                num_err_log_entries:  .nvme_smart_health_information_log.num_err_log_entries,
                percentage_used:      .nvme_smart_health_information_log.percentage_used,
                data_units_read:      .nvme_smart_health_information_log.data_units_read,
                data_units_written:   .nvme_smart_health_information_log.data_units_written
            } else null end
        ),
        self_tests: (
            [.ata_smart_self_test_log.standard.table[]? | {
                num:    .num,
                type:   .type.string,
                status: .status.string,
                remaining: .lifetime_hours
            }] | .[0:5]
        )
    } // {"error":"parse failed"}'
}

