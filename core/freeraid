    local name="${1:-}" val="${2:-false}"
    [ -z "$name" ] && die "Usage: freeraid docker-autoupdate-set <name> <true|false>"
    [ "$val" = "true" ] || val="false"
    jq --arg n "$name" --argjson v "$val" \
        '.docker.autoupdate[$n] = $v' "$CONFIG_FILE" > /tmp/freeraid.conf.tmp \
        && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    info "Auto-update for $name set to $val"
}

cmd_docker_autoupdate_get() {
    # Returns JSON object: { "name": true/false, ... }
    jq -r '.docker.autoupdate // {}' "$CONFIG_FILE" 2>/dev/null || echo '{}'
}

cmd_docker_update() {
    # Pull latest image for a container and restart if the image changed
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid docker-update <name>"
    local f="${COMPOSE_DIR}/${name}.docker-compose.yml"
    [ -f "$f" ] || die "No compose file found for: $name"
    require docker

    # Get current image ID before pull
    local container_name image old_id new_id
    container_name=$(python3 -c "
import json
try:
    d = json.load(open('$f'))
    svcs = d.get('services', {})
    svc = next(iter(svcs.values()), {})
    print(svc.get('container_name', list(svcs.keys())[0] if svcs else '$name'))
except: print('$name')
" 2>/dev/null || echo "$name")

    image=$(python3 -c "
import json
try:
    d = json.load(open('$f'))
    svcs = d.get('services', {})
    svc = next(iter(svcs.values()), {})
    print(svc.get('image', ''))
except: print('')
" 2>/dev/null || echo "")

    [ -z "$image" ] && die "Could not determine image for $name"

    old_id=$(docker inspect --format '{{.Id}}' "$image" 2>/dev/null || echo "")

    info "Pulling latest image for $name ($image)..."
    docker pull "$image" 2>&1 || { warn "Pull failed for $name"; return 1; }

    new_id=$(docker inspect --format '{{.Id}}' "$image" 2>/dev/null || echo "")

    if [ "$old_id" = "$new_id" ] && [ -n "$old_id" ]; then
        info "$name is already up to date."
        echo '{"name":"'"$name"'","updated":false,"image":"'"$image"'"}'
        return 0
    fi

    info "New image available — restarting $name..."
    docker_compose -f "$f" up -d 2>&1
    cmd_notify_send "container_updated" "Container $name updated to latest image ($image)" 2>/dev/null || true
    info "$name updated and restarted."
    echo '{"name":"'"$name"'","updated":true,"image":"'"$image"'"}'
}

cmd_docker_update_all() {
    # Update all containers that have auto-update enabled
    require docker
    local autoupdate
    autoupdate=$(jq -r '.docker.autoupdate // {} | to_entries[] | select(.value==true) | .key' "$CONFIG_FILE" 2>/dev/null || echo "")

    if [ -z "$autoupdate" ]; then
        info "No containers have auto-update enabled."
        return 0
    fi

    local updated=0 failed=0
    while IFS= read -r name; do
        [ -z "$name" ] && continue
        local f="${COMPOSE_DIR}/${name}.docker-compose.yml"
        if [ ! -f "$f" ]; then
            warn "Skipping $name — compose file not found"
            continue
        fi
        info "Checking $name..."
        if cmd_docker_update "$name" 2>&1; then
            updated=$(( updated + 1 ))
        else
            failed=$(( failed + 1 ))
            warn "Update failed for $name"
        fi
    done <<< "$autoupdate"

    info "Auto-update complete: $updated checked, $failed failed."
}

cmd_install_deps() {
    info "Installing FreeRAID dependencies..."
    apt-get update -qq
    apt-get install -y \
        mergerfs snapraid jq xfsprogs btrfs-progs \
        samba nfs-kernel-server cockpit \
        curl ca-certificates gnupg \
        smartmontools \
        2>&1 | grep -E '(Setting up|already|Error)' || true

    # Docker — try official repo first, fall back to distro package
    if ! command -v docker &>/dev/null; then
        info "Installing Docker..."
        if curl -fsSL https://get.docker.com | sh 2>/dev/null; then
            info "Docker installed via official script"
        else
            apt-get install -y docker.io docker-compose 2>&1 | grep -E '(Setting up|already|Error)' || true
        fi
    fi

    # Ensure docker-compose is available (v1 fallback if v2 plugin missing)
    if ! docker compose version &>/dev/null 2>&1 && ! command -v docker-compose &>/dev/null; then
        apt-get install -y docker-compose 2>&1 | grep -E '(Setting up|already|Error)' || true
    fi

    systemctl enable --now docker 2>/dev/null || true
    info "All dependencies installed."
}

