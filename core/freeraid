cmd_docker_list() {
    if [ ! -d "$COMPOSE_DIR" ]; then
        echo "[]"
        return 0
    fi

    local running
    running=$(docker ps --format '{{.Names}}' 2>/dev/null || echo "")

    local result="["
    local first=true

    for f in "$COMPOSE_DIR"/*.docker-compose.yml; do
        [ -f "$f" ] || continue
        local basename="${f##*/}"
        local name="${basename%.docker-compose.yml}"

        local image container_name
        image=$(python3 -c "
import sys
try:
    import json
    d = json.load(open('$f'))
    svcs = d.get('services', {})
    svc = next(iter(svcs.values()), {})
    print(svc.get('image','unknown'))
except: print('unknown')
" 2>/dev/null || echo "unknown")
        container_name=$(python3 -c "
import sys
try:
    import json
    d = json.load(open('$f'))
    svcs = d.get('services', {})
    svc = next(iter(svcs.values()), {})
    print(svc.get('container_name', list(svcs.keys())[0] if svcs else ''))
except: print('')
" 2>/dev/null || echo "")
        [ -z "$container_name" ] && container_name="$name"

        local state="stopped" ports="[]" ip='""' webui='""' app_name_label='""'

        if echo "$running" | grep -qxF "$container_name" 2>/dev/null; then
            state="running"
            # Get ports: "0.0.0.0:8096->8096/tcp" format
            local raw_ports
            raw_ports=$(docker port "$container_name" 2>/dev/null || echo "")
            ports=$(echo "$raw_ports" | python3 -c "
import sys, json
lines = [l.strip() for l in sys.stdin if l.strip()]
out = []
for l in lines:
    # e.g. '8096/tcp -> 0.0.0.0:8096'
    parts = l.split(' -> ')
    if len(parts) == 2:
        container_side = parts[0].strip()
        host_side = parts[1].strip()
        host_port = host_side.split(':')[-1] if ':' in host_side else host_side
        out.append({'host': host_port, 'container': container_side})
print(json.dumps(out))
" 2>/dev/null || echo "[]")
            ip=$(docker inspect "$container_name" --format '{{range .NetworkSettings.Networks}}{{.IPAddress}}{{end}}' 2>/dev/null | tr -d '\n' | python3 -c "import sys,json; print(json.dumps(sys.stdin.read()))" 2>/dev/null || echo '""')
            webui=$(docker inspect "$container_name" --format '{{index .Config.Labels "freeraid.webui"}}' 2>/dev/null | tr -d '\n' | python3 -c "import sys,json; print(json.dumps(sys.stdin.read()))" 2>/dev/null || echo '""')
            app_name_label=$(docker inspect "$container_name" --format '{{index .Config.Labels "freeraid.name"}}' 2>/dev/null | tr -d '\n' | python3 -c "import sys,json; print(json.dumps(sys.stdin.read()))" 2>/dev/null || echo '""')
        fi

        # Fall back to label from compose file if not running
        if [ "$webui" = '""' ] || [ "$webui" = '"null"' ]; then
            webui=$(python3 -c "
import json
try:
    d = json.load(open('$f'))
    svcs = d.get('services',{})
    svc = next(iter(svcs.values()),{})
    labels = svc.get('labels',[])
    if isinstance(labels, list):
        for l in labels:
            if l.startswith('freeraid.webui='):
                print(json.dumps(l.split('=',1)[1])); exit()
    elif isinstance(labels, dict):
        v = labels.get('freeraid.webui','')
        if v: print(json.dumps(v)); exit()
    print('\"\"')
except: print('\"\"')
" 2>/dev/null || echo '""')
        fi

        local image_j; image_j=$(python3 -c "import json; print(json.dumps('$image'))" 2>/dev/null || echo "\"$image\"")

        $first || result+=","
        first=false
        result+="{\"name\":\"$name\",\"container_name\":\"$container_name\",\"image\":${image_j},\"state\":\"$state\",\"ports\":${ports},\"ip\":${ip},\"webui\":${webui}}"
    done

    result+="]"
    echo "$result"
}

