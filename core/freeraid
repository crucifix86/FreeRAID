#!/usr/bin/env bash
# freeraid - main CLI for FreeRAID array management
# Usage: freeraid <command> [options]

set -euo pipefail

VERSION_FILE="${FREERAID_VERSION_FILE:-/etc/freeraid/VERSION}"
FREERAID_VERSION="$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]' || echo '0.1.1')"
CONFIG_FILE="${FREERAID_CONFIG:-/boot/config/freeraid.conf.json}"
SNAPRAID_CONF="/etc/snapraid.conf"
LOG_FILE="/var/log/freeraid.log"
COMPOSE_DIR="${FREERAID_COMPOSE_DIR:-/boot/config/compose}"
GITHUB_REPO="crucifix86/FreeRAID"
GITHUB_API="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"; }
info()    { echo -e "${GREEN}==>${NC} $*"; log "INFO: $*"; }
warn()    { echo -e "${YELLOW}WARN:${NC} $*"; log "WARN: $*"; }
error()   { echo -e "${RED}ERROR:${NC} $*" >&2; log "ERROR: $*"; }
die()     { error "$*"; exit 1; }
require() { command -v "$1" &>/dev/null || die "Required tool not found: $1 — run: freeraid install-deps"; }

# Use docker compose v2 if available, fall back to docker-compose v1
docker_compose() {
    if docker compose version &>/dev/null 2>&1; then
        docker compose "$@"
    elif command -v docker-compose &>/dev/null; then
        docker-compose "$@"
    else
        die "Neither 'docker compose' nor 'docker-compose' found — run: freeraid install-deps"
    fi
}

# ── Config helpers ──────────────────────────────────────────────────────────────

cfg() { jq -r "$1" "$CONFIG_FILE" 2>/dev/null; }

cfg_array_disks_enabled() {
    jq -r '.array.disks[] | select(.enabled==true) | .device + " " + .mountpoint + " " + .fstype' "$CONFIG_FILE"
}

cfg_parity_mountpoints() {
    jq -r '.array.parity[] | .mountpoint + " " + .device + " " + .fstype' "$CONFIG_FILE"
}

cfg_pool_mountpoint() { cfg '.array.pool_mountpoint'; }
cfg_mergerfs_opts()   { cfg '.array.mergerfs_options'; }

# ── Snapraid config generator ────────────────────────────────────────────────────

generate_snapraid_conf() {
    local conf=""
    local parity_index=0

    while IFS=' ' read -r mnt dev fstype; do
        if [ $parity_index -eq 0 ]; then
            conf+="parity $mnt/snapraid.parity"$'\n'
        else
            conf+="${parity_index}-parity $mnt/snapraid.parity"$'\n'
        fi
        parity_index=$((parity_index + 1))
    done < <(cfg_parity_mountpoints)

    conf+=$'\n'

    local disk_index=1
    while IFS=' ' read -r dev mnt fstype; do
        conf+="data d${disk_index} ${mnt}/"$'\n'
        disk_index=$((disk_index + 1))
    done < <(cfg_array_disks_enabled)

    conf+=$'\n'

    while IFS= read -r cfile; do
        conf+="content $cfile"$'\n'
    done < <(jq -r '.snapraid.content_files[]' "$CONFIG_FILE")

    conf+=$'\n'

    while IFS= read -r excl; do
        conf+="exclude $excl"$'\n'
    done < <(jq -r '.snapraid.exclude[]' "$CONFIG_FILE")

    echo "$conf"
}

# ── Helpers ──────────────────────────────────────────────────────────────────────

get_disk_temp() {
    local dev="$1"
    [ -b "$dev" ] || { echo ""; return; }
    local temp
    temp=$(smartctl -j -x "$dev" 2>/dev/null | jq -r '.temperature.current // empty' 2>/dev/null || true)
    echo "${temp:-}"
}

get_disk_uuid() {
    local dev="$1"
    [ -b "$dev" ] || { echo ""; return; }
    blkid -s UUID -o value "$dev" 2>/dev/null || echo ""
}

get_disk_serial() {
    local dev="$1"
    [ -b "$dev" ] || { echo ""; return; }
    lsblk -dn -o SERIAL "$dev" 2>/dev/null | tr -d '[:space:]' || echo ""
}

find_dev_by_uuid() {
    local uuid="$1"
    [ -z "$uuid" ] && { echo ""; return; }
    blkid -l -t "UUID=$uuid" -o device 2>/dev/null || echo ""
}

# Returns the snapraid ID (d1, d2, ...) for a given slot name
get_snapraid_id_for_slot() {
    local target_slot="$1"
    local idx=1
    while IFS= read -r slot; do
        [ "$slot" = "$target_slot" ] && { echo "d${idx}"; return; }
        idx=$((idx + 1))
    done < <(jq -r '.array.disks[] | select(.enabled==true) | .slot' "$CONFIG_FILE")
    echo ""
}

# ── Array commands ───────────────────────────────────────────────────────────────

cmd_status_json() {
    local pool
    pool=$(cfg_pool_mountpoint)

    local array_state="stopped"
    mountpoint -q "$pool" 2>/dev/null && array_state="started"

    # Pool stats
    local pool_size="" pool_used="" pool_free="" pool_pct=""
    if [ "$array_state" = "started" ]; then
        read -r pool_size pool_used pool_free pool_pct < <(df -h "$pool" 2>/dev/null | awk 'NR==2{print $2,$3,$4,$5}' || echo "? ? ? ?")
    fi

    # Last sync
    local last_sync
    last_sync=$(journalctl -u freeraid-sync --no-pager -n 1 --output=short 2>/dev/null | grep -oP '\d{4}-\d{2}-\d{2}' | head -1 || echo "never")

    # Parity drives JSON
    local parity_json="["
    local first=true
    while IFS=' ' read -r slot dev mnt fstype label; do
        local present=false size="" synced=false temp=""
        [ -b "$dev" ] && present=true
        $present && size=$(lsblk -dn -o SIZE "$dev" 2>/dev/null || echo "?")
        $present && temp=$(get_disk_temp "$dev")
        mountpoint -q "$mnt" 2>/dev/null && synced=true
        $first || parity_json+=","
        first=false
        parity_json+="{\"slot\":\"$slot\",\"device\":\"$dev\",\"mountpoint\":\"$mnt\",\"size\":\"$size\",\"present\":$present,\"mounted\":$synced,\"label\":\"$label\",\"temp\":\"$temp\"}"
    done < <(jq -r '.array.parity[] | .slot + " " + .device + " " + .mountpoint + " " + .fstype + " " + .label' "$CONFIG_FILE")
    parity_json+="]"

    # Data drives JSON
    local disks_json="["
    first=true
    while IFS=$'\t' read -r slot dev mnt enabled label uuid; do
        local present=false size="" mounted=false used="" free="" pct="" temp="" status="missing" actual_dev="$dev" serial=""
        if [ -b "$dev" ]; then
            present=true
            actual_dev="$dev"
        elif [ -n "$uuid" ]; then
            local found_dev
            found_dev=$(find_dev_by_uuid "$uuid")
            if [ -b "$found_dev" ]; then
                present=true
                actual_dev="$found_dev"
                # Silently update config with corrected device path
                jq --arg s "$slot" --arg d "$found_dev" \
                   '(.array.disks[] | select(.slot==$s)).device = $d' \
                   "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
            fi
        fi
        if $present; then
            size=$(lsblk -dn -o SIZE "$actual_dev" 2>/dev/null || echo "?")
            temp=$(get_disk_temp "$actual_dev")
            serial=$(get_disk_serial "$actual_dev")
            if mountpoint -q "$mnt" 2>/dev/null; then
                mounted=true
                read -r used free pct < <(df -h "$mnt" 2>/dev/null | awk 'NR==2{print $3,$4,$5}' || echo "? ? ?")
                status="healthy"
            else
                status="unmounted"
            fi
        fi
        $first || disks_json+=","
        first=false
        disks_json+="{\"slot\":\"$slot\",\"device\":\"$actual_dev\",\"mountpoint\":\"$mnt\",\"enabled\":$enabled,\"present\":$present,\"mounted\":$mounted,\"size\":\"$size\",\"used\":\"$used\",\"free\":\"$free\",\"pct\":\"$pct\",\"label\":\"$label\",\"temp\":\"$temp\",\"status\":\"$status\",\"uuid\":\"$uuid\",\"serial\":\"$serial\"}"
    done < <(jq -r '.array.disks[] | [.slot, .device, .mountpoint, (.enabled|tostring), .label, (.uuid // "")] | join("\t")' "$CONFIG_FILE")
    disks_json+="]"

    # Cache drives JSON
    local cache_json="["
    first=true
    while IFS=' ' read -r slot dev mnt enabled label; do
        local present=false size="" mounted=false used="" free="" pct="" temp=""
        [ -b "$dev" ] && present=true
        $present && size=$(lsblk -dn -o SIZE "$dev" 2>/dev/null || echo "?")
        $present && temp=$(get_disk_temp "$dev")
        mountpoint -q "$mnt" 2>/dev/null && mounted=true
        if $mounted; then
            read -r used free pct < <(df -h "$mnt" 2>/dev/null | awk 'NR==2{print $3,$4,$5}' || echo "? ? ?")
        fi
        $first || cache_json+=","
        first=false
        cache_json+="{\"slot\":\"$slot\",\"device\":\"$dev\",\"mountpoint\":\"$mnt\",\"enabled\":$enabled,\"present\":$present,\"mounted\":$mounted,\"size\":\"$size\",\"used\":\"$used\",\"free\":\"$free\",\"pct\":\"$pct\",\"label\":\"$label\",\"temp\":\"$temp\"}"
    done < <(jq -r '.array.cache[] | .slot + " " + .device + " " + .mountpoint + " " + (.enabled|tostring) + " " + .label' "$CONFIG_FILE")
    cache_json+="]"

    # Total raw array capacity = sum of enabled data disk sizes in bytes
    local total_bytes=0
    while IFS=' ' read -r dev enabled; do
        if [ "$enabled" = "true" ] && [ -b "$dev" ]; then
            local b
            b=$(lsblk -dn -o SIZE --bytes "$dev" 2>/dev/null || echo 0)
            total_bytes=$((total_bytes + b))
        fi
    done < <(jq -r '.array.disks[] | .device + " " + (.enabled|tostring)' "$CONFIG_FILE")

    # Human-readable total (awk handles GB/TB nicely)
    local array_total
    array_total=$(awk -v b="$total_bytes" 'BEGIN{
        if(b>=1099511627776) printf "%.1fT", b/1099511627776
        else if(b>=1073741824) printf "%.1fG", b/1073741824
        else if(b>=1048576) printf "%.1fM", b/1048576
        else printf "%dB", b
    }')

    printf '{"version":"%s","array_state":"%s","pool":{"mountpoint":"%s","size":"%s","used":"%s","free":"%s","pct":"%s"},"array_total":"%s","parity":%s,"disks":%s,"cache":%s,"last_sync":"%s"}\n' \
        "$FREERAID_VERSION" "$array_state" "$pool" "$pool_size" "$pool_used" "$pool_free" "$pool_pct" \
        "$array_total" "$parity_json" "$disks_json" "$cache_json" "$last_sync"
}

cmd_status() {
    # Machine-readable mode for web UI
    if [ "${FREERAID_JSON:-}" = "1" ] || [ "${1:-}" = "--json" ]; then
        cmd_status_json
        return
    fi

    echo -e "${BOLD}FreeRAID v${FREERAID_VERSION} — Array Status${NC}"
    echo "────────────────────────────────────────────"

    local pool
    pool=$(cfg_pool_mountpoint)

    local array_running=false
    if mountpoint -q "$pool" 2>/dev/null; then
        array_running=true
        echo -e "Array:   ${GREEN}STARTED${NC}"
    else
        echo -e "Array:   ${YELLOW}STOPPED${NC}"
    fi

    echo ""
    echo -e "${BOLD}Parity Drives:${NC}"
    while IFS=' ' read -r slot dev label; do
        if [ -b "$dev" ]; then
            local size
            size=$(lsblk -dn -o SIZE "$dev" 2>/dev/null || echo "?")
            echo -e "  ${GREEN}●${NC} $slot  $dev  $size  $label"
        else
            echo -e "  ${RED}✗${NC} $slot  $dev  [not found]"
        fi
    done < <(jq -r '.array.parity[] | .slot + " " + .device + " " + .label' "$CONFIG_FILE")

    echo ""
    echo -e "${BOLD}Data Drives:${NC}"
    while IFS=' ' read -r slot dev mnt enabled label; do
        if [ "$enabled" = "true" ]; then
            if [ -b "$dev" ]; then
                local size used avail
                size=$(lsblk -dn -o SIZE "$dev" 2>/dev/null || echo "?")
                if mountpoint -q "$mnt" 2>/dev/null; then
                    read -r used avail _ < <(df -h "$mnt" 2>/dev/null | awk 'NR==2{print $3,$4,$5}' || echo "? ? ?")
                    echo -e "  ${GREEN}●${NC} $slot  $dev  $size  used:$used free:$avail  $label"
                else
                    echo -e "  ${YELLOW}○${NC} $slot  $dev  $size  [not mounted]  $label"
                fi
            else
                echo -e "  ${RED}✗${NC} $slot  $dev  [not found]  $label"
            fi
        else
            echo -e "  ${BLUE}–${NC} $slot  $dev  [disabled]  $label"
        fi
    done < <(jq -r '.array.disks[] | .slot + " " + .device + " " + .mountpoint + " " + (.enabled|tostring) + " " + .label' "$CONFIG_FILE")

    if $array_running; then
        echo ""
        echo -e "${BOLD}Pool (${pool}):${NC}"
        df -h "$pool" 2>/dev/null | awk 'NR==2{printf "  Size: %s  Used: %s  Free: %s  (%s used)\n",$2,$3,$4,$5}' || echo "  [error reading pool]"
    fi

    local last_sync
    last_sync=$(journalctl -u freeraid-sync --no-pager -n 1 --output=short 2>/dev/null | grep -oP '\d{4}-\d{2}-\d{2}' | head -1 || echo "never")
    echo ""
    echo -e "Last parity sync: ${last_sync}"
}

cmd_start() {
    info "Starting FreeRAID array..."

    require jq
    require mergerfs

    local pool
    pool=$(cfg_pool_mountpoint)

    # Format + mount parity drives
    while IFS=' ' read -r mnt dev fstype; do
        if [ ! -b "$dev" ]; then
            warn "Parity device $dev not found, skipping"
            continue
        fi
        mkdir -p "$mnt"
        local cur_fs
        cur_fs=$(blkid -o value -s TYPE "$dev" 2>/dev/null || echo "")
        if [ "$cur_fs" != "$fstype" ]; then
            info "Formatting parity $dev as $fstype..."
            wipefs -af "$dev" &>/dev/null || true
            case "$fstype" in
                xfs)  mkfs.xfs -f -L "parity" "$dev" ;;
                ext4) mkfs.ext4 -F -L "parity" "$dev" ;;
                *) mkfs.xfs -f -L "parity" "$dev" ;;
            esac
        fi
        if ! mountpoint -q "$mnt"; then
            info "Mounting parity $dev → $mnt"
            mount "$dev" "$mnt" || die "Failed to mount parity $dev"
        fi
    done < <(cfg_parity_mountpoints)

    # Format + mount each enabled data disk
    local degraded=false
    while IFS=' ' read -r slot dev mnt fstype uuid; do
        local actual_dev="$dev"
        if [ ! -b "$actual_dev" ]; then
            # Try to find the drive by UUID if it was renumbered
            if [ -n "$uuid" ]; then
                local found_dev
                found_dev=$(find_dev_by_uuid "$uuid")
                if [ -b "$found_dev" ]; then
                    info "Drive $slot found at $found_dev (was $dev), updating config"
                    actual_dev="$found_dev"
                    jq --arg s "$slot" --arg d "$found_dev" \
                       '(.array.disks[] | select(.slot==$s)).device = $d' \
                       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
                fi
            fi
        fi
        if [ ! -b "$actual_dev" ]; then
            warn "Drive $slot ($dev) not found — starting in degraded mode without this disk"
            degraded=true
            continue
        fi

        mkdir -p "$mnt"

        local cur_data_fs
        cur_data_fs=$(blkid -o value -s TYPE "$actual_dev" 2>/dev/null || echo "")
        if [ "$cur_data_fs" != "$fstype" ]; then
            info "Formatting $actual_dev as $fstype..."
            wipefs -af "$actual_dev" &>/dev/null || true
            case "$fstype" in
                xfs)  mkfs.xfs -f -L "$(basename "$mnt")" "$actual_dev" ;;
                ext4) mkfs.ext4 -F -L "$(basename "$mnt")" "$actual_dev" ;;
                btrfs) mkfs.btrfs -f -L "$(basename "$mnt")" "$actual_dev" ;;
                *) die "Unknown fstype: $fstype" ;;
            esac
            # Store UUID after formatting
            local new_uuid; new_uuid=$(get_disk_uuid "$actual_dev")
            local new_serial; new_serial=$(get_disk_serial "$actual_dev")
            [ -n "$new_uuid" ] && jq --arg s "$slot" --arg u "$new_uuid" --arg sr "$new_serial" \
               '(.array.disks[] | select(.slot==$s)) |= . + {"uuid":$u,"serial":$sr}' \
               "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
        fi

        if ! mountpoint -q "$mnt"; then
            info "Mounting $actual_dev → $mnt"
            mount "$actual_dev" "$mnt" || { warn "Failed to mount $actual_dev — skipping (degraded)"; degraded=true; continue; }
        else
            info "$mnt already mounted"
        fi
    done < <(jq -r '.array.disks[] | select(.enabled==true) | .slot + " " + .device + " " + .mountpoint + " " + .fstype + " " + (.uuid // "")' "$CONFIG_FILE")
    if $degraded; then
        warn "Array starting in DEGRADED mode — one or more drives missing"
        cmd_notify_send "array_degraded" "Array started in DEGRADED mode — one or more drives are missing" 2>/dev/null || true
    fi

    # Mount cache
    local cache_dev cache_mnt cache_fs
    cache_dev=$(jq -r '.array.cache[] | select(.enabled==true) | .device' "$CONFIG_FILE" | head -1)
    cache_mnt=$(jq -r '.array.cache[] | select(.enabled==true) | .mountpoint' "$CONFIG_FILE" | head -1)
    cache_fs=$(jq -r '.array.cache[] | select(.enabled==true) | .fstype' "$CONFIG_FILE" | head -1)

    if [ -n "$cache_dev" ] && [ -b "$cache_dev" ]; then
        mkdir -p "$cache_mnt"
        local cur_cache_fs
        cur_cache_fs=$(blkid -o value -s TYPE "$cache_dev" 2>/dev/null || echo "")
        if [ "$cur_cache_fs" != "$cache_fs" ]; then
            info "Formatting cache $cache_dev as $cache_fs..."
            wipefs -af "$cache_dev" &>/dev/null || true
            mkfs."$cache_fs" -F "$cache_dev" 2>/dev/null || mkfs."$cache_fs" "$cache_dev"
        fi
        if ! mountpoint -q "$cache_mnt"; then
            info "Mounting cache $cache_dev → $cache_mnt"
            mount "$cache_dev" "$cache_mnt"
        fi
    fi

    # Build mergerfs branches string
    local branches=""
    while IFS=' ' read -r dev mnt fstype; do
        [ -b "$dev" ] && branches+="${mnt}:"
    done < <(cfg_array_disks_enabled)

    # Prepend cache as highest priority
    if [ -n "$cache_mnt" ] && mountpoint -q "$cache_mnt" 2>/dev/null; then
        branches="${cache_mnt}:${branches}"
    fi

    branches="${branches%:}"  # strip trailing colon

    if [ -z "$branches" ]; then
        die "No drives available to pool"
    fi

    mkdir -p "$pool"

    if ! mountpoint -q "$pool"; then
        info "Mounting mergerfs pool: $branches → $pool"
        mergerfs "$branches" "$pool" -o "$(cfg_mergerfs_opts)" || die "mergerfs failed"
    else
        info "Pool already mounted at $pool"
    fi

    # Generate snapraid config
    info "Generating snapraid config..."
    generate_snapraid_conf > "$SNAPRAID_CONF"

    # Update array state in config
    jq '.array.state = "started"' "$CONFIG_FILE" > /tmp/freeraid.conf.tmp \
        && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    # Apply spin-down settings (only for drives that have it explicitly set)
    cmd_spindown_apply 2>/dev/null || true

    # Configure Docker to use overlay2 on first real data disk (not mergerfs pool)
    if command -v docker &>/dev/null; then
        local first_disk_mnt=""
        first_disk_mnt=$(jq -r '.array.disks[] | select(.enabled==true) | .mountpoint' "$CONFIG_FILE" 2>/dev/null | head -1)
        if [ -n "$first_disk_mnt" ] && mountpoint -q "$first_disk_mnt" 2>/dev/null; then
            local docker_data="${first_disk_mnt}/appdata/docker"
            local cur_driver=""
            cur_driver=$(docker info --format '{{.Driver}}' 2>/dev/null || echo "")
            local cur_root=""
            cur_root=$(docker info --format '{{.DockerRootDir}}' 2>/dev/null || echo "")
            if [ "$cur_driver" != "overlay2" ] || [ "$cur_root" != "$docker_data" ]; then
                info "Switching Docker to overlay2 at $docker_data ..."
                systemctl stop docker 2>/dev/null || true
                mkdir -p "$docker_data"
                cat > /etc/docker/daemon.json <<DOCKERCFG
{
  "storage-driver": "overlay2",
  "data-root": "$docker_data"
}
DOCKERCFG
                systemctl start docker 2>/dev/null || true
                info "Docker: overlay2 at $docker_data"
            fi
        fi
    fi

    info "Array started. Pool at ${pool}"

    # Start any extra pools
    cmd_pool_start_all 2>/dev/null || true

    cmd_status
}

cmd_stop() {
    info "Stopping FreeRAID array..."

    local pool
    pool=$(cfg_pool_mountpoint)

    # Unmount pool first
    # Stop extra pools first
    cmd_pool_stop_all 2>/dev/null || true

    if mountpoint -q "$pool" 2>/dev/null; then
        info "Unmounting pool $pool"
        umount "$pool" || umount -l "$pool"
    fi

    # Unmount data disks in reverse order
    while IFS=' ' read -r dev mnt fstype; do
        if mountpoint -q "$mnt" 2>/dev/null; then
            info "Unmounting $mnt"
            umount "$mnt" || umount -l "$mnt"
        fi
    done < <(cfg_array_disks_enabled | tac)

    # Unmount cache
    local cache_mnt
    cache_mnt=$(jq -r '.array.cache[] | select(.enabled==true) | .mountpoint' "$CONFIG_FILE" | head -1)
    if [ -n "$cache_mnt" ] && mountpoint -q "$cache_mnt" 2>/dev/null; then
        info "Unmounting cache $cache_mnt"
        umount "$cache_mnt" || umount -l "$cache_mnt"
    fi

    # Unmount parity drives
    while IFS=' ' read -r mnt dev fstype; do
        if mountpoint -q "$mnt" 2>/dev/null; then
            info "Unmounting parity $mnt"
            umount "$mnt" || umount -l "$mnt"
        fi
    done < <(cfg_parity_mountpoints)

    jq '.array.state = "stopped"' "$CONFIG_FILE" > /tmp/freeraid.conf.tmp \
        && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    info "Array stopped."
}

cmd_sync() {
    info "Running SnapRAID sync (parity update)..."
    require snapraid

    [ -f "$SNAPRAID_CONF" ] || { generate_snapraid_conf > "$SNAPRAID_CONF"; info "Generated $SNAPRAID_CONF"; }

    if snapraid -c "$SNAPRAID_CONF" sync; then
        info "Sync complete."
    else
        cmd_notify_send "sync_error" "SnapRAID sync failed — check logs for details" 2>/dev/null || true
        die "Sync failed — check snapraid output above"
    fi
}

cmd_scrub() {
    local percent
    percent=$(cfg '.snapraid.scrub_percent')
    percent="${percent:-22}"
    info "Running SnapRAID scrub (${percent}% of parity)..."
    require snapraid
    if snapraid -c "$SNAPRAID_CONF" scrub -p "$percent"; then
        info "Scrub complete."
    else
        cmd_notify_send "scrub_error" "SnapRAID scrub failed — check logs for details" 2>/dev/null || true
        die "Scrub failed"
    fi
}

cmd_diff() {
    info "SnapRAID diff (what changed since last sync)..."
    require snapraid
    snapraid -c "$SNAPRAID_CONF" diff
}

cmd_turbo_get() {
    local enabled
    enabled=$(jq -r '.turbo_write // false' "$CONFIG_FILE" 2>/dev/null || echo "false")
    echo "{\"enabled\":$([ "$enabled" = "true" ] && echo true || echo false)}"
}

cmd_turbo_set() {
    local val="${1:-false}"
    [ "$val" = "true" ] || val="false"

    local current
    current=$(jq -r '.turbo_write // false' "$CONFIG_FILE" 2>/dev/null || echo "false")

    jq --argjson v "$([ "$val" = "true" ] && echo true || echo false)" \
        '.turbo_write = $v' "$CONFIG_FILE" > /tmp/freeraid.conf.tmp \
        && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    if [ "$val" = "true" ]; then
        # Disable the nightly sync timer while turbo write is active
        systemctl stop freeraid-sync.timer 2>/dev/null || true
        warn "Turbo write ENABLED — parity is now INVALID until you disable turbo write or run a manual sync."
        log "TURBO: Turbo write enabled — nightly sync timer paused"
    else
        # Re-enable the nightly sync timer
        systemctl start freeraid-sync.timer 2>/dev/null || true
        info "Turbo write disabled — running parity sync now..."
        log "TURBO: Turbo write disabled — starting sync"
        cmd_sync
    fi
    echo "{\"enabled\":$([ "$val" = "true" ] && echo true || echo false)}"
}

cmd_disks_scan() {
    # Build a flat lookup of all assigned devices from config
    local all_assigned
    all_assigned=$(jq -r '
        [
          (.array.parity[] | {device:.device, slot:.slot, role:"parity"}),
          (.array.disks[]  | {device:.device, slot:.slot, role:"array"}),
          (.array.cache[]  | {device:.device, slot:.slot, role:"cache"}),
          ((.pools // [])[] | .name as $pn | .disks[] | {device:.device, slot:.slot, role:("pool:"+$pn)})
        ]
    ' "$CONFIG_FILE" 2>/dev/null || echo "[]")

    # Detect the live boot medium device to exclude it.
    # With toram, /run/live/medium is a tmpfs (/dev/shm) not the USB.
    # Fall back to blkid FREERAID label to find the real boot device.
    local live_dev=""
    local _src
    _src=$(findmnt -n -o SOURCE /run/live/medium 2>/dev/null | sed 's/[0-9]*$//' || echo "")
    [ -b "$_src" ] && live_dev="$_src"
    if [ -z "$live_dev" ]; then
        local label_dev
        label_dev=$(blkid -L FREERAID 2>/dev/null || echo "")
        [ -n "$label_dev" ] && live_dev=$(echo "$label_dev" | sed 's/[0-9]*$//')
    fi

    local disks_json="["
    local first=true

    while read -r name size rota type; do
        [ "$type" != "disk" ] && continue
        local dev="/dev/${name}"

        # Skip the live boot medium
        [ -n "$live_dev" ] && [ "$dev" = "$live_dev" ] && continue

        # Get model separately to handle blank/spaces safely
        local model
        model=$(lsblk -dn -o MODEL "$dev" 2>/dev/null | tr -d '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        [ -z "$model" ] && model="Virtual Disk"

        local drive_type="HDD"
        [ "$rota" = "0" ] && drive_type="SSD"

        # Filesystem on the raw device (if any)
        local has_fs
        has_fs=$(lsblk -no FSTYPE "$dev" 2>/dev/null | grep -v '^$' | head -1 || echo "")

        # Lookup assignment
        local assigned_slot assigned_role
        assigned_slot=$(echo "$all_assigned" | jq -r --arg d "$dev" '.[] | select(.device==$d) | .slot' 2>/dev/null | head -1 || echo "")
        assigned_role=$(echo "$all_assigned"  | jq -r --arg d "$dev" '.[] | select(.device==$d) | .role' 2>/dev/null | head -1 || echo "")

        $first || disks_json+=","
        first=false
        disks_json+=$(printf '{"device":"%s","name":"%s","size":"%s","type":"%s","model":"%s","assigned":%s,"slot":"%s","role":"%s","has_fs":"%s"}' \
            "$dev" "$name" "$size" "$drive_type" "$model" \
            "$([ -n "$assigned_slot" ] && echo true || echo false)" \
            "$assigned_slot" "$assigned_role" "$has_fs")

    done < <(lsblk -dn -o NAME,SIZE,ROTA,TYPE 2>/dev/null)

    disks_json+="]"
    echo "$disks_json"
}

cmd_disks_assign() {
    local dev="$1" role="$2" slot="$3" fstype="${4:-xfs}"
    [ -z "$dev" ] || [ -z "$role" ] && die "Usage: freeraid disks-assign <device> <role:array|parity|cache> [slot] [fstype]"
    [ -b "$dev" ] || die "Device $dev not found"

    # Check array is stopped
    local pool
    pool=$(cfg_pool_mountpoint)
    mountpoint -q "$pool" 2>/dev/null && die "Stop the array before reassigning disks: freeraid stop"

    case "$role" in
        array)
            # Auto-assign next available slot if not specified
            if [ -z "$slot" ]; then
                local n=1
                while jq -e --arg s "disk${n}" '.array.disks[] | select(.slot==$s)' "$CONFIG_FILE" &>/dev/null; do
                    n=$((n+1))
                done
                slot="disk${n}"
            fi
            local mnt="/mnt/${slot}"
            # Remove from other roles first
            cmd_disks_unassign_dev "$dev" 2>/dev/null || true
            jq --arg slot "$slot" --arg dev "$dev" --arg mnt "$mnt" --arg fs "$fstype" \
               '.array.disks += [{"slot":$slot,"device":$dev,"mountpoint":$mnt,"fstype":$fs,"label":$slot,"enabled":true}]' \
               "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
            info "Assigned $dev as array $slot"
            ;;
        parity)
            if [ -z "$slot" ]; then
                local p=0
                while jq -e --arg s "$([ $p -eq 0 ] && echo 'parity' || echo "parity${p}")" '.array.parity[] | select(.slot==$s)' "$CONFIG_FILE" &>/dev/null; do
                    p=$((p+1))
                done
                slot=$([ $p -eq 0 ] && echo "parity" || echo "parity${p}")
            fi
            local pmnt="/mnt/${slot}"
            cmd_disks_unassign_dev "$dev" 2>/dev/null || true
            jq --arg slot "$slot" --arg dev "$dev" --arg mnt "$pmnt" \
               '.array.parity += [{"slot":$slot,"device":$dev,"mountpoint":$mnt,"fstype":"xfs","label":$slot}]' \
               "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
            info "Assigned $dev as $slot"
            ;;
        cache)
            slot="${slot:-cache}"
            local cmnt="/mnt/${slot}"
            cmd_disks_unassign_dev "$dev" 2>/dev/null || true
            jq --arg slot "$slot" --arg dev "$dev" --arg mnt "$cmnt" \
               '.array.cache += [{"slot":$slot,"device":$dev,"mountpoint":$mnt,"fstype":"ext4","label":$slot,"enabled":true}]' \
               "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
            info "Assigned $dev as cache $slot"
            ;;
        *)
            die "Role must be: array, parity, or cache"
            ;;
    esac
}

cmd_disks_unassign_dev() {
    # Internal helper — remove a device from all roles (including extra pools)
    local dev="$1"
    jq --arg d "$dev" '
        .array.disks   |= map(select(.device != $d)) |
        .array.parity  |= map(select(.device != $d)) |
        .array.cache   |= map(select(.device != $d)) |
        (.pools // []) |= map(.disks |= map(select(.device != $d)))
    ' "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
}

cmd_disks_unassign() {
    local dev="$1"
    [ -z "$dev" ] && die "Usage: freeraid disks-unassign <device>"
    local pool
    pool=$(cfg_pool_mountpoint)
    mountpoint -q "$pool" 2>/dev/null && die "Stop the array before unassigning disks"
    cmd_disks_unassign_dev "$dev"
    info "Unassigned $dev"
}

cmd_add_disk() {
    local slot="$1" dev="$2" fstype="${3:-xfs}"
    [ -z "$slot" ] || [ -z "$dev" ] && die "Usage: freeraid add-disk <slot> <device> [fstype]"
    [ -b "$dev" ] || die "Device $dev does not exist"

    info "Adding $dev as $slot ($fstype)"

    local mnt="/mnt/${slot}"
    local existing
    existing=$(jq -r --arg s "$slot" '.array.disks[] | select(.slot==$s) | .slot' "$CONFIG_FILE" 2>/dev/null || true)
    [ -n "$existing" ] && die "Slot $slot already exists in config"

    jq --arg slot "$slot" --arg dev "$dev" --arg mnt "$mnt" --arg fs "$fstype" \
       '.array.disks += [{"slot":$slot,"device":$dev,"mountpoint":$mnt,"fstype":$fs,"label":$slot,"enabled":true}]' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    info "Added $slot. Run 'freeraid start' to mount the array with the new disk."
}

cmd_remove_disk() {
    local slot="$1"
    [ -z "$slot" ] && die "Usage: freeraid remove-disk <slot>"
    info "Disabling slot $slot (data remains on disk)"
    jq --arg s "$slot" '(.array.disks[] | select(.slot==$s)).enabled = false' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    info "Slot $slot disabled. Run 'freeraid stop && freeraid start' to apply."
}

cmd_pool_list() {
    local pools_json="["
    local first=true
    while IFS= read -r pool_entry; do
        local name mnt
        name=$(echo "$pool_entry" | jq -r '.name')
        mnt=$(echo "$pool_entry" | jq -r '.mountpoint')
        local mounted=false
        mountpoint -q "$mnt" 2>/dev/null && mounted=true
        local size="" used="" free="" pct=""
        if $mounted; then
            read -r size used free pct < <(df -h "$mnt" 2>/dev/null | awk 'NR==2{print $2,$3,$4,$5}' || echo "? ? ? ?")
        fi
        $first || pools_json+=","
        first=false
        pools_json+=$(echo "$pool_entry" | jq --argjson m "$mounted" \
            --arg sz "$size" --arg us "$used" --arg fr "$free" --arg pc "$pct" \
            '. + {"mounted":$m,"size":$sz,"used":$us,"free":$fr,"pct":$pc}')
    done < <(jq -c '.pools // [] | .[]' "$CONFIG_FILE" 2>/dev/null)
    pools_json+="]"
    echo "$pools_json"
}

cmd_pool_add() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid pool-add <name>"
    echo "$name" | grep -qE '^[a-zA-Z0-9_-]+$' || die "Pool name must be alphanumeric (underscores/hyphens ok)"
    local existing
    existing=$(jq -r --arg n "$name" '.pools // [] | .[] | select(.name==$n) | .name' "$CONFIG_FILE" 2>/dev/null || true)
    [ -n "$existing" ] && die "Pool '$name' already exists"
    local mnt="/mnt/pools/${name}"
    jq --arg name "$name" --arg mnt "$mnt" \
        '.pools //= [] | .pools += [{"name":$name,"label":$name,"mountpoint":$mnt,"mergerfs_options":"defaults,allow_other,use_ino,category.create=mfs,moveonenospc=true,minfreespace=200M","disks":[]}]' \
        "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    info "Pool '$name' created. Assign drives with: freeraid pool-assign $name <device>"
}

cmd_pool_remove() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid pool-remove <name>"
    local mnt
    mnt=$(jq -r --arg n "$name" '.pools // [] | .[] | select(.name==$n) | .mountpoint' "$CONFIG_FILE" 2>/dev/null || true)
    [ -z "$mnt" ] && die "Pool '$name' not found"
    mountpoint -q "$mnt" 2>/dev/null && die "Stop pool '$name' before removing: freeraid pool-stop $name"
    jq --arg n "$name" '.pools //= [] | .pools |= map(select(.name != $n))' \
        "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    info "Pool '$name' removed."
}

cmd_pool_assign() {
    local name="${1:-}" dev="${2:-}" fstype="${3:-xfs}"
    [ -z "$name" ] || [ -z "$dev" ] && die "Usage: freeraid pool-assign <pool-name> <device> [fstype]"
    [ -b "$dev" ] || die "Device $dev not found"
    local existing_pool
    existing_pool=$(jq -r --arg n "$name" '.pools // [] | .[] | select(.name==$n) | .name' "$CONFIG_FILE" 2>/dev/null || true)
    [ -z "$existing_pool" ] && die "Pool '$name' not found"
    # Remove from other roles first
    cmd_disks_unassign_dev "$dev" 2>/dev/null || true
    local disk_count
    disk_count=$(jq -r --arg n "$name" '(.pools[] | select(.name==$n) | .disks | length)' "$CONFIG_FILE" 2>/dev/null || echo "0")
    local slot="${name}_disk$((disk_count + 1))"
    local mnt="/mnt/pool_${slot}"
    jq --arg n "$name" --arg slot "$slot" --arg dev "$dev" --arg mnt "$mnt" --arg fs "$fstype" \
        '(.pools[] | select(.name==$n)).disks += [{"slot":$slot,"device":$dev,"mountpoint":$mnt,"fstype":$fs,"label":$slot,"enabled":true}]' \
        "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    info "Assigned $dev to pool '$name' as $slot"
}

cmd_pool_unassign() {
    local name="${1:-}" dev="${2:-}"
    [ -z "$name" ] || [ -z "$dev" ] && die "Usage: freeraid pool-unassign <pool-name> <device>"
    local mnt
    mnt=$(jq -r --arg n "$name" '.pools // [] | .[] | select(.name==$n) | .mountpoint' "$CONFIG_FILE" 2>/dev/null || true)
    [ -z "$mnt" ] && die "Pool '$name' not found"
    mountpoint -q "$mnt" 2>/dev/null && die "Stop pool '$name' before unassigning: freeraid pool-stop $name"
    jq --arg n "$name" --arg d "$dev" \
        '(.pools[] | select(.name==$n)).disks |= map(select(.device != $d))' \
        "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    info "Unassigned $dev from pool '$name'."
}

cmd_pool_start() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid pool-start <name>"
    local pool_json
    pool_json=$(jq -c --arg n "$name" '.pools // [] | .[] | select(.name==$n)' "$CONFIG_FILE" 2>/dev/null || true)
    [ -z "$pool_json" ] && die "Pool '$name' not found"
    local mnt mergerfs_opts
    mnt=$(echo "$pool_json" | jq -r '.mountpoint')
    mergerfs_opts=$(echo "$pool_json" | jq -r '.mergerfs_options // "defaults,allow_other,use_ino,category.create=mfs,moveonenospc=true,minfreespace=200M"')
    if mountpoint -q "$mnt" 2>/dev/null; then
        info "Pool '$name' already mounted at $mnt"
        return
    fi
    local branches=""
    while IFS=$'\t' read -r dev disk_mnt fstype; do
        if [ ! -b "$dev" ]; then
            warn "Pool '$name': device $dev not found, skipping"
            continue
        fi
        mkdir -p "$disk_mnt"
        if ! blkid "$dev" &>/dev/null; then
            info "Formatting $dev as $fstype for pool '$name'..."
            case "$fstype" in
                xfs)   mkfs.xfs  -f -L "${name}" "$dev" ;;
                ext4)  mkfs.ext4 -F -L "${name}" "$dev" ;;
                btrfs) mkfs.btrfs -f -L "${name}" "$dev" ;;
                *)     mkfs.xfs  -f "$dev" ;;
            esac
        fi
        if ! mountpoint -q "$disk_mnt"; then
            info "Mounting $dev → $disk_mnt"
            mount "$dev" "$disk_mnt" || { warn "Failed to mount $dev — skipping"; continue; }
        fi
        branches+="${disk_mnt}:"
    done < <(echo "$pool_json" | jq -r '.disks[] | select(.enabled==true) | [.device, .mountpoint, .fstype] | join("\t")')
    branches="${branches%:}"
    if [ -z "$branches" ]; then
        warn "Pool '$name': no drives available — not started"
        return
    fi
    mkdir -p "$mnt"
    info "Starting pool '$name': $branches → $mnt"
    mergerfs "$branches" "$mnt" -o "${mergerfs_opts},fsname=freeraid_${name}" || die "mergerfs failed for pool '$name'"
    info "Pool '$name' started at $mnt"
}

cmd_pool_stop() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid pool-stop <name>"
    local pool_json
    pool_json=$(jq -c --arg n "$name" '.pools // [] | .[] | select(.name==$n)' "$CONFIG_FILE" 2>/dev/null || true)
    [ -z "$pool_json" ] && die "Pool '$name' not found"
    local mnt
    mnt=$(echo "$pool_json" | jq -r '.mountpoint')
    if mountpoint -q "$mnt" 2>/dev/null; then
        info "Unmounting pool '$name' at $mnt"
        umount "$mnt" || umount -l "$mnt"
    fi
    while IFS= read -r disk_mnt; do
        if mountpoint -q "$disk_mnt" 2>/dev/null; then
            info "Unmounting $disk_mnt"
            umount "$disk_mnt" || umount -l "$disk_mnt"
        fi
    done < <(echo "$pool_json" | jq -r '.disks[] | .mountpoint')
    info "Pool '$name' stopped."
}

cmd_pool_start_all() {
    while IFS= read -r pname; do
        cmd_pool_start "$pname" 2>/dev/null || warn "Failed to start pool '$pname'"
    done < <(jq -r '.pools // [] | .[] | .name' "$CONFIG_FILE" 2>/dev/null)
}

cmd_pool_stop_all() {
    while IFS= read -r pname; do
        cmd_pool_stop "$pname" 2>/dev/null || warn "Failed to stop pool '$pname'"
    done < <(jq -r '.pools // [] | .[] | .name' "$CONFIG_FILE" 2>/dev/null)
}

## ── VM Manager ───────────────────────────────────────────────────────────────

VM_IMAGE_DIR="/var/lib/freeraid/vms"
VM_ISO_DIR="/mnt/user/isos"

cmd_vm_check() {
    command -v virsh &>/dev/null || die "libvirt is not installed. Run: apt-get install -y qemu-kvm libvirt-daemon-system virtinst"
    systemctl is-active --quiet libvirtd 2>/dev/null || systemctl start libvirtd 2>/dev/null || true
}

cmd_vm_list() {
    cmd_vm_check
    local out="["
    local first=1
    # Get all domains (running + stopped)
    while IFS= read -r line; do
        local id name state
        id=$(echo "$line" | awk '{print $1}')
        name=$(echo "$line" | awk '{print $2}')
        state=$(echo "$line" | awk '{$1=$2=""; print $0}' | xargs)
        [ -z "$name" ] || [ "$name" = "Name" ] && continue
        [ "$first" = "1" ] && first=0 || out+=","
        # Get more details
        local vcpus maxmem
        vcpus=$(virsh dominfo "$name" 2>/dev/null | awk '/CPU\(s\)/{print $2}' || echo "?")
        maxmem=$(virsh dominfo "$name" 2>/dev/null | awk '/Max memory/{print $3,$4}' || echo "?")
        name=$(echo "$name" | sed 's/"/\\"/g')
        out+="{\"id\":\"${id}\",\"name\":\"${name}\",\"state\":\"${state}\",\"vcpus\":\"${vcpus}\",\"maxmem\":\"${maxmem}\"}"
    done < <(virsh list --all 2>/dev/null | tail -n +3 | grep -v '^$')
    out+="]"
    echo "$out"
}

cmd_vm_create() {
    # Usage: freeraid vm-create <name> <ram_mb> <vcpus> <disk_gb> <os_type> [iso_path]
    cmd_vm_check
    local name="${1:-}" ram="${2:-2048}" vcpus="${3:-2}" disk_gb="${4:-20}" os_type="${5:-linux}" iso="${6:-}"
    [ -z "$name" ] && die "Usage: freeraid vm-create <name> <ram_mb> <vcpus> <disk_gb> <os_type> [iso]"

    mkdir -p "$VM_IMAGE_DIR"
    local img="${VM_IMAGE_DIR}/${name}.qcow2"
    [ -f "$img" ] && die "VM '$name' already exists at $img"

    info "Creating disk image ${disk_gb}G..."
    qemu-img create -f qcow2 "$img" "${disk_gb}G" 2>&1 || die "qemu-img failed"

    local args=(
        virt-install
        --name "$name"
        --memory "$ram"
        --vcpus "$vcpus"
        --disk "path=${img},format=qcow2"
        --os-variant "${os_type}"
        --network network=default
        --graphics vnc,listen=0.0.0.0
        --noautoconsole
    )

    if [ -n "$iso" ] && [ -f "$iso" ]; then
        args+=(--cdrom "$iso")
    else
        args+=(--boot hd --import)
    fi

    info "Creating VM '$name'..."
    "${args[@]}" 2>&1 || die "virt-install failed"
    info "VM '$name' created."
}

cmd_vm_start() {
    cmd_vm_check
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid vm-start <name>"
    virsh start "$name" 2>&1 || die "Failed to start VM '$name'"
    info "VM '$name' started."
}

cmd_vm_stop() {
    cmd_vm_check
    local name="${1:-}" force="${2:-}"
    [ -z "$name" ] && die "Usage: freeraid vm-stop <name>"
    if [ "$force" = "force" ]; then
        virsh destroy "$name" 2>&1 || true
    else
        virsh shutdown "$name" 2>&1 || die "Failed to shutdown VM '$name'"
    fi
    info "VM '$name' stopped."
}

cmd_vm_delete() {
    cmd_vm_check
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid vm-delete <name>"
    virsh destroy "$name" 2>/dev/null || true
    virsh undefine "$name" --remove-all-storage 2>&1 || virsh undefine "$name" 2>&1 || die "Failed to delete VM"
    info "VM '$name' deleted."
}

cmd_vm_info() {
    cmd_vm_check
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid vm-info <name>"
    local state vcpus maxmem
    state=$(virsh domstate "$name" 2>/dev/null || echo "unknown")
    vcpus=$(virsh dominfo "$name" 2>/dev/null | awk '/CPU\(s\)/{print $2}' || echo "?")
    maxmem=$(virsh dominfo "$name" 2>/dev/null | awk '/Max memory/{printf "%.0f MB", $3/1024}' || echo "?")
    # Get VNC port
    local vnc_port
    vnc_port=$(virsh vncdisplay "$name" 2>/dev/null || echo "")
    state=$(echo "$state" | tr -d '[:space:]')
    echo "{\"name\":\"${name}\",\"state\":\"${state}\",\"vcpus\":\"${vcpus}\",\"maxmem\":\"${maxmem}\",\"vnc\":\"${vnc_port}\"}"
}

cmd_vm_vnc_port() {
    cmd_vm_check
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid vm-vnc-port <name>"
    virsh vncdisplay "$name" 2>/dev/null || echo ""
}

cmd_vm_iso_list() {
    # List ISO files in common locations
    local dirs=("$VM_ISO_DIR" "/var/lib/libvirt/images" "/tmp")
    local out="["
    local first=1
    for dir in "${dirs[@]}"; do
        [ -d "$dir" ] || continue
        while IFS= read -r f; do
            [ "$first" = "1" ] && first=0 || out+=","
            local size
            size=$(du -sh "$f" 2>/dev/null | cut -f1 || echo "?")
            local fname
            fname=$(basename "$f" | sed 's/"/\\"/g')
            f=$(echo "$f" | sed 's/"/\\"/g')
            out+="{\"path\":\"${f}\",\"name\":\"${fname}\",\"size\":\"${size}\"}"
        done < <(find "$dir" -maxdepth 2 -name "*.iso" 2>/dev/null)
    done
    out+="]"
    echo "$out"
}

## ── ZFS ──────────────────────────────────────────────────────────────────────

cmd_zfs_check() {
    command -v zpool &>/dev/null || die "ZFS is not installed. Run: apt-get install -y zfsutils-linux"
}

cmd_zfs_pool_list() {
    cmd_zfs_check
    # Return list of all zpools with health, size, used, free
    if ! zpool list -H -o name 2>/dev/null | grep -q .; then
        echo "[]"
        return
    fi
    local out="["
    local first=1
    while IFS=$'\t' read -r name size alloc free ckpoint expandsz frag cap dedup health altroot; do
        [ "$first" = "1" ] && first=0 || out+=","
        # Get datasets for this pool
        local datasets
        datasets=$(zfs list -H -o name,used,avail,mountpoint,compression,quota -t filesystem -r "$name" 2>/dev/null \
            | awk -v OFS='\t' '{print $0}' | head -20)
        local ds_json="["
        local df=1
        while IFS=$'\t' read -r dsname dsused dsavail dsmount dscomp dsquota; do
            [ "$df" = "1" ] && df=0 || ds_json+=","
            dsname=$(echo "$dsname" | sed 's/"/\\"/g')
            ds_json+="{\"name\":\"${dsname}\",\"used\":\"${dsused}\",\"avail\":\"${dsavail}\",\"mountpoint\":\"${dsmount}\",\"compression\":\"${dscomp}\",\"quota\":\"${dsquota}\"}"
        done <<< "$datasets"
        ds_json+="]"
        out+="{\"name\":\"${name}\",\"size\":\"${size}\",\"alloc\":\"${alloc}\",\"free\":\"${free}\",\"health\":\"${health}\",\"datasets\":${ds_json}}"
    done < <(zpool list -H -o name,size,alloc,free,checkpoint,expandsz,frag,cap,dedup,health,altroot 2>/dev/null)
    out+="]"
    echo "$out"
}

