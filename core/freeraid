cmd_zfs_pool_create() {
    # Usage: freeraid zfs-pool-create <name> <type:stripe|mirror|raidz|raidz2> <dev1> [dev2 ...]
    cmd_zfs_check
    local name="${1:-}" vdev_type="${2:-stripe}"
    shift 2 2>/dev/null || true
    local devs=("$@")
    [ -z "$name" ] && die "Usage: freeraid zfs-pool-create <name> <type> <dev1> [dev2...]"
    [ ${#devs[@]} -eq 0 ] && die "At least one device required"

    local mount_point="/mnt/zfs/${name}"
    mkdir -p "$mount_point"

    local cmd_args=("zpool" "create" "-f" "-m" "$mount_point" "$name")
    if [ "$vdev_type" = "stripe" ]; then
        cmd_args+=("${devs[@]}")
    else
        cmd_args+=("$vdev_type" "${devs[@]}")
    fi

    "${cmd_args[@]}" 2>&1 || die "zpool create failed"

    # Enable compression by default
    zfs set compression=lz4 "$name" 2>/dev/null || true
    zfs set atime=off "$name" 2>/dev/null || true

    info "ZFS pool '$name' created at $mount_point (compression=lz4, atime=off)"
}

