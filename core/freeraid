cmd_shares_list() {
    jq -c '.shares // []' "$CONFIG_FILE"
}

cmd_shares_apply() {
    # Write smb.conf and reload samba based on current shares config
    require samba

    local smb_conf="/etc/samba/smb.conf"
    local pool
    pool=$(cfg_pool_mountpoint)

    info "Writing Samba config..."

    local samba_anon
    samba_anon=$(jq -r '.samba_anon // false' "$CONFIG_FILE" 2>/dev/null || echo "false")

    cat > "$smb_conf" <<SMBEOF
[global]
   workgroup = WORKGROUP
   server string = FreeRAID
   netbios name = $(hostname)
   security = user
   map to guest = $([ "$samba_anon" = "true" ] && echo "bad user" || echo "never")
   dns proxy = no
   fruit:metadata = stream
   fruit:model = MacSamba
   vfs objects = catia fruit streams_xattr

SMBEOF

    while IFS= read -r share; do
        local name smb_enabled smb_security comment read_list write_list share_pw_set samba_user share_pool
        name=$(echo "$share" | jq -r '.name')
        smb_enabled=$(echo "$share" | jq -r '.smb_enabled')
        smb_security=$(echo "$share" | jq -r '.smb_security // "public"')
        comment=$(echo "$share" | jq -r '.comment // ""')
        read_list=$(echo "$share" | jq -r '.smb_read_list // [] | join(",")')
        write_list=$(echo "$share" | jq -r '.smb_write_list // [] | join(",")')
        share_pw_set=$(echo "$share" | jq -r '.share_password_set // false')
        samba_user="freeraid_share_${name}"
        share_pool=$(echo "$share" | jq -r '.pool // "array"')
        local path
        if [ "$share_pool" = "array" ] || [ -z "$share_pool" ]; then
            path="${pool}/${name}"
        else
            local extra_pool_mnt
            extra_pool_mnt=$(jq -r --arg p "$share_pool" '.pools // [] | .[] | select(.name==$p) | .mountpoint' "$CONFIG_FILE" 2>/dev/null || echo "")
            path="${extra_pool_mnt:-$pool}/${name}"
        fi

        [ "$smb_enabled" = "false" ] && continue

        mkdir -p "$path"

        cat >> "$smb_conf" <<SHAREEOF
[${name}]
   path = ${path}
   comment = ${comment}
SHAREEOF

        if [ "$smb_security" = "public" ] && [ "$share_pw_set" != "true" ]; then
            cat >> "$smb_conf" <<SHAREEOF
   guest ok = yes
   browseable = yes
   writable = yes
SHAREEOF
        else
            cat >> "$smb_conf" <<SHAREEOF
   guest ok = no
   browseable = yes
   writable = yes
SHAREEOF
            # If share has a dedicated password user, add them to valid users
            if [ "$share_pw_set" = "true" ]; then
                echo "   valid users = ${samba_user}" >> "$smb_conf"
            else
                [ -n "$read_list"  ] && echo "   read list = ${read_list}" >> "$smb_conf"
                [ -n "$write_list" ] && echo "   write list = ${write_list}" >> "$smb_conf"
            fi
        fi
        echo "" >> "$smb_conf"

    done < <(jq -c '.shares[]' "$CONFIG_FILE" 2>/dev/null)

    systemctl restart smbd nmbd 2>/dev/null || systemctl restart samba 2>/dev/null || true
    info "Samba reloaded. Shares active."

    # Also regenerate NFS exports if nfs-kernel-server is installed
    command -v exportfs &>/dev/null && cmd_nfs_apply 2>/dev/null || true
}

cmd_nfs_apply() {
    local exports_file="/etc/exports"
    local pool
    pool=$(cfg_pool_mountpoint)

    info "Writing NFS exports..."
    > "$exports_file"

    while IFS= read -r share; do
        local name nfs_enabled nfs_clients nfs_options
        name=$(echo "$share" | jq -r '.name')
        nfs_enabled=$(echo "$share" | jq -r '.nfs_enabled // false')
        [ "$nfs_enabled" = "false" ] && continue

        nfs_clients=$(echo "$share" | jq -r '.nfs_clients // "*"')
        nfs_options=$(echo "$share" | jq -r '.nfs_options // "rw,sync,no_subtree_check,no_root_squash"')
        local path="${pool}/${name}"
        mkdir -p "$path"
        echo "${path}  ${nfs_clients}(${nfs_options})" >> "$exports_file"
        info "Exporting: ${path} → ${nfs_clients}"
    done < <(jq -c '.shares[]' "$CONFIG_FILE" 2>/dev/null)

    exportfs -ra 2>/dev/null || true
    systemctl is-active --quiet nfs-kernel-server 2>/dev/null && systemctl reload-or-restart nfs-kernel-server 2>/dev/null || true
    info "NFS exports applied."
}

cmd_shares_add() {
    local name="$1"
    [ -z "$name" ] && die "Usage: freeraid shares-add <name>"
    local existing
    existing=$(jq -r --arg n "$name" '.shares[] | select(.name==$n) | .name' "$CONFIG_FILE" 2>/dev/null || true)
    [ -n "$existing" ] && die "Share '$name' already exists"

    local pool_mnt
    pool_mnt=$(cfg '.array.pool_mountpoint // "/mnt/freeraid"')

    jq --arg name "$name" --arg path "${pool_mnt}/${name}" \
       '.shares += [{"name":$name,"path":$path,"comment":"","smb_enabled":true,"smb_security":"public","smb_read_list":[],"smb_write_list":[],"nfs_enabled":false,"cache_mode":"yes","cache_pool":"cache","include_disks":[],"exclude_disks":[]}]' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    mkdir -p "${pool_mnt}/${name}" 2>/dev/null || true
    cmd_shares_apply
    info "Share '$name' created and active."
}

cmd_shares_remove() {
    local name="$1"
    [ -z "$name" ] && die "Usage: freeraid shares-remove <name>"
    jq --arg n "$name" 'del(.shares[] | select(.name==$n))' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    info "Share '$name' removed. Run 'freeraid shares-apply' to apply."
}

cmd_shares_set_perms() {
    # Usage: freeraid shares-set-perms <name> <security> <read_list_json> <write_list_json>
    # security: public | secure | private
    # read_list_json:  JSON array string e.g. '["alice","bob"]'
    # write_list_json: JSON array string e.g. '["alice"]'
    local name="${1:-}"
    local security="${2:-public}"
    local read_json="${3:-[]}"
    local write_json="${4:-[]}"
    [ -z "$name" ] && die "Usage: freeraid shares-set-perms <name> <security> <read_json> <write_json>"

    local existing
    existing=$(jq -r --arg n "$name" '.shares[] | select(.name==$n) | .name' "$CONFIG_FILE" 2>/dev/null || true)
    [ -z "$existing" ] && die "Share '$name' not found"

    jq --arg n "$name" \
       --arg sec "$security" \
       --argjson rl "$read_json" \
       --argjson wl "$write_json" \
       '(.shares[] | select(.name==$n)) |= . + {"smb_security":$sec,"smb_read_list":$rl,"smb_write_list":$wl}' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    cmd_shares_apply
    info "Permissions updated for share '$name'."
}

cmd_shares_set_password() {
    # Usage: freeraid shares-set-password <name> <password|"">
    # Empty password disables share-level password (reverts to standard user auth)
    local name="${1:-}" password="${2:-}"
    [ -z "$name" ] && die "Usage: freeraid shares-set-password <name> <password>"

    local existing
    existing=$(jq -r --arg n "$name" '.shares[] | select(.name==$n) | .name' "$CONFIG_FILE" 2>/dev/null || true)
    [ -z "$existing" ] && die "Share '$name' not found"

    local samba_user="freeraid_share_${name}"

    if [ -z "$password" ]; then
        # Remove password protection: delete the samba user if it exists
        if id "$samba_user" &>/dev/null; then
            smbpasswd -x "$samba_user" 2>/dev/null || true
            userdel "$samba_user" 2>/dev/null || true
        fi
        jq --arg n "$name" \
           '(.shares[] | select(.name==$n)) |= del(.share_password_set)' \
           "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
        cmd_shares_apply
        info "Password removed from share '$name'."
    else
        # Create system user (no login shell, no home) if not already present
        if ! id "$samba_user" &>/dev/null; then
            useradd -r -s /usr/sbin/nologin -M "$samba_user" 2>/dev/null || true
        fi
        # Set samba password non-interactively
        printf '%s\n%s\n' "$password" "$password" | smbpasswd -a -s "$samba_user" 2>/dev/null
        smbpasswd -e "$samba_user" 2>/dev/null || true
        # Record that share has a password (don't store plaintext)
        jq --arg n "$name" \
           '(.shares[] | select(.name==$n)) |= . + {"share_password_set":true}' \
           "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
        cmd_shares_apply
        info "Password set for share '$name'. Connect as user: $samba_user"
    fi
}

cmd_share_encrypt_enable() {
    # Usage: freeraid share-encrypt-enable <name> <password>
    # Creates a gocryptfs vault for the share and marks it encrypted.
    # The vault lives at <share_path>/.vault and mounts back onto <share_path>.
    local name="${1:-}" password="${2:-}"
    [ -z "$name" ] || [ -z "$password" ] && die "Usage: freeraid share-encrypt-enable <name> <password>"

    command -v gocryptfs &>/dev/null || die "gocryptfs is not installed. Run: apt-get install -y gocryptfs"

    local existing
    existing=$(jq -r --arg n "$name" '.shares[] | select(.name==$n) | .name' "$CONFIG_FILE" 2>/dev/null || true)
    [ -z "$existing" ] && die "Share '$name' not found"

    local already_enc
    already_enc=$(jq -r --arg n "$name" '.shares[] | select(.name==$n) | .encrypted // false' "$CONFIG_FILE")
    [ "$already_enc" = "true" ] && die "Share '$name' is already encrypted."

    local share_path
    share_path=$(jq -r --arg n "$name" '.shares[] | select(.name==$n) | .pool // "array"' "$CONFIG_FILE")
    local pool_mnt
    pool_mnt=$(cfg_pool_mountpoint)
    if [ "$share_path" = "array" ] || [ -z "$share_path" ]; then
        share_path="${pool_mnt}/${name}"
    else
        local extra_mnt
        extra_mnt=$(jq -r --arg p "$share_path" '.pools // [] | .[] | select(.name==$p) | .mountpoint' "$CONFIG_FILE" 2>/dev/null || echo "")
        share_path="${extra_mnt:-$pool_mnt}/${name}"
    fi

    local vault_dir="${share_path}/.vault"
    mkdir -p "$vault_dir" "$share_path"

    # Move existing share contents into vault staging area so they aren't lost
    local staging="/tmp/freeraid_enc_stage_${name}"
    mkdir -p "$staging"
    shopt -s dotglob nullglob
    local files=("${share_path}"/*)
    for f in "${files[@]}"; do
        [[ "$f" == "${vault_dir}" ]] && continue
        mv "$f" "$staging/" 2>/dev/null || true
    done
    shopt -u dotglob nullglob

    # Initialise the gocryptfs vault
    echo "$password" | gocryptfs -init -passfile /dev/stdin "$vault_dir" 2>&1 \
        || die "gocryptfs init failed"

    # Mount vault onto share path
    echo "$password" | gocryptfs -passfile /dev/stdin "$vault_dir" "$share_path" 2>&1 \
        || die "gocryptfs mount failed"

    # Restore files into the now-encrypted mount
    if [ -d "$staging" ]; then
        cp -a "$staging"/. "$share_path"/ 2>/dev/null || true
        rm -rf "$staging"
    fi

    # Record in config
    jq --arg n "$name" \
       '(.shares[] | select(.name==$n)) |= . + {"encrypted":true}' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    info "Share '$name' is now encrypted and unlocked."
}

cmd_share_encrypt_disable() {
    # Usage: freeraid share-encrypt-disable <name> <password>
    local name="${1:-}" password="${2:-}"
    [ -z "$name" ] || [ -z "$password" ] && die "Usage: freeraid share-encrypt-disable <name> <password>"

    local share_path
    share_path=$(_share_resolve_path "$name")

    local vault_dir="${share_path}/.vault"
    [ ! -d "$vault_dir" ] && die "No vault found for share '$name'"

    # Unlock if not already mounted so we can decrypt files out
    if ! mountpoint -q "$share_path" 2>/dev/null; then
        echo "$password" | gocryptfs -passfile /dev/stdin "$vault_dir" "$share_path" 2>&1 \
            || die "Could not unlock vault to decrypt — wrong password?"
    fi

    # Copy files out to a temp location
    local staging="/tmp/freeraid_dec_stage_${name}"
    mkdir -p "$staging"
    shopt -s dotglob nullglob
    local files=("${share_path}"/*)
    for f in "${files[@]}"; do
        cp -a "$f" "$staging/" 2>/dev/null || true
    done
    shopt -u dotglob nullglob

    # Unmount
    fusermount -u "$share_path" 2>/dev/null || umount "$share_path" 2>/dev/null || true

    # Remove vault directory
    rm -rf "$vault_dir"

    # Restore plaintext files
    cp -a "$staging"/. "$share_path"/ 2>/dev/null || true
    rm -rf "$staging"

    # Update config
    jq --arg n "$name" \
       '(.shares[] | select(.name==$n)) |= del(.encrypted)' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    info "Encryption removed from share '$name'. Files are now unencrypted."
}

cmd_share_encrypt_unlock() {
    # Usage: freeraid share-encrypt-unlock <name> <password>
    local name="${1:-}" password="${2:-}"
    [ -z "$name" ] || [ -z "$password" ] && die "Usage: freeraid share-encrypt-unlock <name> <password>"

    local share_path
    share_path=$(_share_resolve_path "$name")
    local vault_dir="${share_path}/.vault"
    [ ! -d "$vault_dir" ] && die "No vault found for share '$name'. Is encryption enabled?"

    if mountpoint -q "$share_path" 2>/dev/null; then
        info "Share '$name' is already unlocked."
        exit 0
    fi

    echo "$password" | gocryptfs -passfile /dev/stdin "$vault_dir" "$share_path" 2>&1 \
        || die "Failed to unlock share '$name' — wrong password?"

    info "Share '$name' unlocked."
}

cmd_share_encrypt_lock() {
    # Usage: freeraid share-encrypt-lock <name>
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid share-encrypt-lock <name>"

    local share_path
    share_path=$(_share_resolve_path "$name")

    if ! mountpoint -q "$share_path" 2>/dev/null; then
        info "Share '$name' is already locked."
        exit 0
    fi

    fusermount -u "$share_path" 2>/dev/null || umount "$share_path" 2>/dev/null \
        || die "Failed to lock share '$name' — files may still be open."

    info "Share '$name' locked."
}

cmd_share_encrypt_status() {
    # Usage: freeraid share-encrypt-status <name>
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid share-encrypt-status <name>"

    local encrypted
    encrypted=$(jq -r --arg n "$name" '.shares[] | select(.name==$n) | .encrypted // false' "$CONFIG_FILE" 2>/dev/null || echo "false")

    local share_path
    share_path=$(_share_resolve_path "$name")
    local unlocked="false"
    if mountpoint -q "$share_path" 2>/dev/null; then
        unlocked="true"
    fi

    echo "{\"encrypted\":${encrypted},\"unlocked\":${unlocked}}"
}

_share_resolve_path() {
    local name="${1:-}"
    local share_pool
    share_pool=$(jq -r --arg n "$name" '.shares[] | select(.name==$n) | .pool // "array"' "$CONFIG_FILE" 2>/dev/null || echo "array")
    local pool_mnt
    pool_mnt=$(cfg_pool_mountpoint)
    if [ "$share_pool" = "array" ] || [ -z "$share_pool" ]; then
        echo "${pool_mnt}/${name}"
    else
        local extra_mnt
        extra_mnt=$(jq -r --arg p "$share_pool" '.pools // [] | .[] | select(.name==$p) | .mountpoint' "$CONFIG_FILE" 2>/dev/null || echo "")
        echo "${extra_mnt:-$pool_mnt}/${name}"
    fi
}

cmd_shares_set_nfs() {
    # Usage: freeraid shares-set-nfs <name> <enabled:true|false> [clients] [options]
    local name="${1:-}" enabled="${2:-false}"
    local clients="${3:-*}"
    local options="${4:-rw,sync,no_subtree_check,no_root_squash}"
    [ -z "$name" ] && die "Usage: freeraid shares-set-nfs <name> <true|false> [clients] [options]"

    local existing
    existing=$(jq -r --arg n "$name" '.shares[] | select(.name==$n) | .name' "$CONFIG_FILE" 2>/dev/null || true)
    [ -z "$existing" ] && die "Share '$name' not found"

    jq --arg n "$name" \
       --argjson en "$([ "$enabled" = "true" ] && echo true || echo false)" \
       --arg cl "$clients" \
       --arg op "$options" \
       '(.shares[] | select(.name==$n)) |= . + {"nfs_enabled":$en,"nfs_clients":$cl,"nfs_options":$op}' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    cmd_nfs_apply
    info "NFS settings updated for share '$name'."
}

cmd_shares_import() {
    # Import shares from a Unraid config directory
    local src="${1:-}"
    [ -z "$src" ] && die "Usage: freeraid shares-import <path-to-unraid-config-dir>"
    [ -d "$src/shares" ] || die "No shares/ directory found in $src"

    require python3

    local tmpout
    tmpout=$(mktemp /tmp/freeraid-shares-XXXXXX.json)

    python3 - "$src" "$tmpout" <<'PYEOF'
import sys, json, re
from pathlib import Path

def parse_cfg(path):
    result = {}
    if not path.exists(): return result
    for line in path.read_text(errors='replace').splitlines():
        line = line.strip()
        if not line or line.startswith('#'): continue
        m = re.match(r'^(\w+)="?([^"]*)"?$', line)
        if m: result[m.group(1)] = m.group(2)
    return result

config_dir = Path(sys.argv[1])
out_file   = sys.argv[2]
shares = []

for f in sorted((config_dir / 'shares').glob('*.cfg')):
    s    = parse_cfg(f)
    name = f.stem
    shares.append({
        "name":           name,
        "path":           f'/mnt/user/{name}',
        "comment":        s.get('shareComment', ''),
        "smb_enabled":    s.get('shareExport', 'e') == 'e',
        "smb_security":   s.get('shareSecurity', 'public'),
        "smb_read_list":  [u for u in s.get('shareReadList','').split(',') if u],
        "smb_write_list": [u for u in s.get('shareWriteList','').split(',') if u],
        "nfs_enabled":    s.get('shareExportNFS', '-') != '-',
        "nfs_security":   s.get('shareSecurityNFS', 'public'),
        "cache_mode":     s.get('shareUseCache', 'yes'),
        "cache_pool":     s.get('shareCachePool', 'cache'),
        "allocator":      s.get('shareAllocator', 'highwater'),
        "split_level":    s.get('shareSplitLevel', ''),
        "include_disks":  [d for d in s.get('shareInclude','').split(',') if d],
        "exclude_disks":  [d for d in s.get('shareExclude','').split(',') if d],
        "cow":            s.get('shareCOW', 'auto'),
        "_imported_from_unraid": True
    })

json.dump(shares, open(out_file, 'w'), indent=2)
print(f"Parsed {len(shares)} shares")
PYEOF

    local count
    count=$(jq 'length' "$tmpout")
    info "Importing $count shares from $src..."

    # Merge into config — replace existing shares array
    jq --slurpfile newshares "$tmpout" '.shares = $newshares[0]' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    rm -f "$tmpout"
    info "Done. Run 'freeraid shares-apply' to activate via Samba."
}

APPFEED_CACHE="/etc/freeraid/appfeed.json"
APPFEED_URL="https://raw.githubusercontent.com/Squidly271/AppFeed/master/applicationFeed.json"

cmd_apps_fetch() {
    require curl
    require python3
    info "Fetching Community App feed..."
    local tmp; tmp=$(mktemp /tmp/freeraid-appfeed-XXXXXX.json)
    curl -fsSL "$APPFEED_URL" -o "$tmp" || die "Failed to download app feed"
    info "Processing feed..."
    mkdir -p "$(dirname "$APPFEED_CACHE")"
    python3 - "$tmp" "$APPFEED_CACHE" <<'PYEOF'
import sys, json

raw = json.load(open(sys.argv[1]))
apps = raw.get('applist', [])

out = []
for a in apps:
    if a.get('Plugin'):
        continue
    repo = a.get('Repository', '')
    if not repo:
        continue
    # Normalize Config to flat list
    cfg = a.get('Config', []) or []
    if isinstance(cfg, dict):
        cfg = [cfg]
    clean_cfg = []
    for c in cfg:
        attrs = c.get('@attributes', {}) if isinstance(c, dict) else {}
        clean_cfg.append({
            'name':     attrs.get('Name', ''),
            'type':     attrs.get('Type', ''),
            'target':   attrs.get('Target', ''),
            'default':  attrs.get('Default', c.get('value', '') if isinstance(c, dict) else ''),
            'mode':     attrs.get('Mode', 'rw'),
            'desc':     attrs.get('Description', ''),
            'required': attrs.get('Required', 'false') == 'true',
            'mask':     attrs.get('Mask', 'false') == 'true',
        })
    out.append({
        'name':       a.get('Name', ''),
        'image':      repo,
        'registry':   a.get('Registry', ''),
        'network':    a.get('Network', 'bridge'),
        'webui':      a.get('WebUI', ''),
        'overview':   a.get('Overview', ''),
        'icon':       a.get('Icon', ''),
        'categories': a.get('CategoryList', []),
        'downloads':  a.get('downloads', 0),
        'stars':      a.get('stars', 0),
        'search':     ' '.join(filter(None, [
            a.get('Name',''), a.get('Overview','')[:100],
            a.get('ExtraSearchTerms',''),
            ' '.join(a.get('CategoryList', []))
        ])).lower(),
        'config':     clean_cfg,
    })

out.sort(key=lambda x: -(x.get('downloads') or 0))
json.dump(out, open(sys.argv[2], 'w'))
print(f"Cached {len(out)} apps to {sys.argv[2]}")
PYEOF
    rm -f "$tmp"
    info "App feed ready. $(jq 'length' "$APPFEED_CACHE") apps available."
}

cmd_apps_search() {
    local query="${1:-}" limit="${2:-50}"
    [ -f "$APPFEED_CACHE" ] || die "App feed not cached. Run: freeraid apps-fetch"
    python3 - "$APPFEED_CACHE" "$query" "$limit" <<'PYEOF'
import sys, json, re

apps  = json.load(open(sys.argv[1]))
query = sys.argv[2].lower().strip()
limit = int(sys.argv[3])

if query:
    terms = query.split()
    def score(a):
        s = a.get('search', '')
        n = a.get('name', '').lower()
        return sum(2 if t in n else (1 if t in s else 0) for t in terms)
    results = [a for a in apps if score(a) > 0]
    results.sort(key=lambda a: -score(a))
else:
    results = apps

out = []
for a in results[:limit]:
    out.append({
        'name':       a['name'],
        'image':      a['image'],
        'overview':   a['overview'][:120] + ('…' if len(a.get('overview','')) > 120 else ''),
        'icon':       a['icon'],
        'categories': a['categories'][:3],
        'downloads':  a.get('downloads', 0),
        'stars':      a.get('stars', 0),
    })

print(json.dumps(out))
PYEOF
}

