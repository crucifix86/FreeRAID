    docker network create \
        -d macvlan \
        --subnet="$subnet" \
        --gateway="$gateway" \
        -o parent="$parent" \
        "$net_name" \
    && echo "{\"ok\":true,\"name\":\"$net_name\"}" \
    || die "Failed to create network $net_name"
}

