cmd_replace_disk_status() {
    local slot="${1:-}"
    [ -z "$slot" ] && die "Usage: freeraid replace-disk-status <slot>"
    local run_dir="/var/run/freeraid"
    local pid_file="$run_dir/replace-${slot}.pid"
    local log_file="/var/log/freeraid-replace-${slot}.log"
    local status_file="$run_dir/replace-${slot}.status"

    if [ ! -f "$pid_file" ]; then
        printf '{"running":false,"exit":null,"log":""}\n'
        return
    fi

    local pid; pid=$(cat "$pid_file")
    local running=false exit_code="null" last_lines=""

    if kill -0 "$pid" 2>/dev/null; then
        running=true
    else
        local raw_status
        raw_status=$(cat "$status_file" 2>/dev/null || echo "")
        [[ "$raw_status" =~ ^[0-9]+$ ]] && exit_code="$raw_status"
    fi

    [ -f "$log_file" ] && last_lines=$(tail -5 "$log_file" 2>/dev/null | jq -Rs .)

    printf '{"running":%s,"exit":%s,"log":%s}\n' \
        "$running" "$exit_code" "${last_lines:-\"\"}"
}

# ── File balancer ────────────────────────────────────────────────────────────

cmd_balance_status() {
    # Returns per-disk usage as JSON for the UI to display
    local run_dir="/var/run/freeraid"
    local progress_file="$run_dir/balance.progress"
    local pid_file="$run_dir/balance.pid"

    local running=false
    if [ -f "$pid_file" ]; then
        local pid; pid=$(cat "$pid_file")
        kill -0 "$pid" 2>/dev/null && running=true
    fi

    # Per-disk usage
    local disks_json="["
    local first=true
    while IFS=' ' read -r dev mnt fstype; do
        [ -b "$dev" ] || continue
        mountpoint -q "$mnt" 2>/dev/null || continue
        local used_kb avail_kb total_kb pct
        read -r used_kb avail_kb total_kb < <(df -k --output=used,avail,size "$mnt" 2>/dev/null | tail -1)
        pct=$(( total_kb > 0 ? used_kb * 100 / total_kb : 0 ))
        $first || disks_json+=","
        disks_json+="{\"device\":\"${dev}\",\"mountpoint\":\"${mnt}\",\"used_kb\":${used_kb:-0},\"avail_kb\":${avail_kb:-0},\"total_kb\":${total_kb:-0},\"pct\":${pct}}"
        first=false
    done < <(cfg_array_disks_enabled)
    disks_json+="]"

    local progress='{}'
    [ -f "$progress_file" ] && progress=$(cat "$progress_file" 2>/dev/null || echo '{}')

    printf '{"running":%s,"disks":%s,"progress":%s}\n' \
        "$running" "$disks_json" "$progress"
}

cmd_balance_bg() {
    # Start the file balancer as a background job
    # Moves files from most-full disks to least-full until within threshold
    local threshold="${1:-10}"  # stop when max-min usage % difference is within threshold
    local run_dir="/var/run/freeraid"
    mkdir -p "$run_dir"
    local pid_file="$run_dir/balance.pid"
    local log_file="/var/log/freeraid-balance.log"
    local progress_file="$run_dir/balance.progress"

    if [ -f "$pid_file" ]; then
        local old_pid; old_pid=$(cat "$pid_file")
        kill -0 "$old_pid" 2>/dev/null && die "Balancer already running (pid $old_pid)"
    fi

    printf '{"stage":"starting","moved_files":0,"moved_bytes":0,"log":"Starting balancer..."}\n' > "$progress_file"

    # Build disk list for the background script
    local disk_list
    disk_list=$(jq -r '.array.disks[] | select(.enabled==true) | .mountpoint' "$CONFIG_FILE" 2>/dev/null | tr '\n' ' ')

    nohup bash << BALSCRIPT > /dev/null 2>&1 &
#!/bin/bash
LOG="$log_file"
PROG="$progress_file"
THRESHOLD=$threshold
DISKS=($disk_list)

_upd() { printf '{"stage":"%s","moved_files":%d,"moved_bytes":%d,"log":"%s"}\n' "\$1" "\$2" "\$3" "\$4" > "\$PROG"; }
_disk_used_pct() { df -k "\$1" 2>/dev/null | tail -1 | awk '{if(\$2>0) print int(\$3*100/\$2); else print 0}'; }
_disk_avail_kb() { df -k "\$1" 2>/dev/null | tail -1 | awk '{print \$4}'; }

echo "[$(date)] Balancer started. Threshold: \${THRESHOLD}%" > "\$LOG"
_upd "balancing" 0 0 "Analyzing disk usage..."

moved_files=0
moved_bytes=0
passes=0

while true; do
    passes=\$((passes + 1))
    [ "\$passes" -gt 50 ] && break  # safety limit

    # Find most-full and least-full mounted disks
    max_pct=0; min_pct=100; src=""; dst=""
    for d in "\${DISKS[@]}"; do
        mountpoint -q "\$d" 2>/dev/null || continue
        pct=\$(_disk_used_pct "\$d")
        [ "\$pct" -gt "\$max_pct" ] && { max_pct=\$pct; src="\$d"; }
        [ "\$pct" -lt "\$min_pct" ] && { min_pct=\$pct; dst="\$d"; }
    done

    diff=\$((max_pct - min_pct))
    echo "[$(date)] Pass \$passes: max=\${max_pct}% (\$src), min=\${min_pct}% (\$dst), diff=\${diff}%" >> "\$LOG"

    [ "\$diff" -le "\$THRESHOLD" ] && break
    [ -z "\$src" ] || [ -z "\$dst" ] || [ "\$src" = "\$dst" ] && break

    avail_kb=\$(_disk_avail_kb "\$dst")

    # Find and move the largest file from src that fits in dst
    moved_this_pass=0
    while IFS= read -r -d '' f; do
        fsize_kb=\$(du -k "\$f" 2>/dev/null | awk '{print \$1}')
        [ "\${fsize_kb:-0}" -gt "\$avail_kb" ] && continue

        rel="\${f#\$src/}"
        dst_path="\$dst/\$rel"
        dst_dir="\$(dirname "\$dst_path")"
        mkdir -p "\$dst_dir"

        echo "[$(date)] Moving: \$f → \$dst_path (\${fsize_kb}KB)" >> "\$LOG"
        _upd "balancing" "\$moved_files" "\$((moved_bytes + fsize_kb * 1024))" "Moving \$(basename "\$f")..."

        if rsync -a --remove-source-files "\$f" "\$dst_path" 2>> "\$LOG"; then
            moved_files=\$((moved_files + 1))
            moved_bytes=\$((moved_bytes + fsize_kb * 1024))
            avail_kb=\$((avail_kb - fsize_kb))
            moved_this_pass=1
            break
        else
            echo "[$(date)] rsync failed for \$f" >> "\$LOG"
        fi
    done < <(find "\$src" -type f -not -name '.snapraid*' -print0 2>/dev/null | sort -z -t/ -k1)

    # If we couldn't move anything this pass, stop
    [ "\$moved_this_pass" -eq 0 ] && break
done

echo "[$(date)] Balancer done. Moved \$moved_files files (\$((moved_bytes / 1048576)) MB)." >> "\$LOG"
_upd "done" "\$moved_files" "\$moved_bytes" "Complete — moved \$moved_files files."
BALSCRIPT

    echo $! > "$pid_file"
    info "Balancer started in background (pid $!)"
    printf '{"pid":%d,"log":"%s"}\n' "$!" "$log_file"
}

cmd_balance_cancel() {
    local run_dir="/var/run/freeraid"
    local pid_file="$run_dir/balance.pid"
    [ -f "$pid_file" ] || die "No balancer running"
    local pid; pid=$(cat "$pid_file")
    kill -TERM "$pid" 2>/dev/null || true
    pkill -TERM -P "$pid" 2>/dev/null || true
    rm -f "$pid_file"
    info "Balancer cancelled"
}

# ── Drive pre-clear ──────────────────────────────────────────────────────────

cmd_preclear_bg() {
    # Start a pre-clear on a drive in the background
    # Stages: 1) SMART short test  2) Zero the drive  3) SMART long test
    local dev="${1:-}"
    [ -z "$dev" ] && die "Usage: freeraid preclear-bg <device>"
    [ -b "$dev" ] || die "Device not found: $dev"

    # Safety: refuse if device is currently assigned in config
    local assigned
    assigned=$(jq -r '
        (.array.disks[]  | .device),
        (.array.parity[] | .device),
        (.array.cache[]  | .device)
    ' "$CONFIG_FILE" 2>/dev/null | grep -xF "$dev" || true)
    [ -n "$assigned" ] && die "Cannot pre-clear $dev — it is assigned to the array"

    local run_dir="/var/run/freeraid"
    mkdir -p "$run_dir"
    local safe_dev="${dev//\//_}"
    local pid_file="$run_dir/preclear-${safe_dev}.pid"
    local log_file="/var/log/freeraid-preclear-${safe_dev}.log"
    local progress_file="$run_dir/preclear-${safe_dev}.progress"

    if [ -f "$pid_file" ]; then
        local old_pid; old_pid=$(cat "$pid_file")
        kill -0 "$old_pid" 2>/dev/null && die "Pre-clear already running on $dev (pid $old_pid)"
    fi

    local size_bytes
    size_bytes=$(blockdev --getsize64 "$dev" 2>/dev/null || echo 0)

    printf '{"stage":"starting","pct":0,"log":"Starting pre-clear on %s"}\n' "$dev" > "$progress_file"

    nohup bash << PCLSCRIPT > /dev/null 2>&1 &
#!/bin/bash
set -e
DEV="$dev"
LOG="$log_file"
PROG="$progress_file"
SIZE=$size_bytes

_upd() { printf '{"stage":"%s","pct":%d,"log":"%s"}\n' "\$1" "\$2" "\$3" > "\$PROG"; }

echo "[$(date)] Pre-clear started on \$DEV" > "\$LOG"

# Stage 1: SMART short self-test
_upd "smart_short" 0 "Running SMART short self-test..."
echo "[$(date)] Stage 1: SMART short self-test" >> "\$LOG"
if command -v smartctl &>/dev/null; then
    smartctl -t short "\$DEV" >> "\$LOG" 2>&1 || true
    # Wait up to 3 minutes for short test
    for i in \$(seq 1 36); do
        sleep 5
        result=\$(smartctl -a "\$DEV" 2>/dev/null | grep -i "self-test execution status" | head -1 || echo "")
        echo "\$result" >> "\$LOG"
        echo "\$result" | grep -qi "completed without error" && break
        echo "\$result" | grep -qi "in progress" || break
    done
    smartctl -a "\$DEV" >> "\$LOG" 2>&1 || true
else
    echo "smartctl not available — skipping SMART tests" >> "\$LOG"
fi
_upd "zeroing" 5 "Zeroing drive (this may take a while)..."

# Stage 2: Zero the drive with progress tracking
echo "[$(date)] Stage 2: Zeroing drive" >> "\$LOG"
if [ "\$SIZE" -gt 0 ]; then
    dd if=/dev/zero of="\$DEV" bs=1M 2>&1 | while IFS= read -r line; do
        echo "\$line" >> "\$LOG"
        # dd outputs "N bytes (X GB) copied" — parse bytes written
        if [[ "\$line" =~ ^([0-9]+)[[:space:]]bytes ]]; then
            written="\${BASH_REMATCH[1]}"
            pct=\$(( 5 + (written * 90 / SIZE) ))
            [ "\$pct" -gt 95 ] && pct=95
            _upd "zeroing" "\$pct" "Zeroing: \$((written / 1073741824)) GB written..."
        fi
    done || true
fi
sync
_upd "smart_long" 96 "Running SMART long self-test..."

# Stage 3: SMART long self-test
echo "[$(date)] Stage 3: SMART long self-test" >> "\$LOG"
if command -v smartctl &>/dev/null; then
    smartctl -t long "\$DEV" >> "\$LOG" 2>&1 || true
    # Wait up to 3 hours for long test (poll every 60s)
    for i in \$(seq 1 180); do
        sleep 60
        result=\$(smartctl -a "\$DEV" 2>/dev/null | grep -i "self-test execution status" | head -1 || echo "")
        echo "\$result" >> "\$LOG"
        echo "\$result" | grep -qi "in progress" || break
    done
    smartctl -a "\$DEV" >> "\$LOG" 2>&1 || true
fi

echo "[$(date)] Pre-clear complete." >> "\$LOG"
_upd "done" 100 "Pre-clear complete. Drive is ready to use."
PCLSCRIPT

    echo $! > "$pid_file"
    info "Pre-clear started on $dev (pid $!). Log: $log_file"
    printf '{"pid":%d,"log":"%s","progress_file":"%s"}\n' "$!" "$log_file" "$progress_file"
}

cmd_preclear_status() {
    local dev="${1:-}"
    [ -z "$dev" ] && die "Usage: freeraid preclear-status <device>"
    local run_dir="/var/run/freeraid"
    local safe_dev="${dev//\//_}"
    local pid_file="$run_dir/preclear-${safe_dev}.pid"
    local progress_file="$run_dir/preclear-${safe_dev}.progress"
    local log_file="/var/log/freeraid-preclear-${safe_dev}.log"

    if [ ! -f "$pid_file" ] && [ ! -f "$progress_file" ]; then
        printf '{"running":false,"stage":"idle","pct":0,"log":""}\n'
        return
    fi

    local running=false
    if [ -f "$pid_file" ]; then
        local pid; pid=$(cat "$pid_file")
        kill -0 "$pid" 2>/dev/null && running=true
    fi

    local progress='{}'
    [ -f "$progress_file" ] && progress=$(cat "$progress_file" 2>/dev/null || echo '{}')

    local last_lines=""
    [ -f "$log_file" ] && last_lines=$(tail -8 "$log_file" 2>/dev/null | jq -Rs .)

    local stage pct msg
    stage=$(echo "$progress" | jq -r '.stage // "idle"')
    pct=$(echo "$progress" | jq -r '.pct // 0')
    msg=$(echo "$progress" | jq -r '.log // ""' | jq -Rs .)

    printf '{"running":%s,"stage":"%s","pct":%s,"message":%s,"log":%s}\n' \
        "$running" "$stage" "$pct" "$msg" "${last_lines:-\"\"}"
}

cmd_preclear_cancel() {
    local dev="${1:-}"
    [ -z "$dev" ] && die "Usage: freeraid preclear-cancel <device>"
    local run_dir="/var/run/freeraid"
    local safe_dev="${dev//\//_}"
    local pid_file="$run_dir/preclear-${safe_dev}.pid"

    [ -f "$pid_file" ] || die "No pre-clear running on $dev"
    local pid; pid=$(cat "$pid_file")
    kill -TERM "$pid" 2>/dev/null || true
    # Also kill any dd child
    pkill -TERM -P "$pid" 2>/dev/null || true
    rm -f "$pid_file"
    info "Pre-clear cancelled on $dev"
}

# Scan all currently-mounted drives and update UUIDs/serials in config
cmd_registry_sync() {
    info "Syncing drive registry (UUID/serial) from currently-mounted drives..."
    local updated=0

    while IFS=' ' read -r slot dev mnt; do
        [ -b "$dev" ] || continue
        local uuid serial
        uuid=$(get_disk_uuid "$dev")
        serial=$(get_disk_serial "$dev")
        [ -z "$uuid" ] && continue
        jq --arg s "$slot" --arg u "$uuid" --arg sr "$serial" \
           '(.array.disks[] | select(.slot==$s)) |= . + {"uuid":$u,"serial":$sr}' \
           "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
        info "  $slot ($dev): uuid=$uuid serial=${serial:-unknown}"
        updated=$((updated + 1))
    done < <(jq -r '.array.disks[] | .slot + " " + .device + " " + .mountpoint' "$CONFIG_FILE")

    # Also parity drives
    while IFS=' ' read -r slot dev mnt; do
        [ -b "$dev" ] || continue
        local uuid serial
        uuid=$(get_disk_uuid "$dev")
        serial=$(get_disk_serial "$dev")
        [ -z "$uuid" ] && continue
        jq --arg s "$slot" --arg u "$uuid" --arg sr "$serial" \
           '(.array.parity[] | select(.slot==$s)) |= . + {"uuid":$u,"serial":$sr}' \
           "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
        info "  $slot ($dev): uuid=$uuid serial=${serial:-unknown}"
        updated=$((updated + 1))
    done < <(jq -r '.array.parity[] | .slot + " " + .device + " " + .mountpoint' "$CONFIG_FILE")

    info "Registry updated for $updated drives."
}

