#!/usr/bin/env bash
# freeraid - main CLI for FreeRAID array management
# Usage: freeraid <command> [options]

set -euo pipefail

VERSION_FILE="${FREERAID_VERSION_FILE:-/etc/freeraid/VERSION}"
FREERAID_VERSION="$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]' || echo '0.1.1')"
CONFIG_FILE="${FREERAID_CONFIG:-/boot/config/freeraid.conf.json}"
SNAPRAID_CONF="/etc/snapraid.conf"
LOG_FILE="/var/log/freeraid.log"
COMPOSE_DIR="/etc/freeraid/compose"
GITHUB_REPO="crucifix86/FreeRAID"
GITHUB_API="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"; }
info()    { echo -e "${GREEN}==>${NC} $*"; log "INFO: $*"; }
warn()    { echo -e "${YELLOW}WARN:${NC} $*"; log "WARN: $*"; }
error()   { echo -e "${RED}ERROR:${NC} $*" >&2; log "ERROR: $*"; }
die()     { error "$*"; exit 1; }
require() { command -v "$1" &>/dev/null || die "Required tool not found: $1 — run: freeraid install-deps"; }

# ── Config helpers ──────────────────────────────────────────────────────────────

cfg() { jq -r "$1" "$CONFIG_FILE" 2>/dev/null; }

cfg_array_disks_enabled() {
    jq -r '.array.disks[] | select(.enabled==true) | .device + " " + .mountpoint + " " + .fstype' "$CONFIG_FILE"
}

cfg_parity_mountpoints() {
    jq -r '.array.parity[] | .mountpoint + " " + .device + " " + .fstype' "$CONFIG_FILE"
}

cfg_pool_mountpoint() { cfg '.array.pool_mountpoint'; }
cfg_mergerfs_opts()   { cfg '.array.mergerfs_options'; }

# ── Snapraid config generator ────────────────────────────────────────────────────

generate_snapraid_conf() {
    local conf=""
    local parity_index=0

    while IFS=' ' read -r mnt dev fstype; do
        if [ $parity_index -eq 0 ]; then
            conf+="parity $mnt/snapraid.parity"$'\n'
        else
            conf+="${parity_index}-parity $mnt/snapraid.parity"$'\n'
        fi
        parity_index=$((parity_index + 1))
    done < <(cfg_parity_mountpoints)

    conf+=$'\n'

    local disk_index=1
    while IFS=' ' read -r dev mnt fstype; do
        conf+="data d${disk_index} ${mnt}/"$'\n'
        disk_index=$((disk_index + 1))
    done < <(cfg_array_disks_enabled)

    conf+=$'\n'

    while IFS= read -r cfile; do
        conf+="content $cfile"$'\n'
    done < <(jq -r '.snapraid.content_files[]' "$CONFIG_FILE")

    conf+=$'\n'

    while IFS= read -r excl; do
        conf+="exclude $excl"$'\n'
    done < <(jq -r '.snapraid.exclude[]' "$CONFIG_FILE")

    echo "$conf"
}

# ── Array commands ───────────────────────────────────────────────────────────────

cmd_status_json() {
    local pool
    pool=$(cfg_pool_mountpoint)

    local array_state="stopped"
    mountpoint -q "$pool" 2>/dev/null && array_state="started"

    # Pool stats
    local pool_size="" pool_used="" pool_free="" pool_pct=""
    if [ "$array_state" = "started" ]; then
        read -r pool_size pool_used pool_free pool_pct < <(df -h "$pool" 2>/dev/null | awk 'NR==2{print $2,$3,$4,$5}' || echo "? ? ? ?")
    fi

    # Last sync
    local last_sync
    last_sync=$(journalctl -u freeraid-sync --no-pager -n 1 --output=short 2>/dev/null | grep -oP '\d{4}-\d{2}-\d{2}' | head -1 || echo "never")

    # Parity drives JSON
    local parity_json="["
    local first=true
    while IFS=' ' read -r slot dev mnt fstype label; do
        local present=false size="" synced=false
        [ -b "$dev" ] && present=true
        $present && size=$(lsblk -dn -o SIZE "$dev" 2>/dev/null || echo "?")
        mountpoint -q "$mnt" 2>/dev/null && synced=true
        $first || parity_json+=","
        first=false
        parity_json+="{\"slot\":\"$slot\",\"device\":\"$dev\",\"mountpoint\":\"$mnt\",\"size\":\"$size\",\"present\":$present,\"mounted\":$synced,\"label\":\"$label\"}"
    done < <(jq -r '.array.parity[] | .slot + " " + .device + " " + .mountpoint + " " + .fstype + " " + .label' "$CONFIG_FILE")
    parity_json+="]"

    # Data drives JSON
    local disks_json="["
    first=true
    while IFS=' ' read -r slot dev mnt enabled label; do
        local present=false size="" mounted=false used="" free="" pct=""
        [ -b "$dev" ] && present=true
        $present && size=$(lsblk -dn -o SIZE "$dev" 2>/dev/null || echo "?")
        mountpoint -q "$mnt" 2>/dev/null && mounted=true
        if $mounted; then
            read -r used free pct < <(df -h "$mnt" 2>/dev/null | awk 'NR==2{print $3,$4,$5}' || echo "? ? ?")
        fi
        $first || disks_json+=","
        first=false
        disks_json+="{\"slot\":\"$slot\",\"device\":\"$dev\",\"mountpoint\":\"$mnt\",\"enabled\":$enabled,\"present\":$present,\"mounted\":$mounted,\"size\":\"$size\",\"used\":\"$used\",\"free\":\"$free\",\"pct\":\"$pct\",\"label\":\"$label\"}"
    done < <(jq -r '.array.disks[] | .slot + " " + .device + " " + .mountpoint + " " + (.enabled|tostring) + " " + .label' "$CONFIG_FILE")
    disks_json+="]"

    # Cache drives JSON
    local cache_json="["
    first=true
    while IFS=' ' read -r slot dev mnt enabled label; do
        local present=false size="" mounted=false used="" free="" pct=""
        [ -b "$dev" ] && present=true
        $present && size=$(lsblk -dn -o SIZE "$dev" 2>/dev/null || echo "?")
        mountpoint -q "$mnt" 2>/dev/null && mounted=true
        if $mounted; then
            read -r used free pct < <(df -h "$mnt" 2>/dev/null | awk 'NR==2{print $3,$4,$5}' || echo "? ? ?")
        fi
        $first || cache_json+=","
        first=false
        cache_json+="{\"slot\":\"$slot\",\"device\":\"$dev\",\"mountpoint\":\"$mnt\",\"enabled\":$enabled,\"present\":$present,\"mounted\":$mounted,\"size\":\"$size\",\"used\":\"$used\",\"free\":\"$free\",\"pct\":\"$pct\",\"label\":\"$label\"}"
    done < <(jq -r '.array.cache[] | .slot + " " + .device + " " + .mountpoint + " " + (.enabled|tostring) + " " + .label' "$CONFIG_FILE")
    cache_json+="]"

    # Total raw array capacity = sum of enabled data disk sizes in bytes
    local total_bytes=0
    while IFS=' ' read -r dev enabled; do
        if [ "$enabled" = "true" ] && [ -b "$dev" ]; then
            local b
            b=$(lsblk -dn -o SIZE --bytes "$dev" 2>/dev/null || echo 0)
            total_bytes=$((total_bytes + b))
        fi
    done < <(jq -r '.array.disks[] | .device + " " + (.enabled|tostring)' "$CONFIG_FILE")

    # Human-readable total (awk handles GB/TB nicely)
    local array_total
    array_total=$(awk -v b="$total_bytes" 'BEGIN{
        if(b>=1099511627776) printf "%.1fT", b/1099511627776
        else if(b>=1073741824) printf "%.1fG", b/1073741824
        else if(b>=1048576) printf "%.1fM", b/1048576
        else printf "%dB", b
    }')

    printf '{"version":"%s","array_state":"%s","pool":{"mountpoint":"%s","size":"%s","used":"%s","free":"%s","pct":"%s"},"array_total":"%s","parity":%s,"disks":%s,"cache":%s,"last_sync":"%s"}\n' \
        "$FREERAID_VERSION" "$array_state" "$pool" "$pool_size" "$pool_used" "$pool_free" "$pool_pct" \
        "$array_total" "$parity_json" "$disks_json" "$cache_json" "$last_sync"
}

cmd_status() {
    # Machine-readable mode for web UI
    if [ "${FREERAID_JSON:-}" = "1" ] || [ "${1:-}" = "--json" ]; then
        cmd_status_json
        return
    fi

    echo -e "${BOLD}FreeRAID v${FREERAID_VERSION} — Array Status${NC}"
    echo "────────────────────────────────────────────"

    local pool
    pool=$(cfg_pool_mountpoint)

    local array_running=false
    if mountpoint -q "$pool" 2>/dev/null; then
        array_running=true
        echo -e "Array:   ${GREEN}STARTED${NC}"
    else
        echo -e "Array:   ${YELLOW}STOPPED${NC}"
    fi

    echo ""
    echo -e "${BOLD}Parity Drives:${NC}"
    while IFS=' ' read -r slot dev label; do
        if [ -b "$dev" ]; then
            local size
            size=$(lsblk -dn -o SIZE "$dev" 2>/dev/null || echo "?")
            echo -e "  ${GREEN}●${NC} $slot  $dev  $size  $label"
        else
            echo -e "  ${RED}✗${NC} $slot  $dev  [not found]"
        fi
    done < <(jq -r '.array.parity[] | .slot + " " + .device + " " + .label' "$CONFIG_FILE")

    echo ""
    echo -e "${BOLD}Data Drives:${NC}"
    while IFS=' ' read -r slot dev mnt enabled label; do
        if [ "$enabled" = "true" ]; then
            if [ -b "$dev" ]; then
                local size used avail
                size=$(lsblk -dn -o SIZE "$dev" 2>/dev/null || echo "?")
                if mountpoint -q "$mnt" 2>/dev/null; then
                    read -r used avail _ < <(df -h "$mnt" 2>/dev/null | awk 'NR==2{print $3,$4,$5}' || echo "? ? ?")
                    echo -e "  ${GREEN}●${NC} $slot  $dev  $size  used:$used free:$avail  $label"
                else
                    echo -e "  ${YELLOW}○${NC} $slot  $dev  $size  [not mounted]  $label"
                fi
            else
                echo -e "  ${RED}✗${NC} $slot  $dev  [not found]  $label"
            fi
        else
            echo -e "  ${BLUE}–${NC} $slot  $dev  [disabled]  $label"
        fi
    done < <(jq -r '.array.disks[] | .slot + " " + .device + " " + .mountpoint + " " + (.enabled|tostring) + " " + .label' "$CONFIG_FILE")

    if $array_running; then
        echo ""
        echo -e "${BOLD}Pool (${pool}):${NC}"
        df -h "$pool" 2>/dev/null | awk 'NR==2{printf "  Size: %s  Used: %s  Free: %s  (%s used)\n",$2,$3,$4,$5}' || echo "  [error reading pool]"
    fi

    local last_sync
    last_sync=$(journalctl -u freeraid-sync --no-pager -n 1 --output=short 2>/dev/null | grep -oP '\d{4}-\d{2}-\d{2}' | head -1 || echo "never")
    echo ""
    echo -e "Last parity sync: ${last_sync}"
}

cmd_start() {
    info "Starting FreeRAID array..."

    require jq
    require mergerfs

    local pool
    pool=$(cfg_pool_mountpoint)

    # Format + mount parity drives
    while IFS=' ' read -r mnt dev fstype; do
        if [ ! -b "$dev" ]; then
            warn "Parity device $dev not found, skipping"
            continue
        fi
        mkdir -p "$mnt"
        if ! blkid "$dev" &>/dev/null; then
            info "Formatting parity $dev as $fstype..."
            case "$fstype" in
                xfs)  mkfs.xfs -f -L "parity" "$dev" ;;
                ext4) mkfs.ext4 -F -L "parity" "$dev" ;;
                *) mkfs.xfs -f "$dev" ;;
            esac
        fi
        if ! mountpoint -q "$mnt"; then
            info "Mounting parity $dev → $mnt"
            mount "$dev" "$mnt" || die "Failed to mount parity $dev"
        fi
    done < <(cfg_parity_mountpoints)

    # Format + mount each enabled data disk
    while IFS=' ' read -r dev mnt fstype; do
        if [ ! -b "$dev" ]; then
            warn "Device $dev not found, skipping"
            continue
        fi

        mkdir -p "$mnt"

        if ! blkid "$dev" &>/dev/null; then
            info "Formatting $dev as $fstype..."
            case "$fstype" in
                xfs)  mkfs.xfs -f -L "$(basename "$mnt")" "$dev" ;;
                ext4) mkfs.ext4 -F -L "$(basename "$mnt")" "$dev" ;;
                btrfs) mkfs.btrfs -f -L "$(basename "$mnt")" "$dev" ;;
                *) die "Unknown fstype: $fstype" ;;
            esac
        fi

        if ! mountpoint -q "$mnt"; then
            info "Mounting $dev → $mnt"
            mount "$dev" "$mnt" || die "Failed to mount $dev"
        else
            info "$mnt already mounted"
        fi
    done < <(cfg_array_disks_enabled)

    # Mount cache
    local cache_dev cache_mnt cache_fs
    cache_dev=$(jq -r '.array.cache[] | select(.enabled==true) | .device' "$CONFIG_FILE" | head -1)
    cache_mnt=$(jq -r '.array.cache[] | select(.enabled==true) | .mountpoint' "$CONFIG_FILE" | head -1)
    cache_fs=$(jq -r '.array.cache[] | select(.enabled==true) | .fstype' "$CONFIG_FILE" | head -1)

    if [ -n "$cache_dev" ] && [ -b "$cache_dev" ]; then
        mkdir -p "$cache_mnt"
        if ! blkid "$cache_dev" &>/dev/null; then
            info "Formatting cache $cache_dev as $cache_fs..."
            mkfs."$cache_fs" -F "$cache_dev" 2>/dev/null || mkfs."$cache_fs" "$cache_dev"
        fi
        if ! mountpoint -q "$cache_mnt"; then
            info "Mounting cache $cache_dev → $cache_mnt"
            mount "$cache_dev" "$cache_mnt"
        fi
    fi

    # Build mergerfs branches string
    local branches=""
    while IFS=' ' read -r dev mnt fstype; do
        [ -b "$dev" ] && branches+="${mnt}:"
    done < <(cfg_array_disks_enabled)

    # Prepend cache as highest priority
    if [ -n "$cache_mnt" ] && mountpoint -q "$cache_mnt" 2>/dev/null; then
        branches="${cache_mnt}:${branches}"
    fi

    branches="${branches%:}"  # strip trailing colon

    if [ -z "$branches" ]; then
        die "No drives available to pool"
    fi

    mkdir -p "$pool"

    if ! mountpoint -q "$pool"; then
        info "Mounting mergerfs pool: $branches → $pool"
        mergerfs "$branches" "$pool" -o "$(cfg_mergerfs_opts)" || die "mergerfs failed"
    else
        info "Pool already mounted at $pool"
    fi

    # Generate snapraid config
    info "Generating snapraid config..."
    generate_snapraid_conf > "$SNAPRAID_CONF"

    # Update array state in config
    jq '.array.state = "started"' "$CONFIG_FILE" > /tmp/freeraid.conf.tmp \
        && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    info "Array started. Pool at ${pool}"
    cmd_status
}

cmd_stop() {
    info "Stopping FreeRAID array..."

    local pool
    pool=$(cfg_pool_mountpoint)

    # Unmount pool first
    if mountpoint -q "$pool" 2>/dev/null; then
        info "Unmounting pool $pool"
        umount "$pool" || umount -l "$pool"
    fi

    # Unmount data disks in reverse order
    while IFS=' ' read -r dev mnt fstype; do
        if mountpoint -q "$mnt" 2>/dev/null; then
            info "Unmounting $mnt"
            umount "$mnt" || umount -l "$mnt"
        fi
    done < <(cfg_array_disks_enabled | tac)

    # Unmount cache
    local cache_mnt
    cache_mnt=$(jq -r '.array.cache[] | select(.enabled==true) | .mountpoint' "$CONFIG_FILE" | head -1)
    if [ -n "$cache_mnt" ] && mountpoint -q "$cache_mnt" 2>/dev/null; then
        info "Unmounting cache $cache_mnt"
        umount "$cache_mnt" || umount -l "$cache_mnt"
    fi

    # Unmount parity drives
    while IFS=' ' read -r mnt dev fstype; do
        if mountpoint -q "$mnt" 2>/dev/null; then
            info "Unmounting parity $mnt"
            umount "$mnt" || umount -l "$mnt"
        fi
    done < <(cfg_parity_mountpoints)

    jq '.array.state = "stopped"' "$CONFIG_FILE" > /tmp/freeraid.conf.tmp \
        && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    info "Array stopped."
}

cmd_sync() {
    info "Running SnapRAID sync (parity update)..."
    require snapraid

    [ -f "$SNAPRAID_CONF" ] || { generate_snapraid_conf > "$SNAPRAID_CONF"; info "Generated $SNAPRAID_CONF"; }

    snapraid -c "$SNAPRAID_CONF" sync && info "Sync complete." || die "Sync failed — check snapraid output above"
}

cmd_scrub() {
    local percent
    percent=$(cfg '.snapraid.scrub_percent')
    percent="${percent:-22}"
    info "Running SnapRAID scrub (${percent}% of parity)..."
    require snapraid
    snapraid -c "$SNAPRAID_CONF" scrub -p "$percent" && info "Scrub complete." || die "Scrub failed"
}

cmd_diff() {
    info "SnapRAID diff (what changed since last sync)..."
    require snapraid
    snapraid -c "$SNAPRAID_CONF" diff
}

cmd_disks_scan() {
    # Build a flat lookup of all assigned devices from config
    local all_assigned
    all_assigned=$(jq -r '
        [
          (.array.parity[] | {device:.device, slot:.slot, role:"parity"}),
          (.array.disks[]  | {device:.device, slot:.slot, role:"array"}),
          (.array.cache[]  | {device:.device, slot:.slot, role:"cache"})
        ]
    ' "$CONFIG_FILE" 2>/dev/null || echo "[]")

    local disks_json="["
    local first=true

    while read -r name size rota type; do
        [ "$type" != "disk" ] && continue
        local dev="/dev/${name}"

        # Get model separately to handle blank/spaces safely
        local model
        model=$(lsblk -dn -o MODEL "$dev" 2>/dev/null | tr -d '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        [ -z "$model" ] && model="Virtual Disk"

        local drive_type="HDD"
        [ "$rota" = "0" ] && drive_type="SSD"

        # Filesystem on the raw device (if any)
        local has_fs
        has_fs=$(lsblk -no FSTYPE "$dev" 2>/dev/null | grep -v '^$' | head -1 || echo "")

        # Lookup assignment
        local assigned_slot assigned_role
        assigned_slot=$(echo "$all_assigned" | jq -r --arg d "$dev" '.[] | select(.device==$d) | .slot' 2>/dev/null | head -1 || echo "")
        assigned_role=$(echo "$all_assigned"  | jq -r --arg d "$dev" '.[] | select(.device==$d) | .role' 2>/dev/null | head -1 || echo "")

        $first || disks_json+=","
        first=false
        disks_json+=$(printf '{"device":"%s","name":"%s","size":"%s","type":"%s","model":"%s","assigned":%s,"slot":"%s","role":"%s","has_fs":"%s"}' \
            "$dev" "$name" "$size" "$drive_type" "$model" \
            "$([ -n "$assigned_slot" ] && echo true || echo false)" \
            "$assigned_slot" "$assigned_role" "$has_fs")

    done < <(lsblk -dn -o NAME,SIZE,ROTA,TYPE 2>/dev/null)

    disks_json+="]"
    echo "$disks_json"
}

cmd_disks_assign() {
    local dev="$1" role="$2" slot="$3" fstype="${4:-xfs}"
    [ -z "$dev" ] || [ -z "$role" ] && die "Usage: freeraid disks-assign <device> <role:array|parity|cache> [slot] [fstype]"
    [ -b "$dev" ] || die "Device $dev not found"

    # Check array is stopped
    local pool
    pool=$(cfg_pool_mountpoint)
    mountpoint -q "$pool" 2>/dev/null && die "Stop the array before reassigning disks: freeraid stop"

    case "$role" in
        array)
            # Auto-assign next available slot if not specified
            if [ -z "$slot" ]; then
                local n=1
                while jq -e --arg s "disk${n}" '.array.disks[] | select(.slot==$s)' "$CONFIG_FILE" &>/dev/null; do
                    n=$((n+1))
                done
                slot="disk${n}"
            fi
            local mnt="/mnt/${slot}"
            # Remove from other roles first
            cmd_disks_unassign_dev "$dev" 2>/dev/null || true
            jq --arg slot "$slot" --arg dev "$dev" --arg mnt "$mnt" --arg fs "$fstype" \
               '.array.disks += [{"slot":$slot,"device":$dev,"mountpoint":$mnt,"fstype":$fs,"label":$slot,"enabled":true}]' \
               "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
            info "Assigned $dev as array $slot"
            ;;
        parity)
            if [ -z "$slot" ]; then
                local p=0
                while jq -e --arg s "$([ $p -eq 0 ] && echo 'parity' || echo "parity${p}")" '.array.parity[] | select(.slot==$s)' "$CONFIG_FILE" &>/dev/null; do
                    p=$((p+1))
                done
                slot=$([ $p -eq 0 ] && echo "parity" || echo "parity${p}")
            fi
            local pmnt="/mnt/${slot}"
            cmd_disks_unassign_dev "$dev" 2>/dev/null || true
            jq --arg slot "$slot" --arg dev "$dev" --arg mnt "$pmnt" \
               '.array.parity += [{"slot":$slot,"device":$dev,"mountpoint":$mnt,"fstype":"xfs","label":$slot}]' \
               "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
            info "Assigned $dev as $slot"
            ;;
        cache)
            slot="${slot:-cache}"
            local cmnt="/mnt/${slot}"
            cmd_disks_unassign_dev "$dev" 2>/dev/null || true
            jq --arg slot "$slot" --arg dev "$dev" --arg mnt "$cmnt" \
               '.array.cache += [{"slot":$slot,"device":$dev,"mountpoint":$mnt,"fstype":"ext4","label":$slot,"enabled":true}]' \
               "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
            info "Assigned $dev as cache $slot"
            ;;
        *)
            die "Role must be: array, parity, or cache"
            ;;
    esac
}

cmd_disks_unassign_dev() {
    # Internal helper — remove a device from all roles
    local dev="$1"
    jq --arg d "$dev" '
        .array.disks   |= map(select(.device != $d)) |
        .array.parity  |= map(select(.device != $d)) |
        .array.cache   |= map(select(.device != $d))
    ' "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
}

cmd_disks_unassign() {
    local dev="$1"
    [ -z "$dev" ] && die "Usage: freeraid disks-unassign <device>"
    local pool
    pool=$(cfg_pool_mountpoint)
    mountpoint -q "$pool" 2>/dev/null && die "Stop the array before unassigning disks"
    cmd_disks_unassign_dev "$dev"
    info "Unassigned $dev"
}

cmd_add_disk() {
    local slot="$1" dev="$2" fstype="${3:-xfs}"
    [ -z "$slot" ] || [ -z "$dev" ] && die "Usage: freeraid add-disk <slot> <device> [fstype]"
    [ -b "$dev" ] || die "Device $dev does not exist"

    info "Adding $dev as $slot ($fstype)"

    local mnt="/mnt/${slot}"
    local existing
    existing=$(jq -r --arg s "$slot" '.array.disks[] | select(.slot==$s) | .slot' "$CONFIG_FILE" 2>/dev/null || true)
    [ -n "$existing" ] && die "Slot $slot already exists in config"

    jq --arg slot "$slot" --arg dev "$dev" --arg mnt "$mnt" --arg fs "$fstype" \
       '.array.disks += [{"slot":$slot,"device":$dev,"mountpoint":$mnt,"fstype":$fs,"label":$slot,"enabled":true}]' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    info "Added $slot. Run 'freeraid start' to mount the array with the new disk."
}

cmd_remove_disk() {
    local slot="$1"
    [ -z "$slot" ] && die "Usage: freeraid remove-disk <slot>"
    info "Disabling slot $slot (data remains on disk)"
    jq --arg s "$slot" '(.array.disks[] | select(.slot==$s)).enabled = false' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    info "Slot $slot disabled. Run 'freeraid stop && freeraid start' to apply."
}

cmd_shares_list() {
    jq -c '.shares // []' "$CONFIG_FILE"
}

cmd_shares_apply() {
    # Write smb.conf and reload samba based on current shares config
    require samba

    local smb_conf="/etc/samba/smb.conf"
    local pool
    pool=$(cfg_pool_mountpoint)

    info "Writing Samba config..."

    cat > "$smb_conf" <<SMBEOF
[global]
   workgroup = WORKGROUP
   server string = FreeRAID
   netbios name = $(hostname)
   security = user
   map to guest = bad user
   dns proxy = no
   fruit:metadata = stream
   fruit:model = MacSamba
   vfs objects = catia fruit streams_xattr

SMBEOF

    while IFS= read -r share; do
        local name smb_enabled smb_security comment cache_mode read_list write_list
        name=$(echo "$share" | jq -r '.name')
        smb_enabled=$(echo "$share" | jq -r '.smb_enabled')
        smb_security=$(echo "$share" | jq -r '.smb_security // "public"')
        comment=$(echo "$share" | jq -r '.comment // ""')
        read_list=$(echo "$share" | jq -r '.smb_read_list // [] | join(",")')
        write_list=$(echo "$share" | jq -r '.smb_write_list // [] | join(",")')
        local path="${pool}/${name}"

        [ "$smb_enabled" = "false" ] && continue

        mkdir -p "$path"

        cat >> "$smb_conf" <<SHAREEOF
[${name}]
   path = ${path}
   comment = ${comment}
SHAREEOF

        if [ "$smb_security" = "public" ]; then
            cat >> "$smb_conf" <<SHAREEOF
   guest ok = yes
   browseable = yes
   writable = yes
SHAREEOF
        else
            cat >> "$smb_conf" <<SHAREEOF
   guest ok = no
   browseable = yes
   writable = yes
SHAREEOF
            [ -n "$read_list"  ] && echo "   read list = ${read_list}" >> "$smb_conf"
            [ -n "$write_list" ] && echo "   write list = ${write_list}" >> "$smb_conf"
        fi
        echo "" >> "$smb_conf"

    done < <(jq -c '.shares[]' "$CONFIG_FILE" 2>/dev/null)

    systemctl restart smbd nmbd 2>/dev/null || systemctl restart samba 2>/dev/null || true
    info "Samba reloaded. Shares active."
}

cmd_shares_add() {
    local name="$1"
    [ -z "$name" ] && die "Usage: freeraid shares-add <name>"
    local existing
    existing=$(jq -r --arg n "$name" '.shares[] | select(.name==$n) | .name' "$CONFIG_FILE" 2>/dev/null || true)
    [ -n "$existing" ] && die "Share '$name' already exists"

    jq --arg name "$name" \
       '.shares += [{"name":$name,"path":("/mnt/user/"+$name),"comment":"","smb_enabled":true,"smb_security":"public","smb_read_list":[],"smb_write_list":[],"nfs_enabled":false,"cache_mode":"yes","cache_pool":"cache","include_disks":[],"exclude_disks":[]}]' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    info "Share '$name' added. Run 'freeraid shares-apply' to activate."
}

cmd_shares_remove() {
    local name="$1"
    [ -z "$name" ] && die "Usage: freeraid shares-remove <name>"
    jq --arg n "$name" 'del(.shares[] | select(.name==$n))' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    info "Share '$name' removed. Run 'freeraid shares-apply' to apply."
}

cmd_shares_import() {
    # Import shares from a Unraid config directory
    local src="${1:-}"
    [ -z "$src" ] && die "Usage: freeraid shares-import <path-to-unraid-config-dir>"
    [ -d "$src/shares" ] || die "No shares/ directory found in $src"

    require python3

    local tmpout
    tmpout=$(mktemp /tmp/freeraid-shares-XXXXXX.json)

    python3 - "$src" "$tmpout" <<'PYEOF'
import sys, json, re
from pathlib import Path

def parse_cfg(path):
    result = {}
    if not path.exists(): return result
    for line in path.read_text(errors='replace').splitlines():
        line = line.strip()
        if not line or line.startswith('#'): continue
        m = re.match(r'^(\w+)="?([^"]*)"?$', line)
        if m: result[m.group(1)] = m.group(2)
    return result

config_dir = Path(sys.argv[1])
out_file   = sys.argv[2]
shares = []

for f in sorted((config_dir / 'shares').glob('*.cfg')):
    s    = parse_cfg(f)
    name = f.stem
    shares.append({
        "name":           name,
        "path":           f'/mnt/user/{name}',
        "comment":        s.get('shareComment', ''),
        "smb_enabled":    s.get('shareExport', 'e') == 'e',
        "smb_security":   s.get('shareSecurity', 'public'),
        "smb_read_list":  [u for u in s.get('shareReadList','').split(',') if u],
        "smb_write_list": [u for u in s.get('shareWriteList','').split(',') if u],
        "nfs_enabled":    s.get('shareExportNFS', '-') != '-',
        "nfs_security":   s.get('shareSecurityNFS', 'public'),
        "cache_mode":     s.get('shareUseCache', 'yes'),
        "cache_pool":     s.get('shareCachePool', 'cache'),
        "allocator":      s.get('shareAllocator', 'highwater'),
        "split_level":    s.get('shareSplitLevel', ''),
        "include_disks":  [d for d in s.get('shareInclude','').split(',') if d],
        "exclude_disks":  [d for d in s.get('shareExclude','').split(',') if d],
        "cow":            s.get('shareCOW', 'auto'),
        "_imported_from_unraid": True
    })

json.dump(shares, open(out_file, 'w'), indent=2)
print(f"Parsed {len(shares)} shares")
PYEOF

    local count
    count=$(jq 'length' "$tmpout")
    info "Importing $count shares from $src..."

    # Merge into config — replace existing shares array
    jq --slurpfile newshares "$tmpout" '.shares = $newshares[0]' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    rm -f "$tmpout"
    info "Done. Run 'freeraid shares-apply' to activate via Samba."
}

cmd_docker_list() {
    if [ ! -d "$COMPOSE_DIR" ]; then
        echo "[]"
        return 0
    fi

    # Get running container names
    local running
    running=$(docker ps --format '{{.Names}}' 2>/dev/null || echo "")

    local result="["
    local first=true

    for f in "$COMPOSE_DIR"/*.docker-compose.yml; do
        [ -f "$f" ] || continue
        local basename="${f##*/}"
        local name="${basename%.docker-compose.yml}"

        local image container_name
        image=$(jq -r '(.services | to_entries[0].value.image) // "unknown"' "$f" 2>/dev/null || echo "unknown")
        container_name=$(jq -r '(.services | to_entries[0].value.container_name) // ""' "$f" 2>/dev/null || echo "")
        [ -z "$container_name" ] && container_name="$name"

        local state="stopped"
        if echo "$running" | grep -qxF "$container_name" 2>/dev/null; then
            state="running"
        fi

        $first || result+=","
        first=false
        result+=$(printf '{"name":"%s","container_name":"%s","image":"%s","state":"%s"}' \
            "$name" "$container_name" "$image" "$state")
    done

    result+="]"
    echo "$result"
}

cmd_docker_start() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid docker-start <name>"
    local f="${COMPOSE_DIR}/${name}.docker-compose.yml"
    [ -f "$f" ] || die "No compose file found for: $name"
    require docker
    info "Starting $name..."
    docker compose -f "$f" up -d
    info "$name started."
}

cmd_docker_stop() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid docker-stop <name>"
    local f="${COMPOSE_DIR}/${name}.docker-compose.yml"
    [ -f "$f" ] || die "No compose file found for: $name"
    require docker
    info "Stopping $name..."
    docker compose -f "$f" down
    info "$name stopped."
}

cmd_docker_logs() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid docker-logs <name>"
    local f="${COMPOSE_DIR}/${name}.docker-compose.yml"
    [ -f "$f" ] || die "No compose file found for: $name"
    require docker
    docker compose -f "$f" logs --tail=100 --no-color 2>&1 || true
}

cmd_install_deps() {
    info "Installing FreeRAID dependencies..."
    apt-get update -qq
    apt-get install -y \
        mergerfs \
        snapraid \
        jq \
        xfsprogs \
        btrfs-progs \
        samba \
        nfs-kernel-server \
        docker.io \
        docker-compose-plugin \
        cockpit \
        2>&1 | grep -E '(Setting up|already|Error)' || true
    info "All dependencies installed."
}

cmd_version() {
    echo "FreeRAID v${FREERAID_VERSION}"
}

cmd_update() {
    require curl
    require jq

    info "Checking for updates (current: v${FREERAID_VERSION})..."

    # Fetch latest release info from GitHub
    local release_json
    release_json=$(curl -fsSL "$GITHUB_API" 2>/dev/null) \
        || die "Could not reach GitHub. Check your internet connection."

    local latest_tag latest_ver tarball_url
    latest_tag=$(echo "$release_json" | jq -r '.tag_name')
    latest_ver="${latest_tag#v}"  # strip leading 'v'
    tarball_url=$(echo "$release_json" | jq -r '.assets[] | select(.name | test("freeraid-components")) | .browser_download_url')

    if [ -z "$latest_tag" ] || [ "$latest_tag" = "null" ]; then
        die "No releases found at ${GITHUB_API}"
    fi

    info "Latest release: ${latest_tag}"

    # Compare versions (simple string compare works for semver x.y.z)
    if [ "$latest_ver" = "$FREERAID_VERSION" ]; then
        info "Already up to date (v${FREERAID_VERSION})"
        return 0
    fi

    if [ -z "$tarball_url" ] || [ "$tarball_url" = "null" ]; then
        die "No component tarball found in release ${latest_tag}. Expected asset named 'freeraid-components-*.tar.gz'"
    fi

    info "Downloading components tarball for ${latest_tag}..."
    local tmpdir
    tmpdir=$(mktemp -d /tmp/freeraid-update-XXXXXX)
    trap "rm -rf $tmpdir" EXIT

    curl -fsSL "$tarball_url" -o "$tmpdir/components.tar.gz" \
        || die "Download failed"

    info "Applying update..."
    tar -xzf "$tmpdir/components.tar.gz" -C "$tmpdir"

    # Install CLI
    if [ -f "$tmpdir/freeraid" ]; then
        cp "$tmpdir/freeraid" /usr/local/bin/freeraid
        chmod +x /usr/local/bin/freeraid
        info "CLI updated"
    fi

    # Install web UI
    if [ -d "$tmpdir/web/freeraid" ]; then
        cp -r "$tmpdir/web/freeraid/." /usr/share/cockpit/freeraid/
        info "Web UI updated"
        systemctl restart cockpit.socket 2>/dev/null || true
    fi

    # Install importer
    if [ -f "$tmpdir/unraid-import" ]; then
        cp "$tmpdir/unraid-import" /usr/local/bin/freeraid-import
        chmod +x /usr/local/bin/freeraid-import
        info "Importer updated"
    fi

    # Stage new compose files (skip existing — user data)
    if [ -d "$tmpdir/compose" ]; then
        mkdir -p "$COMPOSE_DIR"
        for f in "$tmpdir/compose/"*.docker-compose.yml; do
            [ -f "$f" ] || continue
            dest="$COMPOSE_DIR/$(basename "$f")"
            [ -f "$dest" ] || cp "$f" "$dest"
        done
        info "Compose files updated"
    fi

    # Update version file
    mkdir -p "$(dirname "$VERSION_FILE")"
    echo "$latest_ver" > "$VERSION_FILE"

    info "FreeRAID updated to v${latest_ver}"
}

cmd_check_update() {
    require curl
    require jq

    local release_json latest_tag latest_ver
    release_json=$(curl -fsSL "$GITHUB_API" 2>/dev/null) || {
        warn "Could not reach GitHub"
        return 1
    }
    latest_tag=$(echo "$release_json" | jq -r '.tag_name')
    latest_ver="${latest_tag#v}"

    if [ "$latest_ver" = "$FREERAID_VERSION" ]; then
        echo '{"update_available":false,"current":"'"$FREERAID_VERSION"'","latest":"'"$latest_ver"'"}'
    else
        local release_notes
        release_notes=$(echo "$release_json" | jq -r '.body // ""' | head -5)
        echo '{"update_available":true,"current":"'"$FREERAID_VERSION"'","latest":"'"$latest_ver"'","notes":'"$(echo "$release_notes" | jq -Rs .)"'}'
    fi
}

cmd_help() {
    cat <<EOF

${BOLD}FreeRAID v${FREERAID_VERSION}${NC} — Open source Unraid alternative

${BOLD}ARRAY COMMANDS${NC}
  status              Show array, disk, and pool status
  start               Mount all drives and start the pool
  stop                Unmount pool and all drives safely
  add-disk <slot> <dev> [fs]   Add a drive to the array
  remove-disk <slot>           Disable a drive slot

${BOLD}PARITY COMMANDS${NC}
  sync                Update parity (run after adding files)
  scrub               Verify parity data integrity
  diff                Show what changed since last sync

${BOLD}SHARES${NC}
  shares-list              List all shares (JSON)
  shares-add <name>        Add a new share
  shares-remove <name>     Remove a share
  shares-apply             Write smb.conf and reload Samba
  shares-import <dir>      Import shares from Unraid config directory

${BOLD}DOCKER${NC}
  docker-list              List all containers and their state (JSON)
  docker-start <name>      Start a container via docker compose
  docker-stop <name>       Stop a container via docker compose
  docker-logs <name>       Show last 100 lines of container logs

${BOLD}UPDATES${NC}
  version             Show installed version
  check-update        Check if an update is available (JSON output)
  update              Download and apply latest release from GitHub

${BOLD}SYSTEM${NC}
  install-deps        Install all required packages (Debian/Ubuntu)
  config              Print current config path and contents

${BOLD}CONFIG${NC}
  Default config: /boot/config/freeraid.conf.json
  Override:       FREERAID_CONFIG=/path/to/config freeraid <cmd>

EOF
}

cmd_config() {
    echo "Config: $CONFIG_FILE"
    echo "────────────────────────────────────────────"
    cat "$CONFIG_FILE"
}

# ── Dispatch ─────────────────────────────────────────────────────────────────────

case "${1:-help}" in
    status)       cmd_status "${2:-}" ;;
    start)        cmd_start ;;
    stop)         cmd_stop ;;
    sync)         cmd_sync ;;
    scrub)        cmd_scrub ;;
    diff)         cmd_diff ;;
    add-disk)     cmd_add_disk "${2:-}" "${3:-}" "${4:-}" ;;
    remove-disk)  cmd_remove_disk "${2:-}" ;;
    disks-scan)    cmd_disks_scan ;;
    disks-assign)  cmd_disks_assign "${2:-}" "${3:-}" "${4:-}" "${5:-}" ;;
    disks-unassign) cmd_disks_unassign "${2:-}" ;;
    shares-list)   cmd_shares_list ;;
    shares-apply)  cmd_shares_apply ;;
    shares-add)    cmd_shares_add "${2:-}" ;;
    shares-remove) cmd_shares_remove "${2:-}" ;;
    shares-import) cmd_shares_import "${2:-}" ;;
    docker-list)   cmd_docker_list ;;
    docker-start)  cmd_docker_start "${2:-}" ;;
    docker-stop)   cmd_docker_stop "${2:-}" ;;
    docker-logs)   cmd_docker_logs "${2:-}" ;;
    install-deps)  cmd_install_deps ;;
    config)        cmd_config ;;
    version)       cmd_version ;;
    update)        cmd_update ;;
    check-update)  cmd_check_update ;;
    help|--help|-h) cmd_help ;;
    *) error "Unknown command: ${1}"; cmd_help; exit 1 ;;
esac
