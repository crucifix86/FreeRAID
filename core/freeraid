cmd_mover_run() {
    local cache_root="/mnt/cache"
    local pool_root
    pool_root=$(cfg '.array.pool_mountpoint // "/mnt/user"')
    local log_file="/var/log/freeraid-mover.log"

    mountpoint -q "$cache_root" || die "Cache not mounted at $cache_root"
    mountpoint -q "$pool_root"  || die "Pool not mounted at $pool_root"

    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Mover started" >> "$log_file"

    local moved=0
    while IFS= read -r share_name; do
        local src="$cache_root/$share_name"
        [ -d "$src" ] && [ "$(ls -A "$src" 2>/dev/null)" ] || continue
        local dst="$pool_root/$share_name"
        mkdir -p "$dst"
        rsync -a --remove-source-files "$src/" "$dst/" && \
            find "$src" -type d -empty -delete 2>/dev/null || true
        moved=$((moved + 1))
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] Moved: $share_name" >> "$log_file"
    done < <(jq -r '.shares[].name' "$CONFIG_FILE" 2>/dev/null)

    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Mover complete. Processed $moved share(s)." >> "$log_file"
    echo "{\"ok\":true,\"shares_processed\":$moved}"
}

cmd_mover_status() {
    local log_file="/var/log/freeraid-mover.log"
    local last_run="never"
    if [ -f "$log_file" ]; then
        last_run=$(grep "Mover complete" "$log_file" | tail -1 | sed 's/\[//;s/\] Mover.*//' || echo "never")
        [ -z "$last_run" ] && last_run="never"
    fi
    local enabled time
    enabled=$(jq -r '.mover_schedule.enabled // false' "$CONFIG_FILE" 2>/dev/null || echo "false")
    time=$(jq -r '.mover_schedule.time // "02:00"' "$CONFIG_FILE" 2>/dev/null || echo "02:00")
    echo "{\"last_run\":\"$last_run\",\"enabled\":${enabled},\"time\":\"${time}\"}"
}

cmd_mover_set_schedule() {
    local enabled="${1:-true}" time="${2:-02:00}"
    local service="/etc/systemd/system/freeraid-mover.service"
    local timer="/etc/systemd/system/freeraid-mover.timer"

    cat > "$service" <<EOF
[Unit]
Description=FreeRAID Cache Mover

[Service]
Type=oneshot
ExecStart=/usr/local/bin/freeraid mover-run
EOF

    cat > "$timer" <<EOF
[Unit]
Description=FreeRAID Cache Mover

[Timer]
OnCalendar=*-*-* ${time}:00
Persistent=true

[Install]
WantedBy=timers.target
EOF

    systemctl daemon-reload
    if [ "$enabled" = "true" ]; then
        systemctl enable --now freeraid-mover.timer 2>/dev/null || true
    else
        systemctl disable --now freeraid-mover.timer 2>/dev/null || true
    fi

    jq --argjson e "$([ "$enabled" = "true" ] && echo true || echo false)" --arg t "$time" \
       '.mover_schedule = {"enabled":$e,"time":$t}' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    echo "{\"ok\":true}"
}

cmd_parity_get_schedule() {
    local freq day time
    freq=$(jq -r '.parity_schedule.freq // "weekly"' "$CONFIG_FILE" 2>/dev/null || echo "weekly")
    day=$(jq -r  '.parity_schedule.day  // "Sun"'    "$CONFIG_FILE" 2>/dev/null || echo "Sun")
    time=$(jq -r '.parity_schedule.time // "04:00"'  "$CONFIG_FILE" 2>/dev/null || echo "04:00")
    echo "{\"freq\":\"$freq\",\"day\":\"$day\",\"time\":\"$time\"}"
}

cmd_parity_set_schedule() {
    local freq="${1:-weekly}" day="${2:-Sun}" time="${3:-04:00}"
    local on_cal
    case "$freq" in
        daily)   on_cal="*-*-* ${time}:00" ;;
        weekly)  on_cal="${day} *-*-* ${time}:00" ;;
        monthly) on_cal="*-*-01 ${time}:00" ;;
        *)       die "Unknown frequency: $freq (use daily/weekly/monthly)" ;;
    esac

    local timer="/etc/systemd/system/freeraid-scrub.timer"
    [ -f "$timer" ] || die "Scrub timer not found at $timer"
    sed -i "s|^OnCalendar=.*|OnCalendar=${on_cal}|" "$timer"
    systemctl daemon-reload
    systemctl restart freeraid-scrub.timer 2>/dev/null || true

    jq --arg f "$freq" --arg d "$day" --arg t "$time" \
       '.parity_schedule = {"freq":$f,"day":$d,"time":$t}' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    echo "{\"ok\":true,\"oncalendar\":\"${on_cal}\"}"
}

cmd_sysinfo() {
    # CPU: read raw ticks from /proc/stat
    local cpu_line
    cpu_line=$(grep '^cpu ' /proc/stat)
    local cpu_user cpu_nice cpu_system cpu_idle cpu_iowait cpu_irq cpu_softirq cpu_steal
    read -r _ cpu_user cpu_nice cpu_system cpu_idle cpu_iowait cpu_irq cpu_softirq cpu_steal _ <<< "$cpu_line"
    local cpu_idle_total=$(( cpu_idle + cpu_iowait ))
    local cpu_total=$(( cpu_user + cpu_nice + cpu_system + cpu_idle + cpu_iowait + cpu_irq + cpu_softirq + cpu_steal ))

    # Memory: from /proc/meminfo (kB)
    local mem_total mem_available
    mem_total=$(awk '/^MemTotal:/{print $2}' /proc/meminfo)
    mem_available=$(awk '/^MemAvailable:/{print $2}' /proc/meminfo)

    # Network: sum RX/TX bytes across all non-loopback interfaces
    local net_rx=0 net_tx=0
    while IFS=': ' read -r iface rx_bytes rest; do
        [[ "$iface" =~ ^lo ]] && continue
        [[ -z "$iface" || -z "$rx_bytes" ]] && continue
        net_rx=$(( net_rx + rx_bytes ))
        local tx_bytes
        tx_bytes=$(echo "$rest" | awk '{print $8}')
        [[ "$tx_bytes" =~ ^[0-9]+$ ]] && net_tx=$(( net_tx + tx_bytes ))
    done < <(awk 'NR>2{gsub(/^ +/,"",$0); print}' /proc/net/dev)

    # System info
    local hostname uptime_sec cpu_model cpu_cores kernel
    hostname=$(cat /proc/sys/kernel/hostname 2>/dev/null || echo "unknown")
    uptime_sec=$(awk '{print int($1)}' /proc/uptime 2>/dev/null || echo 0)
    cpu_model=$(grep -m1 '^model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | sed 's/^ *//' || echo "unknown")
    cpu_cores=$(grep -c '^processor' /proc/cpuinfo 2>/dev/null || echo 1)
    kernel=$(uname -r 2>/dev/null || echo "unknown")

    # Escape cpu_model for JSON
    cpu_model="${cpu_model//\\/\\\\}"
    cpu_model="${cpu_model//\"/\\\"}"

    printf '{"cpu_idle":%d,"cpu_total":%d,"mem_total":%d,"mem_available":%d,"net_rx":%d,"net_tx":%d,"hostname":"%s","uptime":%d,"cpu_model":"%s","cpu_cores":%d,"kernel":"%s"}\n' \
        "$cpu_idle_total" "$cpu_total" "$mem_total" "$mem_available" "$net_rx" "$net_tx" \
        "$hostname" "$uptime_sec" "$cpu_model" "$cpu_cores" "$kernel"
}

# ── UPS / NUT ────────────────────────────────────────────────────────────────────

cmd_ups_status() {
    require upsc 2>/dev/null || { echo '{"available":false,"error":"NUT not installed"}'; return 0; }

    local ups_name
    ups_name=$(jq -r '.ups.name // "ups@localhost"' "$CONFIG_FILE" 2>/dev/null || echo "ups@localhost")

    local raw
    raw=$(upsc "$ups_name" 2>&1) || { echo '{"available":false,"error":"Cannot connect to UPS: '"$(echo "$raw" | head -1 | tr '"' "'")"'"}'; return 0; }

    _upsc_val() { echo "$raw" | grep "^${1}:" | head -1 | awk '{print $2}'; }

    local status batt_pct load_pct runtime_mins input_v output_v
    status=$(      _upsc_val "ups.status")
    batt_pct=$(    _upsc_val "battery.charge")
    load_pct=$(    _upsc_val "ups.load")
    runtime_mins=$(echo "$raw" | grep "^battery.runtime:" | head -1 | awk '{print int($2/60)}')
    input_v=$(     _upsc_val "input.voltage")
    output_v=$(    _upsc_val "output.voltage")
    model=$(       echo "$raw" | grep "^device.model:" | head -1 | sed 's/^device.model: //')

    local on_battery=false
    echo "$status" | grep -qi "OB" && on_battery=true

    printf '{"available":true,"ups":"%s","status":"%s","on_battery":%s,"battery_pct":%s,"load_pct":%s,"runtime_mins":%s,"input_v":"%s","output_v":"%s","model":"%s"}\n' \
        "$ups_name" \
        "${status:-unknown}" \
        "$on_battery" \
        "${batt_pct:-0}" \
        "${load_pct:-0}" \
        "${runtime_mins:-0}" \
        "${input_v:-?}" \
        "${output_v:-?}" \
        "${model:-Unknown UPS}"
}

cmd_ups_config_get() {
    jq -r '.ups // {"enabled":false,"name":"ups","host":"localhost","driver":"usbhid-ups","port":"auto","shutdown_pct":20,"mode":"standalone"}' "$CONFIG_FILE" 2>/dev/null
}

cmd_ups_config_set() {
    local json="${1:-}"
    [ -z "$json" ] && die "Usage: freeraid ups-config-set <json>"

    # Merge into config
    jq --argjson u "$json" '.ups = ($u + (.ups // {})) | .ups = $u' "$CONFIG_FILE" \
        > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    local enabled driver port ups_name host shutdown_pct mode
    enabled=$(    jq -r '.ups.enabled      // false'       "$CONFIG_FILE")
    mode=$(       jq -r '.ups.mode         // "standalone"' "$CONFIG_FILE")
    driver=$(     jq -r '.ups.driver       // "usbhid-ups"' "$CONFIG_FILE")
    port=$(       jq -r '.ups.port         // "auto"'       "$CONFIG_FILE")
    ups_name=$(   jq -r '.ups.name         // "ups"'        "$CONFIG_FILE")
    host=$(       jq -r '.ups.host         // "localhost"'   "$CONFIG_FILE")
    shutdown_pct=$(jq -r '.ups.shutdown_pct // 20'          "$CONFIG_FILE")

    if [ "$enabled" != "true" ]; then
        systemctl stop nut-server nut-monitor 2>/dev/null || true
        info "UPS monitoring disabled."
        return 0
    fi

    require nut-server 2>/dev/null || {
        warn "NUT not installed. Run: apt-get install nut"
        return 1
    }

    # Write /etc/nut/ups.conf
    if [ "$mode" = "standalone" ]; then
        cat > /etc/nut/ups.conf << UPSCONF
[${ups_name}]
    driver = ${driver}
    port   = ${port}
    desc   = "FreeRAID UPS"
UPSCONF
        echo "MODE=standalone" > /etc/nut/nut.conf
    else
        # netclient — remote UPS server
        echo "MODE=netclient" > /etc/nut/nut.conf
    fi

    # Write /etc/nut/upsmon.conf
    cat > /etc/nut/upsmon.conf << MONCONF
MONITOR ${ups_name}@${host} 1 admin password master
MINSUPPLIES 1
SHUTDOWNCMD "/usr/local/bin/freeraid stop && /sbin/shutdown -h +0"
NOTIFYCMD /usr/local/bin/freeraid-ups-notify
POWERDOWNFLAG /etc/killpower
POLLFREQ 5
POLLFREQALERT 5
DEADTIME 15
RBWARNTIME 43200
NOCOMMWARNTIME 300
FINALDELAY 5
NOTIFYMSG ONLINE    "UPS back on mains power"
NOTIFYMSG ONBATT    "UPS on battery — power outage detected"
NOTIFYMSG LOWBATT   "UPS battery low — shutting down soon"
NOTIFYMSG SHUTDOWN  "System shutting down due to UPS"
NOTIFYFLAG ONLINE   SYSLOG+EXEC
NOTIFYFLAG ONBATT   SYSLOG+EXEC
NOTIFYFLAG LOWBATT  SYSLOG+EXEC
MONCONF

    # Write /etc/nut/upsd.conf (for standalone mode)
    cat > /etc/nut/upsd.conf << UPSDCONF
LISTEN 127.0.0.1 3493
UPSDCONF

    # Write /etc/nut/upsd.users
    cat > /etc/nut/upsd.users << USERSCONF
[admin]
    password = password
    actions = SET
    instcmds = ALL
    upsmon master
USERSCONF

    # Write notify script
    cat > /usr/local/bin/freeraid-ups-notify << 'NOTIFYSCRIPT'
#!/bin/bash
/usr/local/bin/freeraid notify-send "ups_event" "${NOTIFYTYPE}: ${UPSNAME}" 2>/dev/null || true
NOTIFYSCRIPT
    chmod +x /usr/local/bin/freeraid-ups-notify

    chmod 640 /etc/nut/upsd.users /etc/nut/upsmon.conf 2>/dev/null || true
    chown root:nut /etc/nut/upsd.users /etc/nut/upsmon.conf /etc/nut/ups.conf 2>/dev/null || true

    systemctl restart nut-server  2>/dev/null || true
    systemctl restart nut-monitor 2>/dev/null || true
    systemctl enable  nut-server nut-monitor 2>/dev/null || true

    info "UPS monitoring configured and started."
    echo '{"ok":true}'
}

# ── Tailscale ────────────────────────────────────────────────────────────────────

cmd_tailscale_status() {
    if ! command -v tailscale &>/dev/null; then
        echo '{"installed":false}'
        return 0
    fi

    local raw
    raw=$(tailscale status --json 2>/dev/null) || {
        echo '{"installed":true,"running":false,"error":"tailscale daemon not running"}'
        return 0
    }

    local state ip hostname
    state=$(    echo "$raw" | jq -r '.BackendState // "unknown"')
    ip=$(       echo "$raw" | jq -r '.TailscaleIPs[0] // ""')
    hostname=$( echo "$raw" | jq -r '.Self.HostName // ""')
    local online=false
    echo "$raw" | jq -e '.Self.Online == true' &>/dev/null && online=true

    printf '{"installed":true,"running":true,"state":"%s","ip":"%s","hostname":"%s","online":%s}\n' \
        "$state" "$ip" "$hostname" "$online"
}

cmd_tailscale_install() {
    info "Installing Tailscale..."
    curl -fsSL https://tailscale.com/install.sh | sh 2>&1 || die "Tailscale install failed"
    systemctl enable --now tailscaled 2>/dev/null || true
    info "Tailscale installed."
}

cmd_tailscale_up() {
    require tailscale
    info "Bringing Tailscale up..."
    # Run tailscale up and capture the auth URL if not yet authenticated
    local out
    out=$(tailscale up --accept-routes 2>&1) || true
    echo "$out"
    # If there's an auth URL, extract and return it as JSON
    local url
    url=$(echo "$out" | grep -oP 'https://login\.tailscale\.com/\S+' | head -1 || true)
    if [ -n "$url" ]; then
        printf '{"needs_auth":true,"auth_url":"%s"}\n' "$url"
    else
        printf '{"needs_auth":false}\n'
    fi
}

cmd_tailscale_down() {
    require tailscale
    tailscale down 2>&1 && info "Tailscale disconnected." || warn "tailscale down failed"
}

# ── Notifications ────────────────────────────────────────────────────────────────

cmd_notify_get() {
    jq -r '.notifications // {
        "email":   {"enabled":false,"smtp_host":"","smtp_port":587,"smtp_from":"","smtp_user":"","smtp_pass":"","smtp_to":""},
        "webhook": {"enabled":false,"url":"","format":"discord"},
        "events":  {"array_degraded":true,"drive_temp":true,"sync_error":true,"scrub_error":true,"update_available":true,"container_updated":false},
        "temp_threshold": 55
    }' "$CONFIG_FILE"
}

cmd_notify_set() {
    local json="${1:-}"
    [ -z "$json" ] && die "Usage: freeraid notify-set <json>"
    jq --argjson n "$json" '.notifications = $n' "$CONFIG_FILE" > /tmp/freeraid.conf.tmp \
        && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    info "Notification settings saved."
}

_notify_email() {
    local subject="$1" body="$2"
    command -v msmtp &>/dev/null || { warn "msmtp not installed — run: apt-get install msmtp"; return 1; }

    local smtp_host smtp_port smtp_user smtp_pass smtp_tls to_addr
    smtp_host=$(jq -r '.notifications.email.smtp_host // ""' "$CONFIG_FILE")
    smtp_port=$(jq -r '.notifications.email.smtp_port // 587' "$CONFIG_FILE")
    local smtp_from to_addr
    smtp_from=$(jq -r '.notifications.email.smtp_from // ""' "$CONFIG_FILE")
    smtp_user=$(jq -r '.notifications.email.smtp_user // ""' "$CONFIG_FILE")
    smtp_pass=$(jq -r '.notifications.email.smtp_pass // ""' "$CONFIG_FILE")
    to_addr=$(jq -r '.notifications.email.smtp_to // ""' "$CONFIG_FILE")
    [ -z "$smtp_from" ] && smtp_from="freeraid@${smtp_host}"

    [ -z "$smtp_host" ] || [ -z "$to_addr" ] && { warn "Email not configured"; return 1; }

    printf "To: %s\nFrom: %s\nSubject: %s\n\n%s\n" \
        "$to_addr" "$smtp_from" "$subject" "$body" | \
        msmtp --host="$smtp_host" --port="$smtp_port" \
              --auth=on --user="$smtp_user" --passwordeval="echo '${smtp_pass}'" \
              --tls=on --tls-starttls=on \
              "$to_addr" 2>&1
}

_notify_webhook() {
    local event="$1" message="$2" hostname="$3"
    command -v curl &>/dev/null || return 1

    local url format
    url=$(jq -r '.notifications.webhook.url // ""' "$CONFIG_FILE")
    format=$(jq -r '.notifications.webhook.format // "discord"' "$CONFIG_FILE")
    [ -z "$url" ] && { warn "Webhook URL not configured"; return 1; }

    local payload
    case "$format" in
        discord)
            payload=$(jq -n \
                --arg title "FreeRAID Alert: $event" \
                --arg desc "$message" \
                --arg host "$hostname" \
                '{"embeds":[{"title":$title,"description":$desc,"color":15158332,"footer":{"text":("Host: "+$host)}}]}')
            ;;
        slack)
            payload=$(jq -n \
                --arg text "*FreeRAID* ($hostname): *$event* — $message" \
                '{"text":$text}')
            ;;
        *)
            payload=$(jq -n \
                --arg event "$event" --arg message "$message" --arg hostname "$hostname" \
                '{"event":$event,"message":$message,"hostname":$hostname}')
            ;;
    esac

    curl -fsSL -X POST -H "Content-Type: application/json" -d "$payload" "$url" 2>&1
}

cmd_notify_send() {
    local event="${1:-}" message="${2:-unknown}"
    [ -z "$event" ] && die "Usage: freeraid notify-send <event> <message>"

    # Check if event is enabled in config
    local enabled
    enabled=$(jq -r --arg k "$event" '.notifications.events[$k] // true' "$CONFIG_FILE" 2>/dev/null || echo "true")
    [ "$enabled" = "false" ] && return 0

    local hostname; hostname=$(cat /proc/sys/kernel/hostname 2>/dev/null || echo "FreeRAID")
    local subject="[FreeRAID] ${event//_/ }: $message"

    local email_on webhook_on
    email_on=$(jq -r '.notifications.email.enabled // false' "$CONFIG_FILE" 2>/dev/null || echo "false")
    webhook_on=$(jq -r '.notifications.webhook.enabled // false' "$CONFIG_FILE" 2>/dev/null || echo "false")

    [ "$email_on"   = "true" ] && _notify_email   "$subject" "Host: $hostname\nEvent: $event\n\n$message" 2>/dev/null || true
    [ "$webhook_on" = "true" ] && _notify_webhook "$event" "$message" "$hostname" 2>/dev/null || true

    log "NOTIFY: $event — $message"
}

cmd_notify_test() {
    local method="${1:-all}"
    local hostname; hostname=$(cat /proc/sys/kernel/hostname 2>/dev/null || echo "FreeRAID")
    local msg="Test notification from FreeRAID on $hostname. If you see this, notifications are working."

    case "$method" in
        email)
            if _notify_email "[FreeRAID] Test" "$msg" 2>&1; then
                echo '{"ok":true,"message":"Test email sent successfully"}'
            else
                echo '{"ok":false,"message":"Email failed — check SMTP settings"}'
            fi
            ;;
        webhook)
            if _notify_webhook "test" "$msg" "$hostname" 2>&1; then
                echo '{"ok":true,"message":"Test webhook sent successfully"}'
            else
                echo '{"ok":false,"message":"Webhook failed — check URL and format"}'
            fi
            ;;
        *)
            _notify_email   "[FreeRAID] Test" "$msg" 2>/dev/null || true
            _notify_webhook "test" "$msg" "$hostname" 2>/dev/null || true
            echo '{"ok":true,"message":"Test notifications sent"}'
            ;;
    esac
}

cmd_temp_check() {
    # Check all drive temps and notify if above threshold (default 55°C)
    local threshold="${1:-55}"
    command -v smartctl &>/dev/null || return 0

    while IFS= read -r dev; do
        [ -b "$dev" ] || continue
        local temp
        temp=$(smartctl -j -A "$dev" 2>/dev/null | jq -r '
            .temperature.current //
            (.ata_smart_attributes.table[]? | select(.name=="Temperature_Celsius") | .raw.value) //
            empty' 2>/dev/null | head -1)
        [ -z "$temp" ] && continue
        if [ "$temp" -ge "$threshold" ] 2>/dev/null; then
            warn "Drive $dev temperature ${temp}°C exceeds ${threshold}°C threshold"
            cmd_notify_send "drive_temp" "Drive $dev is running hot: ${temp}°C (threshold: ${threshold}°C)" 2>/dev/null || true
        fi
    done < <(jq -r '
        (.array.disks[]  | select(.enabled==true) | .device),
        (.array.parity[] | .device),
        (.array.cache[]  | select(.enabled==true) | .device)
    ' "$CONFIG_FILE" 2>/dev/null | sort -u)
}

# ── Disk I/O stats ───────────────────────────────────────────────────────────────

cmd_iostat() {
    # Returns JSON array with read/write KB/s for each assigned drive
    # Samples /proc/diskstats twice (1 second apart) and returns delta
    local interval="${1:-1}"

    # Collect all assigned device basenames
    local devs
    devs=$(jq -r '
        (.array.disks[]  | select(.enabled==true) | .device),
        (.array.parity[] | .device),
        (.array.cache[]  | select(.enabled==true) | .device)
    ' "$CONFIG_FILE" 2>/dev/null | sed 's|/dev/||' | sort -u)

    [ -z "$devs" ] && { echo "[]"; return 0; }

    # Parse /proc/diskstats: field 3=name, 6=sectors_read, 10=sectors_written
    _read_diskstats() {
        local dev="$1"
        awk -v d="$dev" '$3==d{print $6, $10}' /proc/diskstats 2>/dev/null | head -1
    }

    # Sample 1
    declare -A snap1_r snap1_w
    while IFS= read -r dev; do
        read -r r w <<< "$(_read_diskstats "$dev")"
        snap1_r[$dev]="${r:-0}"
        snap1_w[$dev]="${w:-0}"
    done <<< "$devs"

    sleep "$interval"

    # Sample 2 + compute delta (sectors → KB, 1 sector = 512 bytes)
    local out="["
    local first=true
    while IFS= read -r dev; do
        read -r r w <<< "$(_read_diskstats "$dev")"
        local r2="${r:-0}" w2="${w:-0}"
        local dr=$(( (r2 - ${snap1_r[$dev]:-0}) / 2 ))   # sectors/s → KB/s
        local dw=$(( (w2 - ${snap1_w[$dev]:-0}) / 2 ))
        [ "$dr" -lt 0 ] && dr=0
        [ "$dw" -lt 0 ] && dw=0
        $first || out+=","
        out+="{\"device\":\"/dev/${dev}\",\"read_kbs\":${dr},\"write_kbs\":${dw}}"
        first=false
    done <<< "$devs"
    out+="]"
    echo "$out"
}

# ── Disk spin-down ───────────────────────────────────────────────────────────────

cmd_spindown_get() {
    # Returns JSON: [{device, value, role, spindle}]
    # Parity drives default to 241 (30 min) if not explicitly set — data/cache default to 0 (disabled)
    require hdparm
    local out="["
    local first=true

    # Build a set of parity devices for role detection
    local parity_devs
    parity_devs=$(jq -r '.array.parity[] | .device' "$CONFIG_FILE" 2>/dev/null || true)

    while IFS='|' read -r dev role; do
        [ -b "$dev" ] || continue
        local key; key=$(basename "$dev")

        # Check if there's an explicit saved value
        local has_saved
        has_saved=$(jq -r --arg d "$key" 'if .spindown[$d] != null then "yes" else "no" end' "$CONFIG_FILE" 2>/dev/null || echo "no")

        local saved_val
        if [ "$has_saved" = "yes" ]; then
            saved_val=$(jq -r --arg d "$key" '.spindown[$d]' "$CONFIG_FILE" 2>/dev/null || echo "0")
        elif [ "$role" = "parity" ]; then
            saved_val=241  # 30 min default for parity
        else
            saved_val=0
        fi

        local spindle="unknown"
        local hdparm_out; hdparm_out=$(hdparm -C "$dev" 2>&1 || true)
        local parsed; parsed=$(echo "$hdparm_out" | grep -oP '(?<=drive state is:  )[^\r\n]+' | head -1 | tr -d ' \r\n')
        [ -n "$parsed" ] && spindle="$parsed"

        $first || out+=","
        out+="{\"device\":\"$dev\",\"role\":\"$role\",\"value\":$saved_val,\"spindle\":\"$spindle\"}"
        first=false
    done < <(jq -r '
        (.array.disks[]  | select(.enabled==true) | .device + "|array"),
        (.array.parity[] | .device + "|parity"),
        (.array.cache[]  | select(.enabled==true) | .device + "|cache")
    ' "$CONFIG_FILE" 2>/dev/null | sort -u)
    out+="]"
    echo "$out"
}

cmd_spindown_set() {
    # Usage: freeraid spindown-set <device> <value>
    # value 0 = disabled, otherwise hdparm -S value
    local dev="${1:-}" val="${2:-0}"
    [ -z "$dev" ] && die "Usage: freeraid spindown-set <device> <value>"
    [ -b "$dev" ] || die "Device not found: $dev"

    local key; key=$(basename "$dev")

    # Save to config (.spindown is a map of basename → value)
    jq --arg k "$key" --argjson v "$val" \
       '.spindown[$k] = $v' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    # Apply immediately
    require hdparm
    hdparm -S "$val" "$dev" &>/dev/null
    if [ "$val" -eq 0 ]; then
        info "Spin-down disabled for $dev."
    else
        info "Spin-down set to value $val for $dev."
    fi
}

cmd_spindown_apply() {
    # Apply spindown settings on array start
    # Uses saved value if set; parity drives default to 241 (30min) if never explicitly set
    command -v hdparm &>/dev/null || return 0
    local any=false

    while IFS='|' read -r dev role; do
        [ -b "$dev" ] || continue
        local key; key=$(basename "$dev")
        local has_saved
        has_saved=$(jq -r --arg d "$key" 'if .spindown[$d] != null then "yes" else "no" end' "$CONFIG_FILE" 2>/dev/null || echo "no")
        local val
        if [ "$has_saved" = "yes" ]; then
            val=$(jq -r --arg d "$key" '.spindown[$d]' "$CONFIG_FILE" 2>/dev/null || echo "0")
        elif [ "$role" = "parity" ]; then
            val=241
        else
            val=0
        fi
        [ "$val" -eq 0 ] && continue
        hdparm -S "$val" "$dev" &>/dev/null && any=true
    done < <(jq -r '
        (.array.disks[]  | select(.enabled==true) | .device + "|array"),
        (.array.parity[] | .device + "|parity"),
        (.array.cache[]  | select(.enabled==true) | .device + "|cache")
    ' "$CONFIG_FILE" 2>/dev/null)

    $any && info "Spin-down settings applied."
    return 0
}

# ── Log viewer ───────────────────────────────────────────────────────────────────

cmd_logs_get() {
    local src="${1:-freeraid}" lines="${2:-500}"
    case "$src" in
        freeraid) tail -n "$lines" /var/log/freeraid.log 2>/dev/null || echo "(no freeraid log yet)" ;;
        syslog)   tail -n "$lines" /var/log/syslog 2>/dev/null \
                      || journalctl -n "$lines" --no-pager 2>/dev/null \
                      || echo "(syslog not available)" ;;
        kernel)   dmesg -T 2>/dev/null | tail -n "$lines" || dmesg | tail -n "$lines" ;;
        samba)    tail -n "$lines" /var/log/samba/log.smbd 2>/dev/null \
                      || echo "(no samba log yet)" ;;
        *)        die "Unknown log source: $src" ;;
    esac
}

# ── Plugin system ────────────────────────────────────────────────────────────────

PLUGIN_DIR="/etc/freeraid/plugins"
PLUGIN_INDEX_URL="https://raw.githubusercontent.com/crucifix86/FreeRAID/main/plugins/index.json"

cmd_plugin_list() {
    local out="["
    local first=true
    mkdir -p "$PLUGIN_DIR"
    for manifest in "$PLUGIN_DIR"/*/manifest.json; do
        [ -f "$manifest" ] || continue
        $first || out+=","
        first=false
        out+=$(cat "$manifest")
    done
    out+="]"
    echo "$out"
}

cmd_plugin_available() {
    info "Fetching plugin index..."
    curl -fsSL "$PLUGIN_INDEX_URL" 2>/dev/null || die "Could not fetch plugin index. Check internet connection."
}

cmd_plugin_install() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid plugin-install <name>"

    # Check not already installed
    [ -f "$PLUGIN_DIR/$name/manifest.json" ] && die "Plugin '$name' is already installed. Use plugin-update to upgrade."

    info "Fetching plugin index..."
    local index
    index=$(curl -fsSL "$PLUGIN_INDEX_URL" 2>/dev/null) || die "Could not fetch plugin index."

    local plugin_entry
    plugin_entry=$(echo "$index" | jq -c --arg n "$name" '.[] | select(.name==$n)' 2>/dev/null || true)
    [ -z "$plugin_entry" ] && die "Plugin '$name' not found in index."

    local install_url
    install_url=$(echo "$plugin_entry" | jq -r '.install_url')
    [ -z "$install_url" ] || [ "$install_url" = "null" ] && die "Plugin '$name' has no install URL."

    info "Installing plugin: $name"
    local plugin_tmp="/tmp/freeraid-plugin-$name"
    rm -rf "$plugin_tmp"
    mkdir -p "$plugin_tmp"

    # Download and run install script
    curl -fsSL "$install_url" -o "$plugin_tmp/install.sh" || die "Failed to download install script."
    chmod +x "$plugin_tmp/install.sh"

    mkdir -p "$PLUGIN_DIR/$name"
    PLUGIN_INSTALL_DIR="$PLUGIN_DIR/$name" bash "$plugin_tmp/install.sh" || die "Plugin install script failed."

    # Write manifest from index entry
    echo "$plugin_entry" | jq '. + {"installed_at":"'"$(date -u +%Y-%m-%dT%H:%M:%SZ)"'","status":"installed"}' \
        > "$PLUGIN_DIR/$name/manifest.json"

    rm -rf "$plugin_tmp"
    info "Plugin '$name' installed successfully."
}

cmd_plugin_remove() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid plugin-remove <name>"
    [ -f "$PLUGIN_DIR/$name/manifest.json" ] || die "Plugin '$name' is not installed."

    info "Removing plugin: $name"

    # Run uninstall script if present
    if [ -f "$PLUGIN_DIR/$name/uninstall.sh" ]; then
        bash "$PLUGIN_DIR/$name/uninstall.sh" || warn "Uninstall script returned errors."
    fi

    rm -rf "$PLUGIN_DIR/$name"
    info "Plugin '$name' removed."
}

cmd_plugin_update() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid plugin-update <name>"
    [ -f "$PLUGIN_DIR/$name/manifest.json" ] || die "Plugin '$name' is not installed."

    info "Updating plugin: $name"
    # Run uninstall first (keep config if uninstall script is careful)
    if [ -f "$PLUGIN_DIR/$name/uninstall.sh" ]; then
        bash "$PLUGIN_DIR/$name/uninstall.sh" 2>/dev/null || true
    fi
    rm -rf "$PLUGIN_DIR/$name"
    cmd_plugin_install "$name"
}

# ── Setup wizard ─────────────────────────────────────────────────────────────────

cmd_setup_status() {
    local complete has_disks disk_count
    complete=$(jq -r '.setup_complete // false' "$CONFIG_FILE" 2>/dev/null || echo "false")
    disk_count=$(jq -r '.array.disks | length' "$CONFIG_FILE" 2>/dev/null || echo "0")
    has_disks="false"
    [ "${disk_count:-0}" -gt 0 ] && has_disks="true"
    echo "{\"setup_complete\": $complete, \"has_disks\": $has_disks}"
}

cmd_setup_complete() {
    jq '.setup_complete = true' "$CONFIG_FILE" > /tmp/freeraid.conf.tmp \
        && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
    info "Setup marked as complete."
}

