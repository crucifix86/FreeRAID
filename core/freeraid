# ── Network management ────────────────────────────────────────────────────────

cmd_network_info() {
    python3 << 'PYEOF'
import json, subprocess, re, os

try:
    ifaces_raw = json.loads(subprocess.check_output(['ip','-j','addr','show'], stderr=subprocess.DEVNULL))
except Exception as e:
    print(json.dumps({'error': str(e)})); exit(1)

try:
    ifaces_conf = open('/etc/network/interfaces').read()
except:
    ifaces_conf = ''

# Also try /etc/network/interfaces.d/
for f in os.listdir('/etc/network/interfaces.d') if os.path.isdir('/etc/network/interfaces.d') else []:
    try: ifaces_conf += '\n' + open(f'/etc/network/interfaces.d/{f}').read()
    except: pass

skip_prefixes = ('lo','docker','veth','br-','virbr','vmtap','tun','tap')

result = []
for iface in ifaces_raw:
    name = iface.get('ifname','')
    if any(name.startswith(p) for p in skip_prefixes): continue
    addrs = [a for a in iface.get('addr_info',[]) if a.get('family') == 'inet']
    ip     = addrs[0]['local']     if addrs else ''
    prefix = addrs[0]['prefixlen'] if addrs else 24

    mode = 'static' if re.search(rf'iface\s+{re.escape(name)}\s+inet\s+static', ifaces_conf) else 'dhcp'
    gateway = dns = ''
    if mode == 'static':
        m = re.search(rf'iface\s+{re.escape(name)}\s+inet\s+static(.*?)(?=\niface\s|\Z)', ifaces_conf, re.DOTALL)
        if m:
            block = m.group(1)
            gm = re.search(r'gateway\s+(\S+)', block)
            dm = re.search(r'dns-nameservers\s+(.+)', block)
            if gm: gateway = gm.group(1)
            if dm: dns    = dm.group(1).strip()
    if not gateway:
        try:
            rt = subprocess.check_output(['ip','-j','route','show','default'], stderr=subprocess.DEVNULL)
            routes = json.loads(rt)
            for r in routes:
                if r.get('dev') == name: gateway = r.get('gateway',''); break
            if not gateway and routes: gateway = routes[0].get('gateway','')
        except: pass

    result.append({'name':name,'ip':ip,'prefix':prefix,'mode':mode,
                   'gateway':gateway,'dns':dns,
                   'state':iface.get('operstate','UNKNOWN'),
                   'mac':iface.get('address','')})

print(json.dumps(result))
PYEOF
}

cmd_network_set() {
    # Usage: freeraid network-set <iface> dhcp
    #        freeraid network-set <iface> static <ip/prefix> <gateway> <dns>
    local iface="${1:-}" mode="${2:-}"
    [ -z "$iface" ] || [ -z "$mode" ] && die "Usage: freeraid network-set <iface> <dhcp|static> [ip/prefix gateway dns]"

    local conf_file="/etc/network/interfaces"

    if [ "$mode" = "dhcp" ]; then
        python3 - "$conf_file" "$iface" << 'PYEOF'
import sys, re
path, iface = sys.argv[1], sys.argv[2]
txt = open(path).read()
# Remove existing iface block
txt = re.sub(rf'\n?(allow-hotplug|auto)\s+{re.escape(iface)}\n', '\n', txt)
txt = re.sub(rf'\niface\s+{re.escape(iface)}\s+inet\s+\w+.*?(?=\niface\s|\n\s*\n|\Z)', '', txt, flags=re.DOTALL)
txt = txt.rstrip() + f'\n\nauto {iface}\niface {iface} inet dhcp\n'
open(path,'w').write(txt)
print('ok')
PYEOF
    else
        local cidr="${3:-}" gateway="${4:-}" dns="${5:-8.8.8.8}"
        [ -z "$cidr" ] || [ -z "$gateway" ] && die "static requires: ip/prefix gateway [dns]"
        # split cidr into ip and prefix
        local ip="${cidr%%/*}" prefix="${cidr##*/}"
        [ "$prefix" = "$ip" ] && prefix=24
        # Convert prefix to netmask
        local netmask
        netmask=$(python3 -c "import ipaddress; print(str(ipaddress.IPv4Network(f'0.0.0.0/${prefix}',False).netmask))" 2>/dev/null || echo "255.255.255.0")

        python3 - "$conf_file" "$iface" "$ip" "$netmask" "$gateway" "$dns" << 'PYEOF'
import sys, re
path, iface, ip, netmask, gateway, dns = sys.argv[1:]
txt = open(path).read()
txt = re.sub(rf'\n?(allow-hotplug|auto)\s+{re.escape(iface)}\n', '\n', txt)
txt = re.sub(rf'\niface\s+{re.escape(iface)}\s+inet\s+\w+.*?(?=\niface\s|\n\s*\n|\Z)', '', txt, flags=re.DOTALL)
block = (f'\nauto {iface}\n'
         f'iface {iface} inet static\n'
         f'    address {ip}\n'
         f'    netmask {netmask}\n'
         f'    gateway {gateway}\n'
         f'    dns-nameservers {dns}\n')
txt = txt.rstrip() + block
open(path,'w').write(txt)
print('ok')
PYEOF
    fi

    # Re-apply without taking down SSH if it's the current connection iface
    # Use ifup --force in background so we don't kill the calling process
    nohup bash -c "sleep 1; ifdown '$iface' 2>/dev/null; ifup '$iface' 2>/dev/null" &>/dev/null &
    echo "{\"ok\":true,\"iface\":\"$iface\",\"mode\":\"$mode\"}"
}

# ── User management ───────────────────────────────────────────────────────────

cmd_users_list() {
    python3 << 'PYEOF'
import json, subprocess, pwd

# System users with UID >= 1000 (excluding nobody)
users = []
for entry in pwd.getpwall():
    if entry.pw_uid < 1000: continue
    if entry.pw_name in ('nobody',): continue
    # Check if they're a Samba user
    try:
        out = subprocess.check_output(['pdbedit','-L','-u',entry.pw_name], stderr=subprocess.DEVNULL).decode()
        samba = bool(out.strip())
    except:
        samba = False
    users.append({'name': entry.pw_name, 'uid': entry.pw_uid,
                  'home': entry.pw_dir, 'samba': samba})

print(json.dumps(users))
PYEOF
}

cmd_users_add() {
    local username="${1:-}" password="${2:-}"
    [ -z "$username" ] || [ -z "$password" ] && die "Usage: freeraid users-add <username> <password>"
    # Validate username
    [[ "$username" =~ ^[a-z_][a-z0-9_-]*$ ]] || die "Invalid username (lowercase letters, numbers, _ - only)"

    # Create system user if doesn't exist
    if ! id "$username" &>/dev/null; then
        useradd -m -s /bin/bash -G users "$username" || die "Failed to create user: $username"
    fi

    # Set system password
    echo "$username:$password" | chpasswd || die "Failed to set password"

    # Add/update Samba password
    printf '%s\n%s\n' "$password" "$password" | smbpasswd -a -s "$username" 2>/dev/null || true
    smbpasswd -e "$username" 2>/dev/null || true

    echo "{\"ok\":true,\"name\":\"$username\"}"
}

cmd_users_delete() {
    local username="${1:-}"
    [ -z "$username" ] && die "Usage: freeraid users-delete <username>"
    [ "$username" = "root" ] || [ "$username" = "freeraid" ] && die "Cannot delete system user: $username"

    smbpasswd -x "$username" 2>/dev/null || true
    userdel -r "$username" 2>/dev/null || userdel "$username" 2>/dev/null || die "Failed to delete: $username"
    echo "{\"ok\":true}"
}

cmd_users_setpassword() {
    local username="${1:-}" password="${2:-}"
    [ -z "$username" ] || [ -z "$password" ] && die "Usage: freeraid users-setpassword <username> <password>"
    echo "$username:$password" | chpasswd || die "Failed to set password"
    printf '%s\n%s\n' "$password" "$password" | smbpasswd -a -s "$username" 2>/dev/null || true
    echo "{\"ok\":true}"
}

cmd_users_enable_samba() {
    local username="${1:-}" password="${2:-}"
    [ -z "$username" ] || [ -z "$password" ] && die "Usage: freeraid users-enable-samba <username> <password>"
    id "$username" &>/dev/null || die "User does not exist: $username"
    printf '%s\n%s\n' "$password" "$password" | smbpasswd -a -s "$username" || die "Failed to add Samba user"
    smbpasswd -e "$username" 2>/dev/null || true
    echo "{\"ok\":true}"
}

cmd_users_disable_samba() {
    local username="${1:-}"
    [ -z "$username" ] && die "Usage: freeraid users-disable-samba <username>"
    smbpasswd -x "$username" 2>/dev/null || true
    echo "{\"ok\":true}"
}

