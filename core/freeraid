cmd_update() {
    require curl
    require jq

    info "Checking for updates (current: v${FREERAID_VERSION})..."

    # Fetch latest release info from GitHub
    local release_json
    release_json=$(curl -fsSL "$GITHUB_API" 2>/dev/null) \
        || die "Could not reach GitHub. Check your internet connection."

    local latest_tag latest_ver tarball_url
    latest_tag=$(echo "$release_json" | jq -r '.tag_name')
    latest_ver="${latest_tag#v}"  # strip leading 'v'
    tarball_url=$(echo "$release_json" | jq -r '.assets[] | select(.name | test("freeraid-components")) | .browser_download_url')

    if [ -z "$latest_tag" ] || [ "$latest_tag" = "null" ]; then
        die "No releases found at ${GITHUB_API}"
    fi

    info "Latest release: ${latest_tag}"

    # Compare versions (simple string compare works for semver x.y.z)
    if [ "$latest_ver" = "$FREERAID_VERSION" ]; then
        info "Already up to date (v${FREERAID_VERSION})"
        return 0
    fi

    if [ -z "$tarball_url" ] || [ "$tarball_url" = "null" ]; then
        die "No component tarball found in release ${latest_tag}. Expected asset named 'freeraid-components-*.tar.gz'"
    fi

    info "Downloading components tarball for ${latest_tag}..."
    local tmpdir
    tmpdir=$(mktemp -d /tmp/freeraid-update-XXXXXX)
    trap "rm -rf $tmpdir" EXIT

    curl -fsSL "$tarball_url" -o "$tmpdir/components.tar.gz" \
        || die "Download failed"

    info "Applying update..."
    tar -xzf "$tmpdir/components.tar.gz" -C "$tmpdir"

    # Install CLI
    if [ -f "$tmpdir/freeraid" ]; then
        cp "$tmpdir/freeraid" /usr/local/bin/freeraid
        chmod +x /usr/local/bin/freeraid
        info "CLI updated"
    fi

    # Install web UI
    if [ -d "$tmpdir/web/freeraid" ]; then
        cp -r "$tmpdir/web/freeraid/." /usr/share/cockpit/freeraid/
        info "Web UI updated"
    fi

    # Install importer
    if [ -f "$tmpdir/unraid-import" ]; then
        cp "$tmpdir/unraid-import" /usr/local/bin/freeraid-import
        chmod +x /usr/local/bin/freeraid-import
        info "Importer updated"
    fi

    # Stage new compose files (skip existing — user data)
    if [ -d "$tmpdir/compose" ]; then
        mkdir -p "$COMPOSE_DIR"
        for f in "$tmpdir/compose/"*.docker-compose.yml; do
            [ -f "$f" ] || continue
            dest="$COMPOSE_DIR/$(basename "$f")"
            [ -f "$dest" ] || cp "$f" "$dest"
        done
        info "Compose files updated"
    fi

    # Update version file
    mkdir -p "$(dirname "$VERSION_FILE")"
    echo "$latest_ver" > "$VERSION_FILE"

    info "FreeRAID updated to v${latest_ver}"
}

cmd_check_update() {
    require curl
    require jq

    local release_json latest_tag latest_ver
    release_json=$(curl -fsSL "$GITHUB_API" 2>/dev/null) || {
        warn "Could not reach GitHub"
        return 1
    }
    latest_tag=$(echo "$release_json" | jq -r '.tag_name')
    latest_ver="${latest_tag#v}"

    if [ "$latest_ver" = "$FREERAID_VERSION" ]; then
        echo '{"update_available":false,"current":"'"$FREERAID_VERSION"'","latest":"'"$latest_ver"'"}'
    else
        local release_notes
        release_notes=$(echo "$release_json" | jq -r '.body // ""' | head -5)
        cmd_notify_send "update_available" "FreeRAID update available: v${latest_ver} (current: v${FREERAID_VERSION})" 2>/dev/null || true
        echo '{"update_available":true,"current":"'"$FREERAID_VERSION"'","latest":"'"$latest_ver"'","notes":'"$(echo "$release_notes" | jq -Rs .)"'}'
    fi
}

