cmd_apps_search() {
    local query="${1:-}" limit="${2:-50}"
    [ -f "$APPFEED_CACHE" ] || die "App feed not cached. Run: freeraid apps-fetch"
    python3 - "$APPFEED_CACHE" "$query" "$limit" <<'PYEOF'
import sys, json, re

apps  = json.load(open(sys.argv[1]))
query = sys.argv[2].lower().strip()
limit = int(sys.argv[3])

if query:
    terms = query.split()
    def score(a):
        s = a.get('search', '')
        n = a.get('name', '').lower()
        return sum(2 if t in n else (1 if t in s else 0) for t in terms)
    results = [a for a in apps if score(a) > 0]
    results.sort(key=lambda a: -score(a))
else:
    results = apps

out = []
for a in results[:limit]:
    out.append({
        'name':       a['name'],
        'image':      a['image'],
        'overview':   a['overview'][:120] + ('…' if len(a.get('overview','')) > 120 else ''),
        'icon':       a['icon'],
        'categories': a['categories'][:3],
        'downloads':  a.get('downloads', 0),
        'stars':      a.get('stars', 0),
    })

print(json.dumps(out))
PYEOF
}

cmd_apps_get() {
