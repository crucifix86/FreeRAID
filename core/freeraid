cmd_replace_disk() {
    local slot="${1:-}" new_dev="${2:-}"
    [ -z "$slot" ] || [ -z "$new_dev" ] && die "Usage: freeraid replace-disk <slot> <device>"
    [ -b "$new_dev" ] || die "Device $new_dev not found"

    # Confirm slot exists in config
    local mnt fstype
    mnt=$(jq -r --arg s "$slot" '.array.disks[] | select(.slot==$s) | .mountpoint' "$CONFIG_FILE")
    fstype=$(jq -r --arg s "$slot" '.array.disks[] | select(.slot==$s) | .fstype' "$CONFIG_FILE")
    [ -z "$mnt" ] || [ "$mnt" = "null" ] && die "Slot $slot not found in config"

    # Get snapraid ID for this slot
    local snapraid_id
    snapraid_id=$(get_snapraid_id_for_slot "$slot")
    [ -z "$snapraid_id" ] && die "Could not determine snapraid ID for $slot"

    info "Replacing $slot with $new_dev (snapraid $snapraid_id)..."

    # Format new drive
    mkdir -p "$mnt"
    info "Formatting $new_dev as $fstype..."
    case "$fstype" in
        xfs)  mkfs.xfs -f -L "$slot" "$new_dev" ;;
        ext4) mkfs.ext4 -F -L "$slot" "$new_dev" ;;
        btrfs) mkfs.btrfs -f -L "$slot" "$new_dev" ;;
        *) die "Unknown fstype: $fstype" ;;
    esac

    # Get new UUID and serial
    local new_uuid new_serial
    new_uuid=$(get_disk_uuid "$new_dev")
    new_serial=$(get_disk_serial "$new_dev")

    # Mount new drive at slot mountpoint
    if mountpoint -q "$mnt" 2>/dev/null; then
        info "Unmounting existing $mnt"
        umount "$mnt" || umount -l "$mnt"
    fi
    info "Mounting $new_dev → $mnt"
    mount "$new_dev" "$mnt" || die "Failed to mount $new_dev"

    # Update config
    jq --arg s "$slot" --arg dev "$new_dev" --arg uuid "$new_uuid" --arg serial "$new_serial" \
       '(.array.disks[] | select(.slot==$s)) |= . + {"device":$dev,"uuid":$uuid,"serial":$serial}' \
       "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"

    # Regenerate snapraid config
    generate_snapraid_conf > "$SNAPRAID_CONF"

    # Recover data from parity
    info "Recovering data for $slot ($snapraid_id) from parity — this may take a long time..."
    snapraid -c "$SNAPRAID_CONF" fix -e -d "$snapraid_id" \
        && info "Data recovery complete for $slot" \
        || { warn "Fix reported errors — some files may not be recoverable. Check snapraid output."; }

    # Update parity to reflect restored drive
    info "Updating parity..."
    snapraid -c "$SNAPRAID_CONF" sync \
        && info "Parity updated. Drive $slot fully restored." \
        || warn "Sync failed — run 'freeraid sync' manually to update parity"
}

cmd_replace_disk_bg() {
    local slot="${1:-}" new_dev="${2:-}"
    [ -z "$slot" ] || [ -z "$new_dev" ] && die "Usage: freeraid replace-disk-bg <slot> <device>"
    local run_dir="/var/run/freeraid"
    mkdir -p "$run_dir"
    local pid_file="$run_dir/replace-${slot}.pid"
    local log_file="/var/log/freeraid-replace-${slot}.log"
    local status_file="$run_dir/replace-${slot}.status"

    # Check if already running
    if [ -f "$pid_file" ]; then
        local old_pid; old_pid=$(cat "$pid_file")
        if kill -0 "$old_pid" 2>/dev/null; then
            die "Replace job already running for $slot (pid $old_pid)"
        fi
    fi

    echo "running" > "$status_file"
    nohup bash -c "
        /usr/local/bin/freeraid replace-disk '$slot' '$new_dev' >> '$log_file' 2>&1
        echo \$? > '$status_file'
    " > /dev/null 2>&1 &
    echo $! > "$pid_file"
    info "Replace job started in background (pid $!). Log: $log_file"
    printf '{"pid":%d,"log":"%s","status_file":"%s"}\n' "$!" "$log_file" "$status_file"
}

cmd_replace_disk_status() {
    local slot="${1:-}"
    [ -z "$slot" ] && die "Usage: freeraid replace-disk-status <slot>"
    local run_dir="/var/run/freeraid"
    local pid_file="$run_dir/replace-${slot}.pid"
    local log_file="/var/log/freeraid-replace-${slot}.log"
    local status_file="$run_dir/replace-${slot}.status"

    if [ ! -f "$pid_file" ]; then
        printf '{"running":false,"exit":null,"log":""}\n'
        return
    fi

    local pid; pid=$(cat "$pid_file")
    local running=false exit_code="null" last_lines=""

    if kill -0 "$pid" 2>/dev/null; then
        running=true
    else
        local raw_status
        raw_status=$(cat "$status_file" 2>/dev/null || echo "")
        [[ "$raw_status" =~ ^[0-9]+$ ]] && exit_code="$raw_status"
    fi

    [ -f "$log_file" ] && last_lines=$(tail -5 "$log_file" 2>/dev/null | jq -Rs .)

    printf '{"running":%s,"exit":%s,"log":%s}\n' \
        "$running" "$exit_code" "${last_lines:-\"\"}"
}

# Scan all currently-mounted drives and update UUIDs/serials in config
cmd_registry_sync() {
    info "Syncing drive registry (UUID/serial) from currently-mounted drives..."
    local updated=0

    while IFS=' ' read -r slot dev mnt; do
        [ -b "$dev" ] || continue
        local uuid serial
        uuid=$(get_disk_uuid "$dev")
        serial=$(get_disk_serial "$dev")
        [ -z "$uuid" ] && continue
        jq --arg s "$slot" --arg u "$uuid" --arg sr "$serial" \
           '(.array.disks[] | select(.slot==$s)) |= . + {"uuid":$u,"serial":$sr}' \
           "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
        info "  $slot ($dev): uuid=$uuid serial=${serial:-unknown}"
        updated=$((updated + 1))
    done < <(jq -r '.array.disks[] | .slot + " " + .device + " " + .mountpoint' "$CONFIG_FILE")

    # Also parity drives
    while IFS=' ' read -r slot dev mnt; do
        [ -b "$dev" ] || continue
        local uuid serial
        uuid=$(get_disk_uuid "$dev")
        serial=$(get_disk_serial "$dev")
        [ -z "$uuid" ] && continue
        jq --arg s "$slot" --arg u "$uuid" --arg sr "$serial" \
           '(.array.parity[] | select(.slot==$s)) |= . + {"uuid":$u,"serial":$sr}' \
           "$CONFIG_FILE" > /tmp/freeraid.conf.tmp && mv /tmp/freeraid.conf.tmp "$CONFIG_FILE"
        info "  $slot ($dev): uuid=$uuid serial=${serial:-unknown}"
        updated=$((updated + 1))
    done < <(jq -r '.array.parity[] | .slot + " " + .device + " " + .mountpoint' "$CONFIG_FILE")

    info "Registry updated for $updated drives."
}

