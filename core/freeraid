    local log_file="/var/log/freeraid-replace-${slot}.log"
    local status_file="$run_dir/replace-${slot}.status"

    # Check if already running
    if [ -f "$pid_file" ]; then
        local old_pid; old_pid=$(cat "$pid_file")
        if kill -0 "$old_pid" 2>/dev/null; then
