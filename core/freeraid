cmd_apps_install() {
    local name="${1:-}" config_json="${2:-[]}"
    [ -z "$name" ] && die "Usage: freeraid apps-install <name> [config-json]"
    [ -f "$APPFEED_CACHE" ] || die "App feed not cached. Run: freeraid apps-fetch"

    python3 - "$APPFEED_CACHE" "$name" "$config_json" "$COMPOSE_DIR" <<'PYEOF'
import sys, json, os, re

apps       = json.load(open(sys.argv[1]))
name       = sys.argv[2]
user_cfg   = json.loads(sys.argv[3])   # list of {type, target, value}
compose_dir = sys.argv[4]

app = next((a for a in apps if a['name'].lower() == name.lower()), None)
if not app:
    print(json.dumps({'error': f'App not found: {name}'}))
    sys.exit(1)

# Extract special freeraid.* entries from user config before merging
network_entry = next((c for c in user_cfg if c.get('type') == 'freeraid.network'), None)
network_ip_entry = next((c for c in user_cfg if c.get('type') == 'freeraid.network_ip'), None)
plain_cfg = [c for c in user_cfg if c.get('type') not in ('freeraid.network', 'freeraid.network_ip')]

# Merge user config values into template config
cfg_map = {c['target']: c['value'] for c in plain_cfg}
resolved = []
for c in app.get('config', []):
    val = cfg_map.get(c['target'], c.get('default', ''))
    # Remap Unraid default appdata paths to FreeRAID paths
    if c.get('type','').lower() == 'path' and isinstance(val, str):
        val = val.replace('/mnt/user/appdata/', '/mnt/freeraid/appdata/')
        val = val.replace('/mnt/user/', '/mnt/freeraid/')
    resolved.append({**c, 'value': val})

# Build compose
slug = re.sub(r'[^a-z0-9_-]', '-', name.lower()).strip('-')
image = app['image']
# Network: prefer user override, then app default, then bridge
network = (network_entry['value'] if network_entry else None) or app.get('network', 'bridge')
network_ip = network_ip_entry['value'] if network_ip_entry else ''

is_host_network = network.lower() == 'host'
# For custom networks (not bridge/host/none) we use 'networks:' block instead of network_mode
is_custom_network = network.lower() not in ('bridge', 'host', 'none', '')

ports, volumes, env, devices = [], [], [], []
for c in resolved:
    t = c.get('type','').lower()
    val = c.get('value') or c.get('default','')
    target = c.get('target','')
    mode = c.get('mode','rw')
    if not target:
        continue
    if t == 'port' and val and not is_host_network:
        proto = mode.lower() if mode.lower() in ('tcp','udp') else 'tcp'
        host_port = val
        ports.append(f'      - "{host_port}:{target}/{proto}"')
    elif t == 'path' and val:
        volumes.append(f'      - "{val}:{target}:{mode}"')
    elif t in ('variable', 'env') and target:
        env.append(f'      - {target}={val}')
    elif t == 'device' and val:
        devices.append(f'      - {val}:{target}')

lines = [
    f'services:',
    f'  {slug}:',
    f'    image: {image}',
    f'    container_name: {slug}',
    f'    restart: unless-stopped',
]
if is_custom_network:
    # Use networks: block so container joins the named network with optional static IP
    lines.append(f'    networks:')
    lines.append(f'      {network}:')
    if network_ip:
        lines.append(f'        ipv4_address: {network_ip}')
    lines.append(f'networks:')
    lines.append(f'  {network}:')
    lines.append(f'    external: true')
elif network and network.lower() not in ('none',''):
    lines.append(f'    network_mode: {network}')
if ports:
    lines.append('    ports:')
    lines.extend(ports)
if volumes:
    lines.append('    volumes:')
    lines.extend(volumes)
if env:
    lines.append('    environment:')
    lines.extend(env)
if devices:
    lines.append('    devices:')
    lines.extend(devices)
# Store metadata as labels for runtime retrieval
webui = app.get('webui', '')
lines.append('    labels:')
lines.append(f'      - "freeraid.name={name}"')
if webui:
    lines.append(f'      - "freeraid.webui={webui}"')

compose = '\n'.join(lines) + '\n'
os.makedirs(compose_dir, exist_ok=True)
out_path = os.path.join(compose_dir, f'{slug}.docker-compose.yml')
with open(out_path, 'w') as f:
    f.write(compose)

print(json.dumps({'ok': True, 'slug': slug, 'path': out_path, 'compose': compose}))
PYEOF
}

cmd_docker_get_config() {
    local name="${1:-}"
    [ -z "$name" ] && die "Usage: freeraid docker-get-config <name>"
    local f="${COMPOSE_DIR}/${name}.docker-compose.yml"
    [ -f "$f" ] || die "No compose file for: $name"

    python3 - "$f" "$name" <<'PYEOF'
import sys, json, re, os

fpath = sys.argv[1]
name  = sys.argv[2]

try:
    import yaml
    data = yaml.safe_load(open(fpath).read())
except ImportError:
    # Manual minimal YAML parser for our predictable compose format
    import re as _re
    data = {'services': {}, 'networks': {}}
    cur_svc = None
    cur_key = None
    svc_block = False
    net_block = False
    lines = open(fpath).readlines()
    for line in lines:
        stripped = line.rstrip()
        indent = len(stripped) - len(stripped.lstrip())
        val = stripped.strip()
        if val == 'services:':
            svc_block = True; net_block = False; continue
        if val == 'networks:':
            svc_block = False; net_block = True; continue
        if svc_block and indent == 2 and val.endswith(':'):
            cur_svc = val[:-1]
            data['services'][cur_svc] = {'ports':[],'volumes':[],'environment':[],'labels':[]}
        elif cur_svc and indent == 4:
            m = _re.match(r'(\w[\w_-]*):\s*(.*)', val)
            if m:
                cur_key = m.group(1)
                v = m.group(2)
                if v:
                    data['services'][cur_svc][cur_key] = v
                else:
                    data['services'][cur_svc].setdefault(cur_key, [])
        elif cur_svc and indent == 6 and cur_key and isinstance(data['services'][cur_svc].get(cur_key), list):
            data['services'][cur_svc][cur_key].append(val.lstrip('- ').strip('"\''))

svc = data.get('services', {})
svc_data = svc.get(name) or (list(svc.values())[0] if svc else {})

image = svc_data.get('image', '')
network_mode = svc_data.get('network_mode', 'bridge')
network_name = network_mode
network_ip = ''

# Check for networks: block (custom network mode)
svc_nets = svc_data.get('networks', {})
if isinstance(svc_nets, dict) and svc_nets:
    network_name = list(svc_nets.keys())[0]
    net_cfg = svc_nets[network_name]
    if isinstance(net_cfg, dict):
        network_ip = net_cfg.get('ipv4_address', '')

# Parse labels
labels = {}
for lbl in svc_data.get('labels', []):
    s = str(lbl).strip('"\'')
    if '=' in s:
        k, v = s.split('=', 1)
        labels[k] = v

webui    = labels.get('freeraid.webui', '')
app_name = labels.get('freeraid.name', name)

# Build config items from current compose
config = []
for port in svc_data.get('ports', []):
    s = str(port).strip('"\'')
    m = re.match(r'(\d+):(\d+)(?:/(tcp|udp))?', s)
    if m:
        host_p, cont_p, proto = m.group(1), m.group(2), (m.group(3) or 'tcp')
        config.append({'type':'Port','target':cont_p,'name':f'Port {cont_p}/{proto}','default':host_p,'mode':proto})

for vol in svc_data.get('volumes', []):
    s = str(vol).strip('"\'')
    parts = s.split(':')
    if len(parts) >= 2:
        config.append({'type':'Path','target':parts[1],'name':parts[1],
                       'default':parts[0],'mode':parts[2] if len(parts)>2 else 'rw'})

for env in svc_data.get('environment', []):
    s = str(env).strip('"\'')
    if '=' in s:
        k, v = s.split('=', 1)
        config.append({'type':'Variable','target':k,'name':k,'default':v})

print(json.dumps({
    'name': app_name, 'image': image,
    'network': network_name, 'network_ip': network_ip,
    'webui': webui, 'config': config, '_is_edit': True
}))
PYEOF
}

cmd_docker_network_list() {
    docker network ls --format '{{json .}}' 2>/dev/null | python3 -c "
import sys, json, subprocess
nets = []
for line in sys.stdin:
    line = line.strip()
    if not line: continue
    try:
        n = json.loads(line)
    except: continue
    nid = n.get('ID','')
    name = n.get('Name','')
    driver = n.get('Driver','')
    # Skip built-in defaults
    if name in ('bridge','host','none'): continue
    # Get subnet
    try:
        info = json.loads(subprocess.check_output(['docker','network','inspect',nid], stderr=subprocess.DEVNULL))
        cfg = info[0].get('IPAM',{}).get('Config',[{}])
        subnet = cfg[0].get('Subnet','') if cfg else ''
    except:
        subnet = ''
    nets.append({'id':nid[:12],'name':name,'driver':driver,'subnet':subnet})
print(json.dumps(nets))
"
}

cmd_docker_network_create() {
    local net_name="${1:-}" parent="${2:-}" subnet="${3:-}" gateway="${4:-}"
