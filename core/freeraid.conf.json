{
  "_version": "1",
  "_schema": "freeraid-config",
  "system": {
    "hostname": "freeraid",
    "timezone": "America/Chicago",
    "language": "en_US"
  },
  "array": {
    "state": "stopped",
    "parity": [],
    "disks": [],
    "cache": [],
    "pool_mountpoint": "/mnt/user",
    "mergerfs_options": "defaults,allow_other,use_ino,cache.files=off,dropcacheonclose=true,category.create=mfs"
  },
  "snapraid": {
    "sync_schedule": "0 3 * * *",
    "scrub_schedule": "0 4 * * 0",
    "scrub_percent": 22,
    "scrub_age": 10,
    "diff_warn_deleted": 40,
    "diff_warn_updated": 40,
    "content_files": [],
    "exclude": [
      "/lost+found/",
      "*.tmp",
      "*.!qB",
      "*.part"
    ]
  },
  "pools": [],
  "shares": [],
  "samba_anon": true,
  "network": {
    "interface": "",
    "dhcp": true,
    "ip": "",
    "gateway": "",
    "dns": [
      "1.1.1.1",
      "8.8.8.8"
    ]
  },
  "docker": {
    "enabled": true,
    "data_root": "/mnt/user/appdata",
    "compose_dir": "/etc/freeraid/compose",
    "autoupdate": {}
  },
  "notifications": {
    "email": {
      "enabled": false,
      "smtp_host": "",
      "smtp_port": "587",
      "smtp_user": "",
      "smtp_pass": "",
      "smtp_from": "",
      "smtp_to": ""
    },
    "webhook": {
      "enabled": false,
      "url": "",
      "type": "discord"
    },
    "events": {
      "array_degraded": true,
      "drive_temp": true,
      "sync_error": true,
      "scrub_error": true,
      "update_available": false,
      "container_updated": false
    },
    "temp_threshold": 55
  }
}
